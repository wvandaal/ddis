   {:e #blake3 "f2d860022d89346aa3f74e2a0cfd8aa08b0956b8ae5e85d2a5e212e358eecaf5" :a :db/doc :v "Semi-Naive Termination" :op :assert}
   {:e #blake3 "f2d860022d89346aa3f74e2a0cfd8aa08b0956b8ae5e85d2a5e212e358eecaf5" :a :spec/source-file :v "03-query.md" :op :assert}
   {:e #blake3 "f2d860022d89346aa3f74e2a0cfd8aa08b0956b8ae5e85d2a5e212e358eecaf5" :a :element/body :v "**Traces to**: ADRS FD-003\n**Verification**: `V:PROP`\n**Stage**: 0\n\n#### Level 0 (Algebraic Law)\n```\nSemi-naive evaluation terminates iff the Datalog program is safe\n(every variable in the head appears in a positive body literal).\nBraid restricts to safe Datalog programs.\n\nTermination: ΔT_P^(i+1) = ∅ after finitely many iterations\n(because the Herbrand base is finite for a finite store).\n```\n\n#### Level 1 (State Invariant)\nThe parser rejects unsafe Datalog programs (unbound head variables).\nEvaluation always terminates.\n\n**Falsification**: A query that runs indefinitely (non-terminating fixpoint computation).\n\n---" :op :assert}
   {:e #blake3 "f2d860022d89346aa3f74e2a0cfd8aa08b0956b8ae5e85d2a5e212e358eecaf5" :a :spec/statement :v "``` Semi-naive evaluation terminates iff the Datalog program is safe (every variable in the head appears in a positive body literal). Braid restricts to safe Datalog programs. Termination: ΔT_P^(i+1) = ∅ after finitely many iterations (because the Herbrand base is finite for a finite store). ```" :op :assert}
   {:e #blake3 "f2d860022d89346aa3f74e2a0cfd8aa08b0956b8ae5e85d2a5e212e358eecaf5" :a :spec/falsification :v "A query that runs indefinitely (non-terminating fixpoint computation)." :op :assert}
   {:e #blake3 "f2d860022d89346aa3f74e2a0cfd8aa08b0956b8ae5e85d2a5e212e358eecaf5" :a :element/traces-to :v "ADRS FD-003" :op :assert}
   {:e #blake3 "f2d860022d89346aa3f74e2a0cfd8aa08b0956b8ae5e85d2a5e212e358eecaf5" :a :spec/verification :v "`V:PROP`" :op :assert}
