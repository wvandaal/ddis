   {:e #blake3 "f0b883930ec049de92aadec22b712a3f917ae46ec27e570c495f977956e0fa36" :a :spec/element-type :v :spec.element/invariant :op :assert}
   {:e #blake3 "f0b883930ec049de92aadec22b712a3f917ae46ec27e570c495f977956e0fa36" :a :spec/namespace :v :spec.ns/guidance :op :assert}
   {:e #blake3 "f0b883930ec049de92aadec22b712a3f917ae46ec27e570c495f977956e0fa36" :a :db/doc :v "Intention-Action Coherence" :op :assert}
   {:e #blake3 "f0b883930ec049de92aadec22b712a3f917ae46ec27e570c495f977956e0fa36" :a :spec/source-file :v "12-guidance.md" :op :assert}
   {:e #blake3 "f0b883930ec049de92aadec22b712a3f917ae46ec27e570c495f977956e0fa36" :a :element/body :v "**Traces to**: ADRS GU-008\n**Verification**: `V:PROP`\n**Stage**: 1\n\n#### Level 0 (Algebraic Law)\n`∀ action a, intention i:\n  postconditions(a) ∩ goals(i) ≠ ∅ ⟹ score(a) += intention_alignment_bonus`\n\nActions that advance active intentions are scored higher in guidance output.\n\n#### Level 1 (State Invariant)\nThe QUERY_GUIDANCE transition computes intersection between action postconditions\nand active intention goals. Non-empty intersection adds a bonus to action score.\n\n**Falsification**: An action that advances an active intention is scored\nidentically to an action that does not.\n\n---" :op :assert}
   {:e #blake3 "f0b883930ec049de92aadec22b712a3f917ae46ec27e570c495f977956e0fa36" :a :spec/statement :v "`∀ action a, intention i: postconditions(a) ∩ goals(i) ≠ ∅ ⟹ score(a) += intention_alignment_bonus` Actions that advance active intentions are scored higher in guidance output." :op :assert}
   {:e #blake3 "f0b883930ec049de92aadec22b712a3f917ae46ec27e570c495f977956e0fa36" :a :spec/falsification :v "An action that advances an active intention is scored identically to an action that does not." :op :assert}
   {:e #blake3 "f0b883930ec049de92aadec22b712a3f917ae46ec27e570c495f977956e0fa36" :a :element/traces-to :v "ADRS GU-008" :op :assert}
   {:e #blake3 "f0b883930ec049de92aadec22b712a3f917ae46ec27e570c495f977956e0fa36" :a :spec/verification :v "`V:PROP`" :op :assert}
   {:e #blake3 "77ea17864d9a881321883b7cfb853e584cab92726946d10efb364523275e89eb" :a :db/ident :v :spec/inv-guidance-004 :op :assert}
   {:e #blake3 "77ea17864d9a881321883b7cfb853e584cab92726946d10efb364523275e89eb" :a :spec/element-type :v :spec.element/invariant :op :assert}
   {:e #blake3 "77ea17864d9a881321883b7cfb853e584cab92726946d10efb364523275e89eb" :a :spec/namespace :v :spec.ns/guidance :op :assert}
   {:e #blake3 "77ea17864d9a881321883b7cfb853e584cab92726946d10efb364523275e89eb" :a :db/doc :v "Drift Detection Responsiveness" :op :assert}
   {:e #blake3 "77ea17864d9a881321883b7cfb853e584cab92726946d10efb364523275e89eb" :a :spec/source-file :v "12-guidance.md" :op :assert}
   {:e #blake3 "77ea17864d9a881321883b7cfb853e584cab92726946d10efb364523275e89eb" :a :element/body :v "**Traces to**: ADRS GU-007 (mechanism 3)\n**Verification**: `V:PROP`\n**Stage**: 1\n\n#### Level 0 (Algebraic Law)\n`transact_gap > 5 ⟹ drift_signal_emitted`\nIf an agent executes more than 5 bash commands without a transact, the drift\ndetection mechanism emits a GoalDrift signal.\n\n#### Level 1 (State Invariant)\nThe DETECT_DRIFT transition monitors the access log for transact gaps and\ntool absence patterns. When thresholds are exceeded, a signal is emitted.\n\n**Falsification**: An agent executes 10+ bash commands without a transact\nand no drift signal is emitted.\n\n---" :op :assert}
   {:e #blake3 "77ea17864d9a881321883b7cfb853e584cab92726946d10efb364523275e89eb" :a :spec/statement :v "`transact_gap > 5 ⟹ drift_signal_emitted` If an agent executes more than 5 bash commands without a transact, the drift detection mechanism emits a GoalDrift signal." :op :assert}
   {:e #blake3 "77ea17864d9a881321883b7cfb853e584cab92726946d10efb364523275e89eb" :a :spec/falsification :v "An agent executes 10+ bash commands without a transact and no drift signal is emitted." :op :assert}
   {:e #blake3 "77ea17864d9a881321883b7cfb853e584cab92726946d10efb364523275e89eb" :a :element/traces-to :v "ADRS GU-007 (mechanism 3)" :op :assert}
