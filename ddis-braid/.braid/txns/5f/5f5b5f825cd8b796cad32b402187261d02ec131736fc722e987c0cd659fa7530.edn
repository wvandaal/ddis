   {:e #blake3 "223eb58ba4880a5fcc4aa3908e5ba1ee625c6ae8e52fdb2428629c6982d321e9" :a :db/doc :v "Diamond Lattice Signal Generation" :op :assert}
   {:e #blake3 "223eb58ba4880a5fcc4aa3908e5ba1ee625c6ae8e52fdb2428629c6982d321e9" :a :spec/source-file :v "02-schema.md" :op :assert}
   {:e #blake3 "223eb58ba4880a5fcc4aa3908e5ba1ee625c6ae8e52fdb2428629c6982d321e9" :a :element/body :v "**Traces to**: ADRS AS-009, SR-010\n**Verification**: `V:PROP`\n**Stage**: 2\n\n#### Level 0 (Algebraic Law)\n```\nFor lattices with diamond structure (two incomparable top elements):\n  join(a, b) where a ⊥ b = error_signal_element\n\nExample: challenge-verdict lattice\n  :confirmed ⊥ :refuted (incomparable)\n  join(:confirmed, :refuted) = :contradicted (error signal)\n```\n\n#### Level 1 (State Invariant)\nWhen concurrent assertions produce incomparable lattice values, the join operation\nproduces a first-class error signal (the top of the diamond), which triggers the\ncoordination layer's conflict detection.\n\n**Falsification**: Two incomparable lattice values that silently merge without producing\na coordination signal.\n\n---" :op :assert}
   {:e #blake3 "223eb58ba4880a5fcc4aa3908e5ba1ee625c6ae8e52fdb2428629c6982d321e9" :a :spec/statement :v "``` For lattices with diamond structure (two incomparable top elements): join(a, b) where a ⊥ b = error_signal_element Example: challenge-verdict lattice :confirmed ⊥ :refuted (incomparable) join(:confirmed, :refuted) = :contradicted (error signal) ```" :op :assert}
   {:e #blake3 "223eb58ba4880a5fcc4aa3908e5ba1ee625c6ae8e52fdb2428629c6982d321e9" :a :spec/falsification :v "Two incomparable lattice values that silently merge without producing a coordination signal." :op :assert}
   {:e #blake3 "223eb58ba4880a5fcc4aa3908e5ba1ee625c6ae8e52fdb2428629c6982d321e9" :a :element/traces-to :v "ADRS AS-009, SR-010" :op :assert}
