   {:e #blake3 "2bd6362a5aa9d68aa2ecc884ca2eb7d70375260bbcae63f4813dd566e720852f" :a :spec/namespace :v :spec.ns/bootstrap :op :assert}
   {:e #blake3 "2bd6362a5aa9d68aa2ecc884ca2eb7d70375260bbcae63f4813dd566e720852f" :a :db/doc :v "Content-Only Bootstrap Produces Flat Store" :op :assert}
   {:e #blake3 "2bd6362a5aa9d68aa2ecc884ca2eb7d70375260bbcae63f4813dd566e720852f" :a :spec/source-file :v "02-schema.md" :op :assert}
   {:e #blake3 "2bd6362a5aa9d68aa2ecc884ca2eb7d70375260bbcae63f4813dd566e720852f" :a :element/body :v "**Traces to**: SEED §4 (C7), exploration/11-topology-as-compilation.md §2.2\n**Verification**: `V:PROP`\n\n**Statement**: A self-bootstrap that transacts spec element content (id, type,\nstatement, falsification) but NOT dependency relationships (`:spec/depends-on`,\n`:spec/affects`, `:spec/constrains`, `:spec/tests`) produces a store where:\n  - Spec elements exist as isolated entities\n  - No dependency graph is queryable\n  - The compilation front-end (exploration doc 11 §2.2) has no input data\n  - Contradiction detection cannot trace dependency chains\n  - Impact analysis queries return empty results\n\n**Safety property**: `□(bootstrap_complete → dependency_edges > 0)`\n\n**Violation condition**: After bootstrap, the query\n  `[:find (count ?e) :where [?e :spec/depends-on _]]`\nreturns 0 while spec elements with prose dependencies exist.\n\n---" :op :assert}
   {:e #blake3 "2bd6362a5aa9d68aa2ecc884ca2eb7d70375260bbcae63f4813dd566e720852f" :a :spec/statement :v "`□(bootstrap_complete → dependency_edges > 0)`" :op :assert}
   {:e #blake3 "2bd6362a5aa9d68aa2ecc884ca2eb7d70375260bbcae63f4813dd566e720852f" :a :element/traces-to :v "SEED §4 (C7), exploration/11-topology-as-compilation.md §2.2" :op :assert}
   {:e #blake3 "2bd6362a5aa9d68aa2ecc884ca2eb7d70375260bbcae63f4813dd566e720852f" :a :spec/verification :v "`V:PROP`" :op :assert}
   {:e #blake3 "2bd6362a5aa9d68aa2ecc884ca2eb7d70375260bbcae63f4813dd566e720852f" :a :neg/violation :v "`□(bootstrap_complete → dependency_edges > 0)`" :op :assert}
