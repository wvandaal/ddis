   {:e #blake3 "407702c4bb7ec0eef2d7d8aa7a5711fba741417db76d1f6498024444dd25ce0c" :a :spec/element-type :v :spec.element/invariant :op :assert}
   {:e #blake3 "407702c4bb7ec0eef2d7d8aa7a5711fba741417db76d1f6498024444dd25ce0c" :a :spec/namespace :v :spec.ns/merge :op :assert}
   {:e #blake3 "407702c4bb7ec0eef2d7d8aa7a5711fba741417db76d1f6498024444dd25ce0c" :a :db/doc :v "Merge Is Set Union" :op :assert}
   {:e #blake3 "407702c4bb7ec0eef2d7d8aa7a5711fba741417db76d1f6498024444dd25ce0c" :a :spec/source-file :v "07-merge.md" :op :assert}
   {:e #blake3 "407702c4bb7ec0eef2d7d8aa7a5711fba741417db76d1f6498024444dd25ce0c" :a :element/body :v "**Traces to**: SEED §4, C4, ADRS AS-001\n**Verification**: `V:PROP`, `V:KANI`\n**Stage**: 0\n\n#### Level 0 (Algebraic Law)\n```\n∀ S₁, S₂: MERGE(S₁, S₂).datoms = S₁.datoms ∪ S₂.datoms\n  (no heuristics, no resolution, no filtering — pure set union)\n```\n\n#### Level 1 (State Invariant)\nThe merge operation at the store level is exactly set union. All conflict detection,\nresolution, and cascade effects are post-merge operations, not part of merge itself.\n\n**Falsification**: A merge operation that produces a datom set different from the\nmathematical set union of the two input sets.\n\n---" :op :assert}
   {:e #blake3 "407702c4bb7ec0eef2d7d8aa7a5711fba741417db76d1f6498024444dd25ce0c" :a :spec/statement :v "``` ∀ S₁, S₂: MERGE(S₁, S₂).datoms = S₁.datoms ∪ S₂.datoms (no heuristics, no resolution, no filtering — pure set union) ```" :op :assert}
   {:e #blake3 "407702c4bb7ec0eef2d7d8aa7a5711fba741417db76d1f6498024444dd25ce0c" :a :spec/falsification :v "A merge operation that produces a datom set different from the mathematical set union of the two input sets." :op :assert}
   {:e #blake3 "407702c4bb7ec0eef2d7d8aa7a5711fba741417db76d1f6498024444dd25ce0c" :a :element/traces-to :v "SEED §4, C4, ADRS AS-001" :op :assert}
   {:e #blake3 "407702c4bb7ec0eef2d7d8aa7a5711fba741417db76d1f6498024444dd25ce0c" :a :spec/verification :v "`V:PROP`, `V:KANI`" :op :assert}
   {:e #blake3 "92dad8f62f1a61e375e24cbc4d0c55c3ab57f80868a9b8187dc568c3e2b3458b" :a :db/ident :v :spec/inv-merge-002 :op :assert}
   {:e #blake3 "92dad8f62f1a61e375e24cbc4d0c55c3ab57f80868a9b8187dc568c3e2b3458b" :a :spec/element-type :v :spec.element/invariant :op :assert}
   {:e #blake3 "92dad8f62f1a61e375e24cbc4d0c55c3ab57f80868a9b8187dc568c3e2b3458b" :a :spec/namespace :v :spec.ns/merge :op :assert}
   {:e #blake3 "92dad8f62f1a61e375e24cbc4d0c55c3ab57f80868a9b8187dc568c3e2b3458b" :a :db/doc :v "Merge Cascade Completeness" :op :assert}
   {:e #blake3 "92dad8f62f1a61e375e24cbc4d0c55c3ab57f80868a9b8187dc568c3e2b3458b" :a :spec/source-file :v "07-merge.md" :op :assert}
   {:e #blake3 "92dad8f62f1a61e375e24cbc4d0c55c3ab57f80868a9b8187dc568c3e2b3458b" :a :element/body :v "**Traces to**: ADRS PO-006\n**Verification**: `V:PROP`, `V:MODEL`\n**Stage**: 0\n\n#### Level 0 (Algebraic Law)\n```\n∀ merge operations MERGE(S₁, S₂):\n  all 5 cascade steps execute:\n    (1) conflict detection, (2) cache invalidation,\n    (3) projection staleness, (4) uncertainty update,\n    (5) subscription notification\n  all cascade steps produce datoms\n```\n\n#### Level 1 (State Invariant)\nNo cascade step is skipped. Each step produces datoms recording its effects.\nThe merge cascade is atomic — either all 5 steps complete or the merge fails.\n\n**Falsification**: A merge that completes without running conflict detection,\nor a cascade step that produces no datom trail.\n\n**Stateright model**: Model merge operations between 3 agents. Verify that\nevery merge triggers all 5 cascade steps in all interleavings.\n\n---" :op :assert}
   {:e #blake3 "92dad8f62f1a61e375e24cbc4d0c55c3ab57f80868a9b8187dc568c3e2b3458b" :a :spec/statement :v "``` ∀ merge operations MERGE(S₁, S₂): all 5 cascade steps execute: (1) conflict detection, (2) cache invalidation, (3) projection staleness, (4) uncertainty update, (5) subscription notification all cascade steps produce datoms ```" :op :assert}
   {:e #blake3 "92dad8f62f1a61e375e24cbc4d0c55c3ab57f80868a9b8187dc568c3e2b3458b" :a :spec/falsification :v "A merge that completes without running conflict detection, or a cascade step that produces no datom trail." :op :assert}
   {:e #blake3 "92dad8f62f1a61e375e24cbc4d0c55c3ab57f80868a9b8187dc568c3e2b3458b" :a :element/traces-to :v "ADRS PO-006" :op :assert}
   {:e #blake3 "92dad8f62f1a61e375e24cbc4d0c55c3ab57f80868a9b8187dc568c3e2b3458b" :a :spec/verification :v "`V:PROP`, `V:MODEL`" :op :assert}
   {:e #blake3 "4dd88393a93bbe3dd252e32f22a814e2b89e64788fadd2a40e578a1ad4e0f734" :a :db/ident :v :spec/inv-merge-003 :op :assert}
   {:e #blake3 "4dd88393a93bbe3dd252e32f22a814e2b89e64788fadd2a40e578a1ad4e0f734" :a :spec/element-type :v :spec.element/invariant :op :assert}
   {:e #blake3 "4dd88393a93bbe3dd252e32f22a814e2b89e64788fadd2a40e578a1ad4e0f734" :a :spec/namespace :v :spec.ns/merge :op :assert}
   {:e #blake3 "4dd88393a93bbe3dd252e32f22a814e2b89e64788fadd2a40e578a1ad4e0f734" :a :db/doc :v "Branch Isolation" :op :assert}
   {:e #blake3 "4dd88393a93bbe3dd252e32f22a814e2b89e64788fadd2a40e578a1ad4e0f734" :a :spec/source-file :v "07-merge.md" :op :assert}
   {:e #blake3 "4dd88393a93bbe3dd252e32f22a814e2b89e64788fadd2a40e578a1ad4e0f734" :a :element/body :v "**Traces to**: ADRS AS-003, AS-004\n**Verification**: `V:PROP`, `V:KANI`\n**Stage**: 2\n\n#### Level 0 (Algebraic Law)\n```\n∀ branches b₁, b₂ where b₁ ≠ b₂:\n  branch_datoms(b₁) ∩ visible(b₂) = ∅\n  (branches cannot see each other's uncommitted datoms)\n```\n\n#### Level 1 (State Invariant)\nA query against branch b₁ never returns datoms from branch b₂.\nBranch visibility is exactly: `{trunk datoms at fork point} ∪ {b₁'s own datoms}`.\n\n**Falsification**: A query against branch b₁ returning a datom from b₂.\n\n**proptest strategy**: Create two branches from the same fork point. Add different\ndatoms to each. Verify queries against each branch see only their own datoms.\n\n---" :op :assert}
   {:e #blake3 "4dd88393a93bbe3dd252e32f22a814e2b89e64788fadd2a40e578a1ad4e0f734" :a :spec/statement :v "``` ∀ branches b₁, b₂ where b₁ ≠ b₂: branch_datoms(b₁) ∩ visible(b₂) = ∅ (branches cannot see each other's uncommitted datoms) ```" :op :assert}
   {:e #blake3 "4dd88393a93bbe3dd252e32f22a814e2b89e64788fadd2a40e578a1ad4e0f734" :a :spec/falsification :v "A query against branch b₁ returning a datom from b₂." :op :assert}
   {:e #blake3 "4dd88393a93bbe3dd252e32f22a814e2b89e64788fadd2a40e578a1ad4e0f734" :a :element/traces-to :v "ADRS AS-003, AS-004" :op :assert}
   {:e #blake3 "4dd88393a93bbe3dd252e32f22a814e2b89e64788fadd2a40e578a1ad4e0f734" :a :spec/verification :v "`V:PROP`, `V:KANI`" :op :assert}
   {:e #blake3 "4c9e4172d2f35d4c9db9338ff83b9a4d1f4e79d46d9a649e5d2e047319b32de2" :a :db/ident :v :spec/inv-merge-004 :op :assert}
   {:e #blake3 "4c9e4172d2f35d4c9db9338ff83b9a4d1f4e79d46d9a649e5d2e047319b32de2" :a :spec/element-type :v :spec.element/invariant :op :assert}
   {:e #blake3 "4c9e4172d2f35d4c9db9338ff83b9a4d1f4e79d46d9a649e5d2e047319b32de2" :a :spec/namespace :v :spec.ns/merge :op :assert}
   {:e #blake3 "4c9e4172d2f35d4c9db9338ff83b9a4d1f4e79d46d9a649e5d2e047319b32de2" :a :db/doc :v "Competing Branch Lock" :op :assert}
   {:e #blake3 "4c9e4172d2f35d4c9db9338ff83b9a4d1f4e79d46d9a649e5d2e047319b32de2" :a :spec/source-file :v "07-merge.md" :op :assert}
   {:e #blake3 "4c9e4172d2f35d4c9db9338ff83b9a4d1f4e79d46d9a649e5d2e047319b32de2" :a :element/body :v "**Traces to**: ADRS AS-005, PO-007\n**Verification**: `V:PROP`, `V:KANI`, `V:MODEL`\n**Stage**: 2\n\n#### Level 0 (Algebraic Law)\n```\n∀ branches b₁, b₂ where b₁.competing_with = b₂:\n  COMMIT(b₁) is BLOCKED until:\n    ∃ comparison or deliberation resolving {b₁, b₂}\n```\n\n#### Level 1 (State Invariant)\nA branch marked as competing with another branch cannot be committed\nuntil a BranchComparison or Deliberation entity exists that resolves\nthe competition.\n\n**Falsification**: A competing branch committed without a prior comparison or deliberation.\n\n**Stateright model**: Two competing branches, two agents. Verify that no\ninterleaving allows commit without comparison.\n\n---" :op :assert}
   {:e #blake3 "4c9e4172d2f35d4c9db9338ff83b9a4d1f4e79d46d9a649e5d2e047319b32de2" :a :spec/statement :v "``` ∀ branches b₁, b₂ where b₁.competing_with = b₂: COMMIT(b₁) is BLOCKED until: ∃ comparison or deliberation resolving {b₁, b₂} ```" :op :assert}
   {:e #blake3 "4c9e4172d2f35d4c9db9338ff83b9a4d1f4e79d46d9a649e5d2e047319b32de2" :a :spec/falsification :v "A competing branch committed without a prior comparison or deliberation." :op :assert}
   {:e #blake3 "4c9e4172d2f35d4c9db9338ff83b9a4d1f4e79d46d9a649e5d2e047319b32de2" :a :element/traces-to :v "ADRS AS-005, PO-007" :op :assert}
   {:e #blake3 "4c9e4172d2f35d4c9db9338ff83b9a4d1f4e79d46d9a649e5d2e047319b32de2" :a :spec/verification :v "`V:PROP`, `V:KANI`, `V:MODEL`" :op :assert}
   {:e #blake3 "8b531a2bbece56585245fb96052bfa7a879f7983285c75759bdbba6c83b6d08c" :a :db/ident :v :spec/inv-merge-005 :op :assert}
   {:e #blake3 "8b531a2bbece56585245fb96052bfa7a879f7983285c75759bdbba6c83b6d08c" :a :spec/element-type :v :spec.element/invariant :op :assert}
   {:e #blake3 "8b531a2bbece56585245fb96052bfa7a879f7983285c75759bdbba6c83b6d08c" :a :spec/namespace :v :spec.ns/merge :op :assert}
   {:e #blake3 "8b531a2bbece56585245fb96052bfa7a879f7983285c75759bdbba6c83b6d08c" :a :db/doc :v "Branch Commit Monotonicity" :op :assert}
   {:e #blake3 "8b531a2bbece56585245fb96052bfa7a879f7983285c75759bdbba6c83b6d08c" :a :spec/source-file :v "07-merge.md" :op :assert}
   {:e #blake3 "8b531a2bbece56585245fb96052bfa7a879f7983285c75759bdbba6c83b6d08c" :a :element/body :v "**Traces to**: ADRS AS-003 Property P1\n**Verification**: `V:PROP`, `V:KANI`\n**Stage**: 2\n\n#### Level 0 (Algebraic Law)\n```\n∀ branch commits: commit(b, S) ⊇ S\n  (committing a branch only adds datoms to trunk)\n```\n\n#### Level 1 (State Invariant)\nBranch commit is a union operation: trunk grows, never shrinks.\n\n**Falsification**: A branch commit that removes datoms from trunk.\n\n---" :op :assert}
   {:e #blake3 "8b531a2bbece56585245fb96052bfa7a879f7983285c75759bdbba6c83b6d08c" :a :spec/statement :v "``` ∀ branch commits: commit(b, S) ⊇ S (committing a branch only adds datoms to trunk) ```" :op :assert}
   {:e #blake3 "8b531a2bbece56585245fb96052bfa7a879f7983285c75759bdbba6c83b6d08c" :a :spec/falsification :v "A branch commit that removes datoms from trunk." :op :assert}
   {:e #blake3 "8b531a2bbece56585245fb96052bfa7a879f7983285c75759bdbba6c83b6d08c" :a :element/traces-to :v "ADRS AS-003 Property P1" :op :assert}
   {:e #blake3 "8b531a2bbece56585245fb96052bfa7a879f7983285c75759bdbba6c83b6d08c" :a :spec/verification :v "`V:PROP`, `V:KANI`" :op :assert}
   {:e #blake3 "cd20eb7ab34d1512ada42309ca04eab7caa7999ff4031109c76f9f84fb03766c" :a :db/ident :v :spec/inv-merge-006 :op :assert}
   {:e #blake3 "cd20eb7ab34d1512ada42309ca04eab7caa7999ff4031109c76f9f84fb03766c" :a :spec/element-type :v :spec.element/invariant :op :assert}
   {:e #blake3 "cd20eb7ab34d1512ada42309ca04eab7caa7999ff4031109c76f9f84fb03766c" :a :spec/namespace :v :spec.ns/merge :op :assert}
   {:e #blake3 "cd20eb7ab34d1512ada42309ca04eab7caa7999ff4031109c76f9f84fb03766c" :a :db/doc :v "Branch as First-Class Entity" :op :assert}
   {:e #blake3 "cd20eb7ab34d1512ada42309ca04eab7caa7999ff4031109c76f9f84fb03766c" :a :spec/source-file :v "07-merge.md" :op :assert}
   {:e #blake3 "cd20eb7ab34d1512ada42309ca04eab7caa7999ff4031109c76f9f84fb03766c" :a :element/body :v "**Traces to**: ADRS AS-005\n**Verification**: `V:PROP`\n**Stage**: 2\n\n#### Level 0 (Algebraic Law)\n```\n∀ branches b: b is an entity in the datom store with:\n  :branch/ident, :branch/base-tx, :branch/agent,\n  :branch/status, :branch/purpose, :branch/competing-with\n```\n\n#### Level 1 (State Invariant)\nBranch metadata is queryable via the same Datalog engine as any other data.\nThe `:branch/competing-with` attribute enables the competing branch lock.\n\n**Falsification**: A branch whose metadata is not queryable via Datalog.\n\n---" :op :assert}
   {:e #blake3 "cd20eb7ab34d1512ada42309ca04eab7caa7999ff4031109c76f9f84fb03766c" :a :spec/statement :v "``` ∀ branches b: b is an entity in the datom store with: :branch/ident, :branch/base-tx, :branch/agent, :branch/status, :branch/purpose, :branch/competing-with ```" :op :assert}
   {:e #blake3 "cd20eb7ab34d1512ada42309ca04eab7caa7999ff4031109c76f9f84fb03766c" :a :spec/falsification :v "A branch whose metadata is not queryable via Datalog." :op :assert}
   {:e #blake3 "cd20eb7ab34d1512ada42309ca04eab7caa7999ff4031109c76f9f84fb03766c" :a :element/traces-to :v "ADRS AS-005" :op :assert}
   {:e #blake3 "cd20eb7ab34d1512ada42309ca04eab7caa7999ff4031109c76f9f84fb03766c" :a :spec/verification :v "`V:PROP`" :op :assert}
   {:e #blake3 "08c7445ba7817b057859f280ea0a499b3b497aa4d0dc019c647afc65e6799378" :a :db/ident :v :spec/inv-merge-007 :op :assert}
   {:e #blake3 "08c7445ba7817b057859f280ea0a499b3b497aa4d0dc019c647afc65e6799378" :a :spec/element-type :v :spec.element/invariant :op :assert}
   {:e #blake3 "08c7445ba7817b057859f280ea0a499b3b497aa4d0dc019c647afc65e6799378" :a :spec/namespace :v :spec.ns/merge :op :assert}
   {:e #blake3 "08c7445ba7817b057859f280ea0a499b3b497aa4d0dc019c647afc65e6799378" :a :db/doc :v "Bilateral Branch Duality" :op :assert}
   {:e #blake3 "08c7445ba7817b057859f280ea0a499b3b497aa4d0dc019c647afc65e6799378" :a :spec/source-file :v "07-merge.md" :op :assert}
   {:e #blake3 "08c7445ba7817b057859f280ea0a499b3b497aa4d0dc019c647afc65e6799378" :a :element/body :v "**Traces to**: ADRS AS-006\n**Verification**: `V:PROP`\n**Stage**: 2\n\n#### Level 0 (Algebraic Law)\n```\nThe DCC (diverge-compare-converge) pattern works identically:\n  Forward: spec → competing implementations → selection\n  Backward: implementation → competing spec updates → selection\nSame algebraic structure, same comparison machinery.\n```\n\n#### Level 1 (State Invariant)\nIf the system supports branching for implementation alternatives, it must\nalso support branching for specification alternatives.\n\n**Falsification**: The system supports implementation branches but requires\nlinear (non-branching) spec modifications.\n\n---" :op :assert}
   {:e #blake3 "08c7445ba7817b057859f280ea0a499b3b497aa4d0dc019c647afc65e6799378" :a :spec/statement :v "``` The DCC (diverge-compare-converge) pattern works identically: Forward: spec → competing implementations → selection Backward: implementation → competing spec updates → selection Same algebraic structure, same comparison machinery. ```" :op :assert}
   {:e #blake3 "08c7445ba7817b057859f280ea0a499b3b497aa4d0dc019c647afc65e6799378" :a :spec/falsification :v "The system supports implementation branches but requires linear (non-branching) spec modifications." :op :assert}
