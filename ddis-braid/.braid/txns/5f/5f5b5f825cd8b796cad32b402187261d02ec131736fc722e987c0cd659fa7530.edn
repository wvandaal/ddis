   {:e #blake3 "02971edde86430d49d1aab6870829e8ef81d521a1772922509ce4a7341fe65cb" :a :db/doc :v "Three CLI Output Modes" :op :assert}
   {:e #blake3 "02971edde86430d49d1aab6870829e8ef81d521a1772922509ce4a7341fe65cb" :a :spec/source-file :v "14-interface.md" :op :assert}
   {:e #blake3 "02971edde86430d49d1aab6870829e8ef81d521a1772922509ce4a7341fe65cb" :a :element/body :v "**Traces to**: ADRS IB-002\n**Verification**: `V:PROP`\n**Stage**: 0\n\n#### Level 0 (Algebraic Law)\nThe CLI produces output in exactly one of three modes per invocation:\nJson (machine-parseable), Agent (budget-constrained), Human (TTY-formatted).\nMode selection is explicit (flag) or inferred from terminal context.\n\n#### Level 1 (State Invariant)\nEvery CLI_COMMAND invocation selects exactly one mode. The mode determines\nformatting, token budget, and content selection.\n\n**Falsification**: A CLI command produces mixed-mode output (e.g., JSON with\nTTY escape codes, or agent-mode output without budget constraint).\n\n---" :op :assert}
   {:e #blake3 "02971edde86430d49d1aab6870829e8ef81d521a1772922509ce4a7341fe65cb" :a :spec/statement :v "The CLI produces output in exactly one of three modes per invocation: Json (machine-parseable), Agent (budget-constrained), Human (TTY-formatted). Mode selection is explicit (flag) or inferred from terminal context." :op :assert}
   {:e #blake3 "02971edde86430d49d1aab6870829e8ef81d521a1772922509ce4a7341fe65cb" :a :spec/falsification :v "A CLI command produces mixed-mode output (e.g., JSON with TTY escape codes, or agent-mode output without budget constraint)." :op :assert}
   {:e #blake3 "02971edde86430d49d1aab6870829e8ef81d521a1772922509ce4a7341fe65cb" :a :element/traces-to :v "ADRS IB-002" :op :assert}
