   {:e #blake3 "be35a17c00f33f6cf0938aac8c0e7a1791fc9ee7be5ecb3581a7e0d25af4a8d9" :a :spec/source-file :v "06-seed.md" :op :assert}
   {:e #blake3 "be35a17c00f33f6cf0938aac8c0e7a1791fc9ee7be5ecb3581a7e0d25af4a8d9" :a :element/body :v "**Traces to**: ADRS PO-002\n**Verification**: `V:PROP`, `V:KANI`\n**Stage**: 0\n\n#### Level 0 (Algebraic Law)\n```\n∀ ASSOCIATE operations with depth d and breadth b:\n  |result.entities| ≤ d × b\n```\n\n#### Level 1 (State Invariant)\nASSOCIATE graph expansion is bounded to prevent unbounded traversal.\nThe bound is `depth × breadth`, both configurable.\n\n**Falsification**: An ASSOCIATE result with more entities than `depth × breadth`.\n\n---" :op :assert}
