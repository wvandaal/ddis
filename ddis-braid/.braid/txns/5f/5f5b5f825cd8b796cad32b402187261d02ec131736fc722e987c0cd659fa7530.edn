   {:e #blake3 "e7490e24ee92e5ef650f1cfa9b5781b073006c0956a476ee1d55d6c00843b3aa" :a :db/doc :v "FP/FN Calibration" :op :assert}
   {:e #blake3 "e7490e24ee92e5ef650f1cfa9b5781b073006c0956a476ee1d55d6c00843b3aa" :a :spec/source-file :v "05-harvest.md" :op :assert}
   {:e #blake3 "e7490e24ee92e5ef650f1cfa9b5781b073006c0956a476ee1d55d6c00843b3aa" :a :element/body :v "**Traces to**: ADRS LM-006\n**Verification**: `V:PROP`\n**Stage**: 1\n\n#### Level 0 (Algebraic Law)\n```\n∀ committed candidates c:\n  if c is later retracted: FP_count += 1\n∀ rejected candidates c:\n  if c's knowledge is later re-discovered: FN_count += 1\n\nCalibration rule:\n  FP_rate > threshold → raise extraction confidence threshold\n  FN_rate > threshold → lower extraction confidence threshold\n  Both high → improve extractor (not just thresholds)\n```\n\n#### Level 1 (State Invariant)\nThe harvest system tracks empirical quality and adjusts thresholds.\nFalse positives and false negatives are both measurable from the store.\n\n**Falsification**: Harvest thresholds that never adjust despite persistent FP/FN rates.\n\n---" :op :assert}
   {:e #blake3 "e7490e24ee92e5ef650f1cfa9b5781b073006c0956a476ee1d55d6c00843b3aa" :a :spec/statement :v "``` ∀ committed candidates c: if c is later retracted: FP_count += 1 ∀ rejected candidates c: if c's knowledge is later re-discovered: FN_count += 1 Calibration rule: FP_rate > threshold → raise extraction confidence threshold FN_rate > threshold → lower extraction confidence threshold Both high → improve extractor (not just thresholds) ```" :op :assert}
   {:e #blake3 "e7490e24ee92e5ef650f1cfa9b5781b073006c0956a476ee1d55d6c00843b3aa" :a :spec/falsification :v "Harvest thresholds that never adjust despite persistent FP/FN rates." :op :assert}
