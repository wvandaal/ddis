   {:e #blake3 "8e74e26ee8eb40b4a45a284de09dc4ad40cc72f0f66ad0892046987cb0d3c7e7" :a :spec/element-type :v :spec.element/adr :op :assert}
   {:e #blake3 "8e74e26ee8eb40b4a45a284de09dc4ad40cc72f0f66ad0892046987cb0d3c7e7" :a :spec/namespace :v :spec.ns/guidance :op :assert}
   {:e #blake3 "8e74e26ee8eb40b4a45a284de09dc4ad40cc72f0f66ad0892046987cb0d3c7e7" :a :db/doc :v "Comonadic Topology Over Flat Rules" :op :assert}
   {:e #blake3 "8e74e26ee8eb40b4a45a284de09dc4ad40cc72f0f66ad0892046987cb0d3c7e7" :a :spec/source-file :v "12-guidance.md" :op :assert}
   {:e #blake3 "8e74e26ee8eb40b4a45a284de09dc4ad40cc72f0f66ad0892046987cb0d3c7e7" :a :element/body :v "**Traces to**: ADRS GU-001\n**Stage**: 1\n\n#### Problem\nHow should guidance be structured — flat rules or a graph topology?\n\n#### Decision\nComonadic topology: guidance nodes are entities with Datalog predicates.\nThe `(StoreState, A)` comonad means guidance is always contextualized by the\nfull store state. Nodes can be traversed, composed, and extended.\n\n#### Formal Justification\nFlat rules don't compose (interaction between rules is implicit and fragile).\nThe comonadic structure makes composition explicit: `extend` lifts a guidance\nfunction to operate over the full topology. Agents can contribute new guidance\nnodes that integrate with existing ones via graph edges.\n\n---" :op :assert}
   {:e #blake3 "8e74e26ee8eb40b4a45a284de09dc4ad40cc72f0f66ad0892046987cb0d3c7e7" :a :element/traces-to :v "ADRS GU-001" :op :assert}
   {:e #blake3 "8e74e26ee8eb40b4a45a284de09dc4ad40cc72f0f66ad0892046987cb0d3c7e7" :a :adr/problem :v "How should guidance be structured — flat rules or a graph topology?" :op :assert}
   {:e #blake3 "8e74e26ee8eb40b4a45a284de09dc4ad40cc72f0f66ad0892046987cb0d3c7e7" :a :adr/decision :v "Comonadic topology: guidance nodes are entities with Datalog predicates. The `(StoreState, A)` comonad means guidance is always contextualized by the full store state. Nodes can be traversed, composed, and extended." :op :assert}
   {:e #blake3 "4c06d78a3457a9f64c7151c2816a707c00b2abc12e1e06cc9ff241c17c6601c5" :a :db/ident :v :spec/adr-guidance-002 :op :assert}
   {:e #blake3 "4c06d78a3457a9f64c7151c2816a707c00b2abc12e1e06cc9ff241c17c6601c5" :a :spec/element-type :v :spec.element/adr :op :assert}
   {:e #blake3 "4c06d78a3457a9f64c7151c2816a707c00b2abc12e1e06cc9ff241c17c6601c5" :a :spec/namespace :v :spec.ns/guidance :op :assert}
   {:e #blake3 "4c06d78a3457a9f64c7151c2816a707c00b2abc12e1e06cc9ff241c17c6601c5" :a :db/doc :v "Basin Competition as Central Failure Model" :op :assert}
   {:e #blake3 "4c06d78a3457a9f64c7151c2816a707c00b2abc12e1e06cc9ff241c17c6601c5" :a :spec/source-file :v "12-guidance.md" :op :assert}
   {:e #blake3 "4c06d78a3457a9f64c7151c2816a707c00b2abc12e1e06cc9ff241c17c6601c5" :a :element/body :v "**Traces to**: ADRS GU-006\n**Stage**: 0\n\n#### Problem\nWhat is the primary failure mode in agent-methodology interaction?\n\n#### Decision\nBasin competition between DDIS methodology (Basin A) and pretrained coding patterns\n(Basin B). As k*_eff decreases, Basin B's pull increases. At crossover, Basin B\ncaptures the trajectory and the agent's own non-DDIS outputs reinforce it.\n\n#### Formal Justification\nThis is not a memory problem (bigger context doesn't help — it just delays\nthe crossover). It is a dynamical systems problem: two attractors competing for\ntrajectory. The six anti-drift mechanisms are energy injections that maintain\nBasin A dominance. Understanding this is prerequisite to designing effective\ncountermeasures.\n\n---" :op :assert}
   {:e #blake3 "4c06d78a3457a9f64c7151c2816a707c00b2abc12e1e06cc9ff241c17c6601c5" :a :element/traces-to :v "ADRS GU-006" :op :assert}
   {:e #blake3 "4c06d78a3457a9f64c7151c2816a707c00b2abc12e1e06cc9ff241c17c6601c5" :a :adr/problem :v "What is the primary failure mode in agent-methodology interaction?" :op :assert}
   {:e #blake3 "4c06d78a3457a9f64c7151c2816a707c00b2abc12e1e06cc9ff241c17c6601c5" :a :adr/decision :v "Basin competition between DDIS methodology (Basin A) and pretrained coding patterns (Basin B). As k*_eff decreases, Basin B's pull increases. At crossover, Basin B captures the trajectory and the agent's own non-DDIS outputs reinforce it." :op :assert}
   {:e #blake3 "cc90bbbd81dba284049e2ef0d60374c0c231f23d598a0d223916698dd7201dbe" :a :db/ident :v :spec/adr-guidance-003 :op :assert}
   {:e #blake3 "cc90bbbd81dba284049e2ef0d60374c0c231f23d598a0d223916698dd7201dbe" :a :spec/element-type :v :spec.element/adr :op :assert}
   {:e #blake3 "cc90bbbd81dba284049e2ef0d60374c0c231f23d598a0d223916698dd7201dbe" :a :spec/namespace :v :spec.ns/guidance :op :assert}
   {:e #blake3 "cc90bbbd81dba284049e2ef0d60374c0c231f23d598a0d223916698dd7201dbe" :a :db/doc :v "Six Integrated Mechanisms Over Single Solution" :op :assert}
   {:e #blake3 "cc90bbbd81dba284049e2ef0d60374c0c231f23d598a0d223916698dd7201dbe" :a :spec/source-file :v "12-guidance.md" :op :assert}
   {:e #blake3 "cc90bbbd81dba284049e2ef0d60374c0c231f23d598a0d223916698dd7201dbe" :a :element/body :v "**Traces to**: ADRS GU-007\n**Stage**: 1\n\n#### Problem\nHow many anti-drift mechanisms are needed?\n\n#### Decision\nSix. No single mechanism is sufficient — they compose: pre-emption prevents,\ninjection steers, detection catches, gate forces, alarm makes visible, harvest\nrecovers. The failure mode of each mechanism is covered by the others.\n\n#### Formal Justification\nDefense in depth. Pre-emption fails when agents skip the CLAUDE.md check.\nInjection fails when agents ignore footer. Detection fails for novel drift\npatterns. Gate fails if agents don't call pre-check. Alarm fails if agent\ndoesn't read statusline. Harvest fails if session terminates abnormally.\nNo mechanism is single-point-of-failure because each covers the others' gaps.\n\n---" :op :assert}
   {:e #blake3 "cc90bbbd81dba284049e2ef0d60374c0c231f23d598a0d223916698dd7201dbe" :a :element/traces-to :v "ADRS GU-007" :op :assert}
   {:e #blake3 "cc90bbbd81dba284049e2ef0d60374c0c231f23d598a0d223916698dd7201dbe" :a :adr/problem :v "How many anti-drift mechanisms are needed?" :op :assert}
   {:e #blake3 "cc90bbbd81dba284049e2ef0d60374c0c231f23d598a0d223916698dd7201dbe" :a :adr/decision :v "Six. No single mechanism is sufficient — they compose: pre-emption prevents, injection steers, detection catches, gate forces, alarm makes visible, harvest recovers. The failure mode of each mechanism is covered by the others." :op :assert}
