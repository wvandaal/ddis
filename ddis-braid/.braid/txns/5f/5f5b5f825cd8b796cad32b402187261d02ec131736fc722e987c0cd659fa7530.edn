   {:e #blake3 "0f31ea9bf5f42430d33945a75099d4a885fb3255dd12fe161d8370d056ef29d5" :a :spec/namespace :v :spec.ns/query :op :assert}
   {:e #blake3 "0f31ea9bf5f42430d33945a75099d4a885fb3255dd12fe161d8370d056ef29d5" :a :db/doc :v "CALM Compliance" :op :assert}
   {:e #blake3 "0f31ea9bf5f42430d33945a75099d4a885fb3255dd12fe161d8370d056ef29d5" :a :spec/source-file :v "03-query.md" :op :assert}
   {:e #blake3 "0f31ea9bf5f42430d33945a75099d4a885fb3255dd12fe161d8370d056ef29d5" :a :element/body :v "**Traces to**: SEED §4 Axiom 4, ADRS FD-003, PO-013\n**Verification**: `V:PROP`, `V:KANI`\n**Stage**: 0\n\n#### Level 0 (Algebraic Law)\n```\n∀ monotonic queries Q, ∀ D ⊆ D':\n  Q(D) ⊆ Q(D')\n  (adding facts can only add results, never remove them)\n```\n\n#### Level 1 (State Invariant)\nQueries declared as `Monotonic` mode MUST NOT contain negation or aggregation.\nThe query parser rejects non-monotonic constructs in Monotonic mode at parse time.\n\n#### Level 2 (Implementation Contract)\n```rust\nimpl QueryParser {\n    pub fn parse(&self, expr: &str, mode: QueryMode) -> Result<QueryAst, QueryError> {\n        let ast = self.parse_inner(expr)?;\n        if mode == QueryMode::Monotonic && ast.has_negation_or_aggregation() {\n            return Err(QueryError::NonMonotonicInMonotonicMode);\n        }\n        Ok(ast)\n    }\n}\n```\n\n**Falsification**: A query in Monotonic mode that contains negation or aggregation and\nis not rejected at parse time.\n\n---" :op :assert}
   {:e #blake3 "0f31ea9bf5f42430d33945a75099d4a885fb3255dd12fe161d8370d056ef29d5" :a :spec/statement :v "``` ∀ monotonic queries Q, ∀ D ⊆ D': Q(D) ⊆ Q(D') (adding facts can only add results, never remove them) ```" :op :assert}
   {:e #blake3 "0f31ea9bf5f42430d33945a75099d4a885fb3255dd12fe161d8370d056ef29d5" :a :spec/falsification :v "A query in Monotonic mode that contains negation or aggregation and is not rejected at parse time." :op :assert}
   {:e #blake3 "0f31ea9bf5f42430d33945a75099d4a885fb3255dd12fe161d8370d056ef29d5" :a :element/traces-to :v "SEED §4 Axiom 4, ADRS FD-003, PO-013" :op :assert}
   {:e #blake3 "0f31ea9bf5f42430d33945a75099d4a885fb3255dd12fe161d8370d056ef29d5" :a :spec/verification :v "`V:PROP`, `V:KANI`" :op :assert}
   {:e #blake3 "ee6f2c84c97900ba3d28e6a2266b3d40d668a0528e4c7932530ef6fd85b3b9fb" :a :db/ident :v :spec/inv-query-002 :op :assert}
   {:e #blake3 "ee6f2c84c97900ba3d28e6a2266b3d40d668a0528e4c7932530ef6fd85b3b9fb" :a :spec/element-type :v :spec.element/invariant :op :assert}
   {:e #blake3 "ee6f2c84c97900ba3d28e6a2266b3d40d668a0528e4c7932530ef6fd85b3b9fb" :a :spec/namespace :v :spec.ns/query :op :assert}
   {:e #blake3 "ee6f2c84c97900ba3d28e6a2266b3d40d668a0528e4c7932530ef6fd85b3b9fb" :a :db/doc :v "Query Determinism" :op :assert}
   {:e #blake3 "ee6f2c84c97900ba3d28e6a2266b3d40d668a0528e4c7932530ef6fd85b3b9fb" :a :spec/source-file :v "03-query.md" :op :assert}
   {:e #blake3 "ee6f2c84c97900ba3d28e6a2266b3d40d668a0528e4c7932530ef6fd85b3b9fb" :a :element/body :v "**Traces to**: ADRS PO-013\n**Verification**: `V:PROP`\n**Stage**: 0\n\n#### Level 0 (Algebraic Law)\n```\n∀ queries Q, ∀ frontiers F:\n  Q(S, F) at time t₁ = Q(S, F) at time t₂\n  (identical expressions at identical frontiers return identical results)\n```\n\n#### Level 1 (State Invariant)\nQuery results are a pure function of the expression and the visible datom set.\nNo external randomness, no time-of-day dependency, no ordering dependency.\n\n**Falsification**: Two evaluations of the same query at the same frontier returning\ndifferent results.\n\n---" :op :assert}
   {:e #blake3 "ee6f2c84c97900ba3d28e6a2266b3d40d668a0528e4c7932530ef6fd85b3b9fb" :a :spec/statement :v "``` ∀ queries Q, ∀ frontiers F: Q(S, F) at time t₁ = Q(S, F) at time t₂ (identical expressions at identical frontiers return identical results) ```" :op :assert}
   {:e #blake3 "ee6f2c84c97900ba3d28e6a2266b3d40d668a0528e4c7932530ef6fd85b3b9fb" :a :spec/falsification :v "Two evaluations of the same query at the same frontier returning different results." :op :assert}
   {:e #blake3 "ee6f2c84c97900ba3d28e6a2266b3d40d668a0528e4c7932530ef6fd85b3b9fb" :a :element/traces-to :v "ADRS PO-013" :op :assert}
