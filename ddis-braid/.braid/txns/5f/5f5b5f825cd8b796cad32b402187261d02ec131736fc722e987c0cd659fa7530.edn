   {:e #blake3 "5a777478ffd751a457bcca3176436e1754400b215c9cf3a80eb2f7c6ffd6b882" :a :spec/source-file :v "14-interface.md" :op :assert}
   {:e #blake3 "5a777478ffd751a457bcca3176436e1754400b215c9cf3a80eb2f7c6ffd6b882" :a :element/body :v "**Traces to**: ADRS IB-001 (Layer 4.5), SR-011\n**Verification**: `V:PROP`\n**Stage**: 1\n\n#### Level 0 (Algebraic Law)\nThe statusline hook produces side effects (writes session state file) but\nconsumes zero tokens from the agent's context window.\n\n#### Level 1 (State Invariant)\nSTATUSLINE_TICK writes to `.ddis/session/context.json` as an external side effect.\nThe statusline output is consumed by the human display and the CLI budget system,\nnever by the agent's context.\n\n**Falsification**: Statusline output appears in the agent's context window,\nconsuming attention budget.\n\n---" :op :assert}
   {:e #blake3 "5a777478ffd751a457bcca3176436e1754400b215c9cf3a80eb2f7c6ffd6b882" :a :spec/statement :v "The statusline hook produces side effects (writes session state file) but consumes zero tokens from the agent's context window." :op :assert}
   {:e #blake3 "5a777478ffd751a457bcca3176436e1754400b215c9cf3a80eb2f7c6ffd6b882" :a :spec/falsification :v "Statusline output appears in the agent's context window, consuming attention budget." :op :assert}
