   {:e #blake3 "cb466c9beb07b822b34668ebe9a406e4863c2ead3fa949cef95749634e4780ac" :a :spec/element-type :v :spec.element/invariant :op :assert}
   {:e #blake3 "cb466c9beb07b822b34668ebe9a406e4863c2ead3fa949cef95749634e4780ac" :a :spec/namespace :v :spec.ns/query :op :assert}
   {:e #blake3 "cb466c9beb07b822b34668ebe9a406e4863c2ead3fa949cef95749634e4780ac" :a :db/doc :v "Frontier as Queryable Data" :op :assert}
   {:e #blake3 "cb466c9beb07b822b34668ebe9a406e4863c2ead3fa949cef95749634e4780ac" :a :spec/source-file :v "03-query.md" :op :assert}
   {:e #blake3 "cb466c9beb07b822b34668ebe9a406e4863c2ead3fa949cef95749634e4780ac" :a :element/body :v "**Traces to**: ADRS SQ-002, SQ-003\n**Verification**: `V:PROP`\n**Stage**: 0\n\n#### Level 0 (Algebraic Law)\n```\nFrontier is stored as :tx/frontier attribute.\nFrontier = Map<AgentId, TxId> (vector-clock equivalent).\n\nThe Datalog extension [:frontier ?f] enables:\n  \"What does agent X know?\" as an ordinary Datalog query.\n```\n\n#### Level 1 (State Invariant)\nFrontier information is queryable via the same query engine as any other data.\nNo special-case API for frontier queries.\n\n**Falsification**: Frontier data that is accessible only through a non-Datalog API.\n\n---" :op :assert}
   {:e #blake3 "cb466c9beb07b822b34668ebe9a406e4863c2ead3fa949cef95749634e4780ac" :a :spec/statement :v "``` Frontier is stored as :tx/frontier attribute. Frontier = Map<AgentId, TxId> (vector-clock equivalent). The Datalog extension [:frontier ?f] enables: \"What does agent X know?\" as an ordinary Datalog query. ```" :op :assert}
   {:e #blake3 "cb466c9beb07b822b34668ebe9a406e4863c2ead3fa949cef95749634e4780ac" :a :spec/falsification :v "Frontier data that is accessible only through a non-Datalog API." :op :assert}
   {:e #blake3 "cb466c9beb07b822b34668ebe9a406e4863c2ead3fa949cef95749634e4780ac" :a :element/traces-to :v "ADRS SQ-002, SQ-003" :op :assert}
   {:e #blake3 "cb466c9beb07b822b34668ebe9a406e4863c2ead3fa949cef95749634e4780ac" :a :spec/verification :v "`V:PROP`" :op :assert}
   {:e #blake3 "f3cf4389974c6ac54af299896db4108f2ba92870dba9b935a66b656e2f80985f" :a :db/ident :v :spec/inv-query-008 :op :assert}
   {:e #blake3 "f3cf4389974c6ac54af299896db4108f2ba92870dba9b935a66b656e2f80985f" :a :spec/element-type :v :spec.element/invariant :op :assert}
   {:e #blake3 "f3cf4389974c6ac54af299896db4108f2ba92870dba9b935a66b656e2f80985f" :a :spec/namespace :v :spec.ns/query :op :assert}
   {:e #blake3 "f3cf4389974c6ac54af299896db4108f2ba92870dba9b935a66b656e2f80985f" :a :db/doc :v "FFI Boundary Purity" :op :assert}
   {:e #blake3 "f3cf4389974c6ac54af299896db4108f2ba92870dba9b935a66b656e2f80985f" :a :spec/source-file :v "03-query.md" :op :assert}
   {:e #blake3 "f3cf4389974c6ac54af299896db4108f2ba92870dba9b935a66b656e2f80985f" :a :element/body :v "**Traces to**: ADRS SQ-010\n**Verification**: `V:PROP`\n**Stage**: 1\n\n#### Level 0 (Algebraic Law)\n```\n∀ derived functions f registered via FFI:\n  f is a pure function: f(inputs) = f(inputs) always\n  f has no side effects on the store\n  Datalog provides the input query; f computes the result\n```\n\n#### Level 1 (State Invariant)\nThree core computations are FFI: σ_a (entropy), σ_c (DAG traversal), spectral authority (SVD).\nEach is a pure function from datom inputs to computed value.\n\n**Falsification**: A derived function that modifies the store or returns different\nresults for identical inputs.\n\n---" :op :assert}
   {:e #blake3 "f3cf4389974c6ac54af299896db4108f2ba92870dba9b935a66b656e2f80985f" :a :spec/statement :v "``` ∀ derived functions f registered via FFI: f is a pure function: f(inputs) = f(inputs) always f has no side effects on the store Datalog provides the input query; f computes the result ```" :op :assert}
   {:e #blake3 "f3cf4389974c6ac54af299896db4108f2ba92870dba9b935a66b656e2f80985f" :a :spec/falsification :v "A derived function that modifies the store or returns different results for identical inputs." :op :assert}
   {:e #blake3 "f3cf4389974c6ac54af299896db4108f2ba92870dba9b935a66b656e2f80985f" :a :element/traces-to :v "ADRS SQ-010" :op :assert}
   {:e #blake3 "f3cf4389974c6ac54af299896db4108f2ba92870dba9b935a66b656e2f80985f" :a :spec/verification :v "`V:PROP`" :op :assert}
   {:e #blake3 "edc90eff79da570fceb7680fcaa458d8c3e89fb6b2ae6f920107661788c7a3ef" :a :db/ident :v :spec/inv-query-009 :op :assert}
   {:e #blake3 "edc90eff79da570fceb7680fcaa458d8c3e89fb6b2ae6f920107661788c7a3ef" :a :spec/element-type :v :spec.element/invariant :op :assert}
   {:e #blake3 "edc90eff79da570fceb7680fcaa458d8c3e89fb6b2ae6f920107661788c7a3ef" :a :spec/namespace :v :spec.ns/query :op :assert}
   {:e #blake3 "edc90eff79da570fceb7680fcaa458d8c3e89fb6b2ae6f920107661788c7a3ef" :a :db/doc :v "Bilateral Query Symmetry" :op :assert}
   {:e #blake3 "edc90eff79da570fceb7680fcaa458d8c3e89fb6b2ae6f920107661788c7a3ef" :a :spec/source-file :v "03-query.md" :op :assert}
   {:e #blake3 "edc90eff79da570fceb7680fcaa458d8c3e89fb6b2ae6f920107661788c7a3ef" :a :element/body :v "**Traces to**: ADRS SQ-006\n**Verification**: `V:PROP`\n**Stage**: 1\n\n#### Level 0 (Algebraic Law)\n```\nThe query layer is bilateral:\n  Forward queries: spec → implementation status\n  Backward queries: implementation → spec alignment\n\nBoth directions use the same Datalog apparatus. No asymmetric special-casing.\n```\n\n#### Level 1 (State Invariant)\nFor every forward query \"does implementation X satisfy spec Y?\" there is a symmetric\nbackward query \"does spec Y accurately describe implementation X?\"\n\n**Falsification**: A forward query with no backward counterpart, or vice versa.\n\n---" :op :assert}
   {:e #blake3 "edc90eff79da570fceb7680fcaa458d8c3e89fb6b2ae6f920107661788c7a3ef" :a :spec/statement :v "``` The query layer is bilateral: Forward queries: spec → implementation status Backward queries: implementation → spec alignment Both directions use the same Datalog apparatus. No asymmetric special-casing. ```" :op :assert}
   {:e #blake3 "edc90eff79da570fceb7680fcaa458d8c3e89fb6b2ae6f920107661788c7a3ef" :a :spec/falsification :v "A forward query with no backward counterpart, or vice versa." :op :assert}
   {:e #blake3 "edc90eff79da570fceb7680fcaa458d8c3e89fb6b2ae6f920107661788c7a3ef" :a :element/traces-to :v "ADRS SQ-006" :op :assert}
   {:e #blake3 "edc90eff79da570fceb7680fcaa458d8c3e89fb6b2ae6f920107661788c7a3ef" :a :spec/verification :v "`V:PROP`" :op :assert}
