   {:e #blake3 "2d85f045ba5fc3afcbc735077886d9eeac8c3f151b61185045ce20d6d9246a9e" :a :db/doc :v "Subscription Completeness" :op :assert}
   {:e #blake3 "2d85f045ba5fc3afcbc735077886d9eeac8c3f151b61185045ce20d6d9246a9e" :a :spec/source-file :v "09-signal.md" :op :assert}
   {:e #blake3 "2d85f045ba5fc3afcbc735077886d9eeac8c3f151b61185045ce20d6d9246a9e" :a :element/body :v "**Traces to**: ADRS PO-008\n**Verification**: `V:PROP`, `V:KANI`\n**Stage**: 3\n\n#### Level 0 (Algebraic Law)\n`∀ subscription s, signal σ: matches(s.pattern, σ) ⟹ s.callback(σ) is invoked`\n\nNo matching signal is silently dropped.\n\n#### Level 1 (State Invariant)\nFor all reachable states where EMIT produces a signal matching a subscription pattern,\nthe subscription callback fires within one refresh cycle. Debounced subscriptions\nbatch within their declared window but still fire.\n\n#### Level 2 (Implementation Contract)\n```rust\n#[kani::ensures(|_| subscriptions.iter()\n    .filter(|s| s.pattern.matches(&signal))\n    .all(|s| s.fired_count > old(s.fired_count)))]\nfn emit_and_dispatch(signal: Signal, subscriptions: &mut [Subscription]) { ... }\n```\n\n**Falsification**: A subscription pattern matches a signal, but the callback is never invoked.\n\n---" :op :assert}
   {:e #blake3 "2d85f045ba5fc3afcbc735077886d9eeac8c3f151b61185045ce20d6d9246a9e" :a :spec/statement :v "`∀ subscription s, signal σ: matches(s.pattern, σ) ⟹ s.callback(σ) is invoked` No matching signal is silently dropped." :op :assert}
   {:e #blake3 "2d85f045ba5fc3afcbc735077886d9eeac8c3f151b61185045ce20d6d9246a9e" :a :spec/falsification :v "A subscription pattern matches a signal, but the callback is never invoked." :op :assert}
   {:e #blake3 "2d85f045ba5fc3afcbc735077886d9eeac8c3f151b61185045ce20d6d9246a9e" :a :element/traces-to :v "ADRS PO-008" :op :assert}
   {:e #blake3 "2d85f045ba5fc3afcbc735077886d9eeac8c3f151b61185045ce20d6d9246a9e" :a :spec/verification :v "`V:PROP`, `V:KANI`" :op :assert}
