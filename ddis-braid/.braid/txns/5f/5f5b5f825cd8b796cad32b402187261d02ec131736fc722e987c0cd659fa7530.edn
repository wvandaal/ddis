   {:e #blake3 "f2b8e6735cabb87a1c960a15dd8b3241caef5cded6b50661d7874c2044c26787" :a :spec/element-type :v :spec.element/invariant :op :assert}
   {:e #blake3 "f2b8e6735cabb87a1c960a15dd8b3241caef5cded6b50661d7874c2044c26787" :a :spec/namespace :v :spec.ns/query :op :assert}
   {:e #blake3 "f2b8e6735cabb87a1c960a15dd8b3241caef5cded6b50661d7874c2044c26787" :a :db/doc :v "Topology-Agnostic Results" :op :assert}
   {:e #blake3 "f2b8e6735cabb87a1c960a15dd8b3241caef5cded6b50661d7874c2044c26787" :a :spec/source-file :v "03-query.md" :op :assert}
   {:e #blake3 "f2b8e6735cabb87a1c960a15dd8b3241caef5cded6b50661d7874c2044c26787" :a :element/body :v "**Traces to**: ADRS SQ-005\n**Verification**: `V:MODEL`\n**Stage**: 3\n\n#### Level 0 (Algebraic Law)\n```\n∀ queries Q, ∀ dissemination topologies T₁, T₂:\n  if all agents have received the same datom set:\n    Q_T₁(S) = Q_T₂(S)\n  (query results are independent of how datoms were distributed)\n```\n\n#### Level 1 (State Invariant)\nQuery results depend only on the datom set, not on the topology\n(star, ring, mesh, hierarchy) used to distribute datoms.\n\n**Falsification**: Two identical stores, assembled via different topologies, producing\ndifferent query results for the same expression.\n\n---" :op :assert}
   {:e #blake3 "f2b8e6735cabb87a1c960a15dd8b3241caef5cded6b50661d7874c2044c26787" :a :spec/statement :v "``` ∀ queries Q, ∀ dissemination topologies T₁, T₂: if all agents have received the same datom set: Q_T₁(S) = Q_T₂(S) (query results are independent of how datoms were distributed) ```" :op :assert}
   {:e #blake3 "f2b8e6735cabb87a1c960a15dd8b3241caef5cded6b50661d7874c2044c26787" :a :spec/falsification :v "Two identical stores, assembled via different topologies, producing different query results for the same expression." :op :assert}
   {:e #blake3 "f2b8e6735cabb87a1c960a15dd8b3241caef5cded6b50661d7874c2044c26787" :a :element/traces-to :v "ADRS SQ-005" :op :assert}
   {:e #blake3 "f2b8e6735cabb87a1c960a15dd8b3241caef5cded6b50661d7874c2044c26787" :a :spec/verification :v "`V:MODEL`" :op :assert}
