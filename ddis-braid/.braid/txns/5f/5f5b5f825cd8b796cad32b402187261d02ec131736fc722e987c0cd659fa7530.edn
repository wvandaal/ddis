   {:e #blake3 "f590df9cce40f8b597303d1fad1a43d4e2c491d1ebfd239bba83388ec5cf5a87" :a :spec/namespace :v :spec.ns/store :op :assert}
   {:e #blake3 "f590df9cce40f8b597303d1fad1a43d4e2c491d1ebfd239bba83388ec5cf5a87" :a :db/doc :v "Working Set Isolation" :op :assert}
   {:e #blake3 "f590df9cce40f8b597303d1fad1a43d4e2c491d1ebfd239bba83388ec5cf5a87" :a :spec/source-file :v "01-store.md" :op :assert}
   {:e #blake3 "f590df9cce40f8b597303d1fad1a43d4e2c491d1ebfd239bba83388ec5cf5a87" :a :element/body :v "**Traces to**: SEED §4, ADRS PD-001\n**Verification**: `V:PROP`, `V:MODEL`\n**Stage**: 2\n\n#### Level 0 (Algebraic Law)\n```\n∀ agents α, β where α ≠ β:\n  W_α ∩ visible(β) = ∅\n  (agent α's working set is invisible to agent β)\n\ncommit : W_α × S → S'\n  where S' = S ∪ {d ∈ W_α | agent chose to commit d}\n  and post-commit: d ∉ W_α for committed datoms\n```\n\n#### Level 1 (State Invariant)\nUncommitted working set datoms are local to one agent. MERGE operations do not\ninclude working set datoms. Only explicit `commit` promotes W_α datoms to the shared store.\n\n#### Level 2 (Implementation Contract)\n```rust\npub struct WorkingSet {\n    local_datoms: BTreeSet<Datom>,\n    agent: AgentId,\n}\n\nimpl WorkingSet {\n    /// Query sees W_α ∪ S (local override).\n    pub fn query_view<'a>(&'a self, store: &'a Store) -> MergedView<'a>;\n\n    /// Promote selected datoms to the shared store.\n    pub fn commit(&mut self, store: &mut Store, datoms: &[Datom]) -> Result<TxReceipt, TxApplyError>;\n}\n```\n\n**Falsification**: Agent β can query and observe datoms from Agent α's working set\nbefore α has committed them.\n\n---" :op :assert}
   {:e #blake3 "f590df9cce40f8b597303d1fad1a43d4e2c491d1ebfd239bba83388ec5cf5a87" :a :spec/statement :v "``` ∀ agents α, β where α ≠ β: W_α ∩ visible(β) = ∅ (agent α's working set is invisible to agent β) commit : W_α × S → S' where S' = S ∪ {d ∈ W_α | agent chose to commit d} and post-commit: d ∉ W_α for committed datoms ```" :op :assert}
   {:e #blake3 "f590df9cce40f8b597303d1fad1a43d4e2c491d1ebfd239bba83388ec5cf5a87" :a :spec/falsification :v "Agent β can query and observe datoms from Agent α's working set before α has committed them." :op :assert}
   {:e #blake3 "f590df9cce40f8b597303d1fad1a43d4e2c491d1ebfd239bba83388ec5cf5a87" :a :element/traces-to :v "SEED §4, ADRS PD-001" :op :assert}
   {:e #blake3 "f590df9cce40f8b597303d1fad1a43d4e2c491d1ebfd239bba83388ec5cf5a87" :a :spec/verification :v "`V:PROP`, `V:MODEL`" :op :assert}
