   {:e #blake3 "18b5e30f9c95d057d8ef76b25e276c7cdb76274aa066635a30003d248582a3f6" :a :spec/element-type :v :spec.element/invariant :op :assert}
   {:e #blake3 "18b5e30f9c95d057d8ef76b25e276c7cdb76274aa066635a30003d248582a3f6" :a :spec/namespace :v :spec.ns/seed :op :assert}
   {:e #blake3 "18b5e30f9c95d057d8ef76b25e276c7cdb76274aa066635a30003d248582a3f6" :a :db/doc :v "Dynamic CLAUDE.md Relevance" :op :assert}
   {:e #blake3 "18b5e30f9c95d057d8ef76b25e276c7cdb76274aa066635a30003d248582a3f6" :a :spec/source-file :v "06-seed.md" :op :assert}
   {:e #blake3 "18b5e30f9c95d057d8ef76b25e276c7cdb76274aa066635a30003d248582a3f6" :a :element/body :v "**Traces to**: ADRS PO-014\n**Verification**: `V:PROP`\n**Stage**: 1\n\n#### Level 0 (Algebraic Law)\n```\n∀ sections s in GENERATE-CLAUDE-MD output:\n  removing s would change agent behavior\n  (no irrelevant padding or boilerplate)\n```\n\n#### Level 1 (State Invariant)\nEvery section of the dynamic CLAUDE.md is relevant to the declared focus.\nIrrelevant sections waste attention budget.\n\n**Falsification**: A section in the generated CLAUDE.md that, if removed, would not\nchange agent behavior (deadweight content).\n\n---" :op :assert}
   {:e #blake3 "18b5e30f9c95d057d8ef76b25e276c7cdb76274aa066635a30003d248582a3f6" :a :spec/statement :v "``` ∀ sections s in GENERATE-CLAUDE-MD output: removing s would change agent behavior (no irrelevant padding or boilerplate) ```" :op :assert}
   {:e #blake3 "18b5e30f9c95d057d8ef76b25e276c7cdb76274aa066635a30003d248582a3f6" :a :spec/falsification :v "A section in the generated CLAUDE.md that, if removed, would not change agent behavior (deadweight content)." :op :assert}
   {:e #blake3 "18b5e30f9c95d057d8ef76b25e276c7cdb76274aa066635a30003d248582a3f6" :a :element/traces-to :v "ADRS PO-014" :op :assert}
   {:e #blake3 "18b5e30f9c95d057d8ef76b25e276c7cdb76274aa066635a30003d248582a3f6" :a :spec/verification :v "`V:PROP`" :op :assert}
   {:e #blake3 "ba7bebf70cca8dc1164b25027811150b0e1610ba73a6617aba173e15a0d4ac15" :a :db/ident :v :spec/inv-seed-008 :op :assert}
   {:e #blake3 "ba7bebf70cca8dc1164b25027811150b0e1610ba73a6617aba173e15a0d4ac15" :a :spec/element-type :v :spec.element/invariant :op :assert}
   {:e #blake3 "ba7bebf70cca8dc1164b25027811150b0e1610ba73a6617aba173e15a0d4ac15" :a :spec/namespace :v :spec.ns/seed :op :assert}
   {:e #blake3 "ba7bebf70cca8dc1164b25027811150b0e1610ba73a6617aba173e15a0d4ac15" :a :db/doc :v "Dynamic CLAUDE.md Improvement" :op :assert}
   {:e #blake3 "ba7bebf70cca8dc1164b25027811150b0e1610ba73a6617aba173e15a0d4ac15" :a :spec/source-file :v "06-seed.md" :op :assert}
   {:e #blake3 "ba7bebf70cca8dc1164b25027811150b0e1610ba73a6617aba173e15a0d4ac15" :a :element/body :v "**Traces to**: ADRS PO-014\n**Verification**: `V:PROP`\n**Stage**: 1\n\n#### Level 0 (Algebraic Law)\n```\n∀ drift corrections in GENERATE-CLAUDE-MD:\n  correction derived from empirical drift data (not speculation)\n  corrections showing no effect after 5 sessions → replaced\n```\n\n#### Level 1 (State Invariant)\nDrift corrections are data-driven. The system tracks which corrections\nchange agent behavior and removes ineffective ones.\n\n**Falsification**: A drift correction that has been included for 5+ sessions\nwith no measurable effect on agent behavior, and is not replaced.\n\n---" :op :assert}
   {:e #blake3 "ba7bebf70cca8dc1164b25027811150b0e1610ba73a6617aba173e15a0d4ac15" :a :spec/statement :v "``` ∀ drift corrections in GENERATE-CLAUDE-MD: correction derived from empirical drift data (not speculation) corrections showing no effect after 5 sessions → replaced ```" :op :assert}
   {:e #blake3 "ba7bebf70cca8dc1164b25027811150b0e1610ba73a6617aba173e15a0d4ac15" :a :spec/falsification :v "A drift correction that has been included for 5+ sessions with no measurable effect on agent behavior, and is not replaced." :op :assert}
   {:e #blake3 "ba7bebf70cca8dc1164b25027811150b0e1610ba73a6617aba173e15a0d4ac15" :a :element/traces-to :v "ADRS PO-014" :op :assert}
   {:e #blake3 "ba7bebf70cca8dc1164b25027811150b0e1610ba73a6617aba173e15a0d4ac15" :a :spec/verification :v "`V:PROP`" :op :assert}
   {:e #blake3 "8eab0152ecd0b33ceb0d1dd367b8ef5c233133226cd060d323b0f4532aa2a034" :a :db/ident :v :spec/adr-seed-001 :op :assert}
   {:e #blake3 "8eab0152ecd0b33ceb0d1dd367b8ef5c233133226cd060d323b0f4532aa2a034" :a :spec/element-type :v :spec.element/adr :op :assert}
   {:e #blake3 "8eab0152ecd0b33ceb0d1dd367b8ef5c233133226cd060d323b0f4532aa2a034" :a :spec/namespace :v :spec.ns/seed :op :assert}
   {:e #blake3 "8eab0152ecd0b33ceb0d1dd367b8ef5c233133226cd060d323b0f4532aa2a034" :a :db/doc :v "Three-Concern Collapse" :op :assert}
   {:e #blake3 "8eab0152ecd0b33ceb0d1dd367b8ef5c233133226cd060d323b0f4532aa2a034" :a :spec/source-file :v "06-seed.md" :op :assert}
   {:e #blake3 "8eab0152ecd0b33ceb0d1dd367b8ef5c233133226cd060d323b0f4532aa2a034" :a :element/body :v "**Traces to**: ADRS GU-004\n**Stage**: 0\n\n#### Problem\nHow to handle ambient awareness, guidance, and trajectory management?\n\n#### Options\nA) **Three separate mechanisms** — CLAUDE.md for awareness, guidance API for steering,\n   seed file for carry-over.\nB) **Single mechanism** — dynamic CLAUDE.md that collapses all three.\n\n#### Decision\n**Option B.** One mechanism, three problems solved. CLAUDE.md IS the ambient awareness\n(Layer 0). The seed context IS the first guidance (pre-computed, zero tool-call cost).\nCLAUDE.md IS the seed turn (trajectory management).\n\n#### Formal Justification\nOption A triples the attention cost: agent must process three separate information\nsources. Option B is rate-distortion optimal: one compressed channel carrying all\nthree signals, prioritized by the budget system.\n\n---" :op :assert}
   {:e #blake3 "8eab0152ecd0b33ceb0d1dd367b8ef5c233133226cd060d323b0f4532aa2a034" :a :element/traces-to :v "ADRS GU-004" :op :assert}
   {:e #blake3 "8eab0152ecd0b33ceb0d1dd367b8ef5c233133226cd060d323b0f4532aa2a034" :a :adr/problem :v "How to handle ambient awareness, guidance, and trajectory management?" :op :assert}
   {:e #blake3 "8eab0152ecd0b33ceb0d1dd367b8ef5c233133226cd060d323b0f4532aa2a034" :a :adr/decision :v "**Option B.** One mechanism, three problems solved. CLAUDE.md IS the ambient awareness (Layer 0). The seed context IS the first guidance (pre-computed, zero tool-call cost). CLAUDE.md IS the seed turn (trajectory management)." :op :assert}
   {:e #blake3 "6777472b3a65e4cf7edff67469283d34489ec2aea6d62cc1d3ce69139e81da94" :a :db/ident :v :spec/adr-seed-002 :op :assert}
   {:e #blake3 "6777472b3a65e4cf7edff67469283d34489ec2aea6d62cc1d3ce69139e81da94" :a :spec/element-type :v :spec.element/adr :op :assert}
   {:e #blake3 "6777472b3a65e4cf7edff67469283d34489ec2aea6d62cc1d3ce69139e81da94" :a :spec/namespace :v :spec.ns/seed :op :assert}
   {:e #blake3 "6777472b3a65e4cf7edff67469283d34489ec2aea6d62cc1d3ce69139e81da94" :a :db/doc :v "Rate-Distortion Assembly" :op :assert}
   {:e #blake3 "6777472b3a65e4cf7edff67469283d34489ec2aea6d62cc1d3ce69139e81da94" :a :spec/source-file :v "06-seed.md" :op :assert}
   {:e #blake3 "6777472b3a65e4cf7edff67469283d34489ec2aea6d62cc1d3ce69139e81da94" :a :element/body :v "**Traces to**: ADRS IB-011\n**Stage**: 0\n\n#### Problem\nHow to compress knowledge to fit the attention budget?\n\n#### Decision\nRate-distortion theory: maximize information value while minimizing attention cost.\nThe projection pyramid (π₀ → π₃) provides controlled lossy compression. The score\nfunction (α×relevance + β×significance + γ×recency) determines what survives.\n\n#### Formal Justification\nThe attention budget is a hard constraint (INV-SEED-002). Within that constraint,\nthe score function and projection pyramid maximize information value — high-relevance,\nhigh-significance, recent entities get richer projections; low-value entities get\ncompressed or omitted.\n\n---" :op :assert}
   {:e #blake3 "6777472b3a65e4cf7edff67469283d34489ec2aea6d62cc1d3ce69139e81da94" :a :element/traces-to :v "ADRS IB-011" :op :assert}
   {:e #blake3 "6777472b3a65e4cf7edff67469283d34489ec2aea6d62cc1d3ce69139e81da94" :a :adr/problem :v "How to compress knowledge to fit the attention budget?" :op :assert}
   {:e #blake3 "6777472b3a65e4cf7edff67469283d34489ec2aea6d62cc1d3ce69139e81da94" :a :adr/decision :v "Rate-distortion theory: maximize information value while minimizing attention cost. The projection pyramid (π₀ → π₃) provides controlled lossy compression. The score function (α×relevance + β×significance + γ×recency) determines what survives." :op :assert}
   {:e #blake3 "38dd8bd2cf71bc2a99e2bfe8d2597bed74fa573e70397fb8ececb369b1f686ea" :a :db/ident :v :spec/adr-seed-003 :op :assert}
   {:e #blake3 "38dd8bd2cf71bc2a99e2bfe8d2597bed74fa573e70397fb8ececb369b1f686ea" :a :spec/element-type :v :spec.element/adr :op :assert}
   {:e #blake3 "38dd8bd2cf71bc2a99e2bfe8d2597bed74fa573e70397fb8ececb369b1f686ea" :a :spec/namespace :v :spec.ns/seed :op :assert}
   {:e #blake3 "38dd8bd2cf71bc2a99e2bfe8d2597bed74fa573e70397fb8ececb369b1f686ea" :a :db/doc :v "Spec-Language Over Instruction-Language" :op :assert}
   {:e #blake3 "38dd8bd2cf71bc2a99e2bfe8d2597bed74fa573e70397fb8ececb369b1f686ea" :a :spec/source-file :v "06-seed.md" :op :assert}
   {:e #blake3 "38dd8bd2cf71bc2a99e2bfe8d2597bed74fa573e70397fb8ececb369b1f686ea" :a :element/body :v "**Traces to**: ADRS GU-003\n**Stage**: 0\n\n#### Problem\nWhat style should seed output use?\n\n#### Options\nA) **Instruction-language** — \"Step 1: do X. Step 2: do Y.\" (checklists, procedures)\nB) **Spec-language** — invariants, formal structure, constraints.\n\n#### Decision\n**Option B.** Spec-language activates the deep formal-methods substrate in the LLM.\nInstruction-language activates the surface procedural substrate. Spec-language produces\nmore rigorous, consistent output because it frames the task as constraint satisfaction\nrather than instruction following.\n\n---" :op :assert}
   {:e #blake3 "38dd8bd2cf71bc2a99e2bfe8d2597bed74fa573e70397fb8ececb369b1f686ea" :a :element/traces-to :v "ADRS GU-003" :op :assert}
   {:e #blake3 "38dd8bd2cf71bc2a99e2bfe8d2597bed74fa573e70397fb8ececb369b1f686ea" :a :adr/problem :v "What style should seed output use?" :op :assert}
   {:e #blake3 "38dd8bd2cf71bc2a99e2bfe8d2597bed74fa573e70397fb8ececb369b1f686ea" :a :adr/decision :v "**Option B.** Spec-language activates the deep formal-methods substrate in the LLM. Instruction-language activates the surface procedural substrate. Spec-language produces more rigorous, consistent output because it frames the task as constraint satisfaction rather than instruction following." :op :assert}
