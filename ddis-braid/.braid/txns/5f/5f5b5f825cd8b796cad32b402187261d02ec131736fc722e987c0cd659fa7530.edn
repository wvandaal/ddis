   {:e #blake3 "4101401309610b85e6f5952ddb483bd23c2921daff9ebdc29a14508f5b814c5b" :a :spec/source-file :v "10-bilateral.md" :op :assert}
   {:e #blake3 "4101401309610b85e6f5952ddb483bd23c2921daff9ebdc29a14508f5b814c5b" :a :element/body :v "**Traces to**: ADRS CO-008\n**Verification**: `V:PROP`\n\n**Safety property (mode-relative)**:\n```\n□ ¬(∃ AUTO_CYCLE that skips any of {CC-1, CC-2, CC-4, CC-5})\n□ ¬(∃ FULL_CYCLE that skips any of {CC-1, CC-2, CC-3, CC-4, CC-5})\n□ ¬(cycles_since_last_full_cycle > cc3_staleness_threshold ∧ ¬CC3StaleWarning_emitted)\n```\n\nNo coherence dimension is left unchecked relative to cycle mode:\n- AUTO_CYCLE checks all four machine-evaluable conditions (CC-1, CC-2, CC-4, CC-5)\n- FULL_CYCLE checks all five conditions including human-gated CC-3\n- CC-3 staleness is bounded: after `cc3_staleness_threshold` AUTO_CYCLEs without\n  a FULL_CYCLE, the system emits CC3StaleWarning\n\n**proptest strategy**: Instrument cycle execution. Verify: (1) AUTO_CYCLE\nexecutes CC-1, CC-2, CC-4, CC-5 checks; (2) FULL_CYCLE executes all five checks;\n(3) CC3StaleWarning emitted when threshold exceeded.\n\n---" :op :assert}
   {:e #blake3 "4101401309610b85e6f5952ddb483bd23c2921daff9ebdc29a14508f5b814c5b" :a :element/traces-to :v "ADRS CO-008" :op :assert}
   {:e #blake3 "4101401309610b85e6f5952ddb483bd23c2921daff9ebdc29a14508f5b814c5b" :a :spec/verification :v "`V:PROP`" :op :assert}
   {:e #blake3 "880ddb5f28c0670560d8fa9f70ff6e3a4946aa3bef2f03f25023f5268312f9a8" :a :db/ident :v :spec/inv-deliberation-001 :op :assert}
   {:e #blake3 "880ddb5f28c0670560d8fa9f70ff6e3a4946aa3bef2f03f25023f5268312f9a8" :a :spec/element-type :v :spec.element/invariant :op :assert}
   {:e #blake3 "880ddb5f28c0670560d8fa9f70ff6e3a4946aa3bef2f03f25023f5268312f9a8" :a :spec/namespace :v :spec.ns/deliberation :op :assert}
   {:e #blake3 "880ddb5f28c0670560d8fa9f70ff6e3a4946aa3bef2f03f25023f5268312f9a8" :a :db/doc :v "Deliberation Convergence" :op :assert}
   {:e #blake3 "880ddb5f28c0670560d8fa9f70ff6e3a4946aa3bef2f03f25023f5268312f9a8" :a :spec/source-file :v "11-deliberation.md" :op :assert}
   {:e #blake3 "880ddb5f28c0670560d8fa9f70ff6e3a4946aa3bef2f03f25023f5268312f9a8" :a :element/body :v "**Traces to**: ADRS CR-004\n**Verification**: `V:PROP`, `V:MODEL`\n**Stage**: 2\n\n#### Level 0 (Algebraic Law)\n`∀ deliberation d: ◇(d.status = :decided ∨ d.status = :stalled)`\nEvery deliberation eventually reaches a terminal state.\n\n#### Level 1 (State Invariant)\nNo deliberation remains in `:open` or `:active` indefinitely. Either positions\nconverge to a decision, or a timeout/stall condition triggers escalation.\n\n#### Level 2 (Implementation Contract)\nDeliberations carry a timeout. If no decision is reached within the timeout,\nthe deliberation transitions to `:stalled` and emits an escalation signal.\n\n**Falsification**: A deliberation remains `:active` past its timeout without\ntransitioning to `:decided` or `:stalled`.\n\n**Stateright model**: 3 agents filing positions on a deliberation. Verify\nthat all executions reach a terminal state.\n\n---" :op :assert}
   {:e #blake3 "880ddb5f28c0670560d8fa9f70ff6e3a4946aa3bef2f03f25023f5268312f9a8" :a :spec/statement :v "`∀ deliberation d: ◇(d.status = :decided ∨ d.status = :stalled)` Every deliberation eventually reaches a terminal state." :op :assert}
   {:e #blake3 "880ddb5f28c0670560d8fa9f70ff6e3a4946aa3bef2f03f25023f5268312f9a8" :a :spec/falsification :v "A deliberation remains `:active` past its timeout without transitioning to `:decided` or `:stalled`." :op :assert}
   {:e #blake3 "880ddb5f28c0670560d8fa9f70ff6e3a4946aa3bef2f03f25023f5268312f9a8" :a :element/traces-to :v "ADRS CR-004" :op :assert}
   {:e #blake3 "880ddb5f28c0670560d8fa9f70ff6e3a4946aa3bef2f03f25023f5268312f9a8" :a :spec/verification :v "`V:PROP`, `V:MODEL`" :op :assert}
   {:e #blake3 "2ce101b229a21fde1e8617db2378f1c6bb33f01789dde380655a28f9b2e0a74e" :a :db/ident :v :spec/inv-deliberation-002 :op :assert}
   {:e #blake3 "2ce101b229a21fde1e8617db2378f1c6bb33f01789dde380655a28f9b2e0a74e" :a :spec/element-type :v :spec.element/invariant :op :assert}
   {:e #blake3 "2ce101b229a21fde1e8617db2378f1c6bb33f01789dde380655a28f9b2e0a74e" :a :spec/namespace :v :spec.ns/deliberation :op :assert}
   {:e #blake3 "2ce101b229a21fde1e8617db2378f1c6bb33f01789dde380655a28f9b2e0a74e" :a :db/doc :v "Stability Guard Enforcement" :op :assert}
   {:e #blake3 "2ce101b229a21fde1e8617db2378f1c6bb33f01789dde380655a28f9b2e0a74e" :a :spec/source-file :v "11-deliberation.md" :op :assert}
   {:e #blake3 "2ce101b229a21fde1e8617db2378f1c6bb33f01789dde380655a28f9b2e0a74e" :a :element/body :v "**Traces to**: ADRS CR-005\n**Verification**: `V:PROP`, `V:KANI`\n**Stage**: 2\n\n#### Level 0 (Algebraic Law)\n`∀ decision d: decide(d) ⟹ stability(d.chosen) ≥ stability_min`\nNo decision is recorded unless the crystallization stability guard passes.\n\n#### Level 1 (State Invariant)\nThe DECIDE transition requires all stability guard conditions (CR-005) to hold.\nA decision attempted with insufficient stability is rejected.\n\n#### Level 2 (Implementation Contract)\n```rust\n#[kani::requires(stability_score(&position) >= STABILITY_MIN)]\nfn decide(delib: &mut Deliberation, position: EntityId, method: DecisionMethod)\n    -> Result<Decision, StabilityError> { ... }\n```\n\n**Falsification**: A decision is recorded where `stability(chosen) < stability_min`.\n\n---" :op :assert}
   {:e #blake3 "2ce101b229a21fde1e8617db2378f1c6bb33f01789dde380655a28f9b2e0a74e" :a :spec/statement :v "`∀ decision d: decide(d) ⟹ stability(d.chosen) ≥ stability_min` No decision is recorded unless the crystallization stability guard passes." :op :assert}
   {:e #blake3 "2ce101b229a21fde1e8617db2378f1c6bb33f01789dde380655a28f9b2e0a74e" :a :spec/falsification :v "A decision is recorded where `stability(chosen) < stability_min`." :op :assert}
   {:e #blake3 "2ce101b229a21fde1e8617db2378f1c6bb33f01789dde380655a28f9b2e0a74e" :a :element/traces-to :v "ADRS CR-005" :op :assert}
   {:e #blake3 "2ce101b229a21fde1e8617db2378f1c6bb33f01789dde380655a28f9b2e0a74e" :a :spec/verification :v "`V:PROP`, `V:KANI`" :op :assert}
   {:e #blake3 "064507038bf509b3dde361b416145dca2417d0f3456c3ae408b5fc0a5d302722" :a :db/ident :v :spec/inv-deliberation-003 :op :assert}
   {:e #blake3 "064507038bf509b3dde361b416145dca2417d0f3456c3ae408b5fc0a5d302722" :a :spec/element-type :v :spec.element/invariant :op :assert}
   {:e #blake3 "064507038bf509b3dde361b416145dca2417d0f3456c3ae408b5fc0a5d302722" :a :spec/namespace :v :spec.ns/deliberation :op :assert}
   {:e #blake3 "064507038bf509b3dde361b416145dca2417d0f3456c3ae408b5fc0a5d302722" :a :db/doc :v "Precedent Queryability" :op :assert}
   {:e #blake3 "064507038bf509b3dde361b416145dca2417d0f3456c3ae408b5fc0a5d302722" :a :spec/source-file :v "11-deliberation.md" :op :assert}
   {:e #blake3 "064507038bf509b3dde361b416145dca2417d0f3456c3ae408b5fc0a5d302722" :a :element/body :v "**Traces to**: ADRS CR-007\n**Verification**: `V:PROP`\n**Stage**: 2\n\n#### Level 0 (Algebraic Law)\nAll decided deliberations are indexed by entity type and contested attributes,\nenabling precedent lookup:\n```\nfind-precedent(entity_type, attributes) =\n  {d ∈ deliberations | d.status = :decided\n                     ∧ d.entity_type = entity_type\n                     ∧ d.contested_attrs ∩ attributes ≠ ∅}\n```\n\n#### Level 1 (State Invariant)\nThe precedent index is maintained as a materialized view, updated on every DECIDE.\nPrecedent queries return all matching decided deliberations.\n\n**Falsification**: A decided deliberation with matching entity type and attributes\nis not returned by a precedent query.\n\n---" :op :assert}
   {:e #blake3 "064507038bf509b3dde361b416145dca2417d0f3456c3ae408b5fc0a5d302722" :a :spec/statement :v "All decided deliberations are indexed by entity type and contested attributes, enabling precedent lookup: ``` find-precedent(entity_type, attributes) = {d ∈ deliberations | d.status = :decided ∧ d.entity_type = entity_type ∧ d.contested_attrs ∩ attributes ≠ ∅} ```" :op :assert}
   {:e #blake3 "064507038bf509b3dde361b416145dca2417d0f3456c3ae408b5fc0a5d302722" :a :spec/falsification :v "A decided deliberation with matching entity type and attributes is not returned by a precedent query." :op :assert}
   {:e #blake3 "064507038bf509b3dde361b416145dca2417d0f3456c3ae408b5fc0a5d302722" :a :element/traces-to :v "ADRS CR-007" :op :assert}
   {:e #blake3 "064507038bf509b3dde361b416145dca2417d0f3456c3ae408b5fc0a5d302722" :a :spec/verification :v "`V:PROP`" :op :assert}
   {:e #blake3 "bc0cd8094a8b637646016dfdd264bca4bed36c7a8723e8610b317b93b69a5c4b" :a :db/ident :v :spec/inv-deliberation-004 :op :assert}
   {:e #blake3 "bc0cd8094a8b637646016dfdd264bca4bed36c7a8723e8610b317b93b69a5c4b" :a :spec/element-type :v :spec.element/invariant :op :assert}
   {:e #blake3 "bc0cd8094a8b637646016dfdd264bca4bed36c7a8723e8610b317b93b69a5c4b" :a :spec/namespace :v :spec.ns/deliberation :op :assert}
   {:e #blake3 "bc0cd8094a8b637646016dfdd264bca4bed36c7a8723e8610b317b93b69a5c4b" :a :db/doc :v "Bilateral Deliberation Symmetry" :op :assert}
   {:e #blake3 "bc0cd8094a8b637646016dfdd264bca4bed36c7a8723e8610b317b93b69a5c4b" :a :spec/source-file :v "11-deliberation.md" :op :assert}
   {:e #blake3 "bc0cd8094a8b637646016dfdd264bca4bed36c7a8723e8610b317b93b69a5c4b" :a :element/body :v "**Traces to**: ADRS CR-004 (INV-DELIBERATION-BILATERAL-001), AS-006\n**Verification**: `V:PROP`\n**Stage**: 2\n\n#### Level 0 (Algebraic Law)\nDeliberation supports both forward and backward flow with identical entity structure:\n- Forward: \"Given this spec, which of these competing implementations is better?\"\n- Backward: \"Given this implementation, which of these spec interpretations is correct?\"\n\n#### Level 1 (State Invariant)\nThe Deliberation/Position/Decision entity structure is direction-agnostic.\nForward and backward deliberations use the same schema, same lifecycle,\nsame stability guard, same precedent query.\n\n**Falsification**: The system creates a structural asymmetry where forward\ndeliberations have capabilities that backward deliberations lack (or vice versa).\n\n---" :op :assert}
   {:e #blake3 "bc0cd8094a8b637646016dfdd264bca4bed36c7a8723e8610b317b93b69a5c4b" :a :spec/statement :v "Deliberation supports both forward and backward flow with identical entity structure: - Forward: \"Given this spec, which of these competing implementations is better?\" - Backward: \"Given this implementation, which of these spec interpretations is correct?\"" :op :assert}
   {:e #blake3 "bc0cd8094a8b637646016dfdd264bca4bed36c7a8723e8610b317b93b69a5c4b" :a :spec/falsification :v "The system creates a structural asymmetry where forward deliberations have capabilities that backward deliberations lack (or vice versa)." :op :assert}
   {:e #blake3 "bc0cd8094a8b637646016dfdd264bca4bed36c7a8723e8610b317b93b69a5c4b" :a :element/traces-to :v "ADRS CR-004 (INV-DELIBERATION-BILATERAL-001), AS-006" :op :assert}
   {:e #blake3 "bc0cd8094a8b637646016dfdd264bca4bed36c7a8723e8610b317b93b69a5c4b" :a :spec/verification :v "`V:PROP`" :op :assert}
   {:e #blake3 "72e5b84510e5c191edfd94c073c885695d382c1142b562fc9d3f18667a9c015a" :a :db/ident :v :spec/inv-deliberation-005 :op :assert}
   {:e #blake3 "72e5b84510e5c191edfd94c073c885695d382c1142b562fc9d3f18667a9c015a" :a :spec/element-type :v :spec.element/invariant :op :assert}
   {:e #blake3 "72e5b84510e5c191edfd94c073c885695d382c1142b562fc9d3f18667a9c015a" :a :spec/namespace :v :spec.ns/deliberation :op :assert}
   {:e #blake3 "72e5b84510e5c191edfd94c073c885695d382c1142b562fc9d3f18667a9c015a" :a :db/doc :v "Commitment Weight Integration" :op :assert}
   {:e #blake3 "72e5b84510e5c191edfd94c073c885695d382c1142b562fc9d3f18667a9c015a" :a :spec/source-file :v "11-deliberation.md" :op :assert}
   {:e #blake3 "72e5b84510e5c191edfd94c073c885695d382c1142b562fc9d3f18667a9c015a" :a :element/body :v "**Traces to**: ADRS AS-002\n**Verification**: `V:PROP`, `V:KANI`\n**Stage**: 2\n\n#### Level 0 (Algebraic Law)\nThe decision's commitment weight is computed from its forward causal cone:\n`w(decision) = |{d' ∈ S : decision ∈ causes*(d')}|`\n\nDecisions with high commitment weight are harder to overturn (require\nstronger evidence, higher authority).\n\n#### Level 1 (State Invariant)\nWhen a new decision is recorded, its commitment weight is computed and stored.\nAs downstream decisions reference it, the weight monotonically increases.\n\n**Falsification**: A decision's commitment weight decreases after downstream\ndecisions are recorded.\n\n---" :op :assert}
   {:e #blake3 "72e5b84510e5c191edfd94c073c885695d382c1142b562fc9d3f18667a9c015a" :a :spec/statement :v "The decision's commitment weight is computed from its forward causal cone: `w(decision) = |{d' ∈ S : decision ∈ causes*(d')}|` Decisions with high commitment weight are harder to overturn (require stronger evidence, higher authority)." :op :assert}
   {:e #blake3 "72e5b84510e5c191edfd94c073c885695d382c1142b562fc9d3f18667a9c015a" :a :spec/falsification :v "A decision's commitment weight decreases after downstream decisions are recorded." :op :assert}
   {:e #blake3 "72e5b84510e5c191edfd94c073c885695d382c1142b562fc9d3f18667a9c015a" :a :element/traces-to :v "ADRS AS-002" :op :assert}
   {:e #blake3 "72e5b84510e5c191edfd94c073c885695d382c1142b562fc9d3f18667a9c015a" :a :spec/verification :v "`V:PROP`, `V:KANI`" :op :assert}
   {:e #blake3 "7bc10b5430a036ad718dd2e0ec602963a5bd36a059d13a38d92899b6cb9a3632" :a :db/ident :v :spec/inv-deliberation-006 :op :assert}
   {:e #blake3 "7bc10b5430a036ad718dd2e0ec602963a5bd36a059d13a38d92899b6cb9a3632" :a :spec/element-type :v :spec.element/invariant :op :assert}
   {:e #blake3 "7bc10b5430a036ad718dd2e0ec602963a5bd36a059d13a38d92899b6cb9a3632" :a :spec/namespace :v :spec.ns/deliberation :op :assert}
   {:e #blake3 "7bc10b5430a036ad718dd2e0ec602963a5bd36a059d13a38d92899b6cb9a3632" :a :db/doc :v "Competing Branch Resolution" :op :assert}
   {:e #blake3 "7bc10b5430a036ad718dd2e0ec602963a5bd36a059d13a38d92899b6cb9a3632" :a :spec/source-file :v "11-deliberation.md" :op :assert}
   {:e #blake3 "7bc10b5430a036ad718dd2e0ec602963a5bd36a059d13a38d92899b6cb9a3632" :a :element/body :v "**Traces to**: ADRS PO-007\n**Verification**: `V:PROP`, `V:MODEL`\n**Stage**: 2\n\n#### Level 0 (Algebraic Law)\nWhen a deliberation produces a decision selecting one competing branch:\n- The winning branch is committed to trunk\n- Losing branches are marked `:abandoned` (remain readable for provenance)\n- No losers' datoms leak into trunk\n\n#### Level 1 (State Invariant)\nFor all reachable states where DECIDE selects a branch:\n```\ntrunk' = trunk ∪ winner.datoms\n∀ loser: loser.status = :abandoned\n∀ loser: loser.datoms ∩ trunk' = loser.datoms ∩ trunk  (no new datoms from losers)\n```\n\n**Falsification**: A losing branch's datoms appear in trunk after the decision.\n\n**Stateright model**: 2 agents with competing branches. Deliberation decides.\nVerify loser's datoms never appear in trunk.\n\n---" :op :assert}
   {:e #blake3 "7bc10b5430a036ad718dd2e0ec602963a5bd36a059d13a38d92899b6cb9a3632" :a :spec/statement :v "When a deliberation produces a decision selecting one competing branch: - The winning branch is committed to trunk - Losing branches are marked `:abandoned` (remain readable for provenance) - No losers' datoms leak into trunk" :op :assert}
   {:e #blake3 "7bc10b5430a036ad718dd2e0ec602963a5bd36a059d13a38d92899b6cb9a3632" :a :spec/falsification :v "A losing branch's datoms appear in trunk after the decision." :op :assert}
   {:e #blake3 "7bc10b5430a036ad718dd2e0ec602963a5bd36a059d13a38d92899b6cb9a3632" :a :element/traces-to :v "ADRS PO-007" :op :assert}
   {:e #blake3 "7bc10b5430a036ad718dd2e0ec602963a5bd36a059d13a38d92899b6cb9a3632" :a :spec/verification :v "`V:PROP`, `V:MODEL`" :op :assert}
   {:e #blake3 "061711704456cf07bab043901d6f5e3ee519408c4b0a78c7d3a8c56fad00aec4" :a :db/ident :v :spec/adr-deliberation-001 :op :assert}
   {:e #blake3 "061711704456cf07bab043901d6f5e3ee519408c4b0a78c7d3a8c56fad00aec4" :a :spec/element-type :v :spec.element/adr :op :assert}
   {:e #blake3 "061711704456cf07bab043901d6f5e3ee519408c4b0a78c7d3a8c56fad00aec4" :a :spec/namespace :v :spec.ns/deliberation :op :assert}
   {:e #blake3 "061711704456cf07bab043901d6f5e3ee519408c4b0a78c7d3a8c56fad00aec4" :a :db/doc :v "Three Entity Types for Structured Resolution" :op :assert}
   {:e #blake3 "061711704456cf07bab043901d6f5e3ee519408c4b0a78c7d3a8c56fad00aec4" :a :spec/source-file :v "11-deliberation.md" :op :assert}
   {:e #blake3 "061711704456cf07bab043901d6f5e3ee519408c4b0a78c7d3a8c56fad00aec4" :a :element/body :v "**Traces to**: ADRS CR-004\n**Stage**: 2\n\n#### Problem\nWhat entities are needed for structured conflict resolution?\n\n#### Decision\nThree: Deliberation (the process), Position (a stance with rationale and evidence),\nDecision (the outcome with method and chosen position). All stored as datoms.\n\n#### Formal Justification\nThe separation into three entity types mirrors legal proceedings: a case (Deliberation),\narguments (Positions), and a ruling (Decision). This structure enables precedent queries\n(CR-007) — past Decisions inform future Deliberations. A single entity type would lose\nthe distinction between process, argument, and outcome.\n\n---" :op :assert}
   {:e #blake3 "061711704456cf07bab043901d6f5e3ee519408c4b0a78c7d3a8c56fad00aec4" :a :element/traces-to :v "ADRS CR-004" :op :assert}
   {:e #blake3 "061711704456cf07bab043901d6f5e3ee519408c4b0a78c7d3a8c56fad00aec4" :a :adr/problem :v "What entities are needed for structured conflict resolution?" :op :assert}
   {:e #blake3 "061711704456cf07bab043901d6f5e3ee519408c4b0a78c7d3a8c56fad00aec4" :a :adr/decision :v "Three: Deliberation (the process), Position (a stance with rationale and evidence), Decision (the outcome with method and chosen position). All stored as datoms." :op :assert}
   {:e #blake3 "374f487318d9a73aae0d13c86224ca5d45e780b69fe931f5ac4e05a39e406f9a" :a :db/ident :v :spec/adr-deliberation-002 :op :assert}
   {:e #blake3 "374f487318d9a73aae0d13c86224ca5d45e780b69fe931f5ac4e05a39e406f9a" :a :spec/element-type :v :spec.element/adr :op :assert}
   {:e #blake3 "374f487318d9a73aae0d13c86224ca5d45e780b69fe931f5ac4e05a39e406f9a" :a :spec/namespace :v :spec.ns/deliberation :op :assert}
   {:e #blake3 "374f487318d9a73aae0d13c86224ca5d45e780b69fe931f5ac4e05a39e406f9a" :a :db/doc :v "Five Decision Methods" :op :assert}
   {:e #blake3 "374f487318d9a73aae0d13c86224ca5d45e780b69fe931f5ac4e05a39e406f9a" :a :spec/source-file :v "11-deliberation.md" :op :assert}
   {:e #blake3 "374f487318d9a73aae0d13c86224ca5d45e780b69fe931f5ac4e05a39e406f9a" :a :element/body :v "**Traces to**: ADRS CR-004\n**Stage**: 2\n\n#### Problem\nWhat decision methods should be supported?\n\n#### Options\nA) Consensus only — simplest, but may never converge\nB) Authority only — fast, but ignores evidence quality\nC) Five methods: Consensus, Majority, Authority, HumanOverride, Automated\n\n#### Decision\n**Option C.** Different conflicts warrant different resolution methods. Low-stakes\nconflicts can use Automated (lattice join). Medium-stakes use Majority or Authority.\nHigh-stakes require HumanOverride. Consensus is the ideal but not always achievable.\n\n#### Formal Justification\nThe method selection aligns with the three-tier conflict routing (CR-002):\nTier 1 (Low) → Automated, Tier 2 (Medium) → Majority/Authority,\nTier 3 (High) → HumanOverride. Consensus is orthogonal — achievable at any tier\nbut never required.\n\n---" :op :assert}
   {:e #blake3 "374f487318d9a73aae0d13c86224ca5d45e780b69fe931f5ac4e05a39e406f9a" :a :element/traces-to :v "ADRS CR-004" :op :assert}
   {:e #blake3 "374f487318d9a73aae0d13c86224ca5d45e780b69fe931f5ac4e05a39e406f9a" :a :adr/problem :v "What decision methods should be supported?" :op :assert}
   {:e #blake3 "374f487318d9a73aae0d13c86224ca5d45e780b69fe931f5ac4e05a39e406f9a" :a :adr/decision :v "**Option C.** Different conflicts warrant different resolution methods. Low-stakes conflicts can use Automated (lattice join). Medium-stakes use Majority or Authority. High-stakes require HumanOverride. Consensus is the ideal but not always achievable." :op :assert}
   {:e #blake3 "cb5ce1bf97c4695909859fa852cebd7f517d25246d3a26b237421d48892adc64" :a :db/ident :v :spec/adr-deliberation-003 :op :assert}
   {:e #blake3 "cb5ce1bf97c4695909859fa852cebd7f517d25246d3a26b237421d48892adc64" :a :spec/element-type :v :spec.element/adr :op :assert}
   {:e #blake3 "cb5ce1bf97c4695909859fa852cebd7f517d25246d3a26b237421d48892adc64" :a :spec/namespace :v :spec.ns/deliberation :op :assert}
   {:e #blake3 "cb5ce1bf97c4695909859fa852cebd7f517d25246d3a26b237421d48892adc64" :a :db/doc :v "Precedent as Case Law" :op :assert}
   {:e #blake3 "cb5ce1bf97c4695909859fa852cebd7f517d25246d3a26b237421d48892adc64" :a :spec/source-file :v "11-deliberation.md" :op :assert}
   {:e #blake3 "cb5ce1bf97c4695909859fa852cebd7f517d25246d3a26b237421d48892adc64" :a :element/body :v "**Traces to**: ADRS CR-007\n**Stage**: 2\n\n#### Problem\nShould past deliberation outcomes inform future conflicts?\n\n#### Decision\nYes. Decided deliberations are indexed by entity type and contested attributes.\nWhen a new conflict arises, the system queries for precedent — past decisions\non the same entity type and attributes. Precedent doesn't bind (not stare decisis)\nbut is surfaced as context for the new deliberation.\n\n#### Formal Justification\nThe growth-only store guarantees precedent preservation by construction (no deliberation\nis ever deleted). Indexing by entity type and attributes is the natural decomposition:\nconflicts on the same kind of entity tend to have similar resolution patterns.\n\n---" :op :assert}
   {:e #blake3 "cb5ce1bf97c4695909859fa852cebd7f517d25246d3a26b237421d48892adc64" :a :element/traces-to :v "ADRS CR-007" :op :assert}
   {:e #blake3 "cb5ce1bf97c4695909859fa852cebd7f517d25246d3a26b237421d48892adc64" :a :adr/problem :v "Should past deliberation outcomes inform future conflicts?" :op :assert}
   {:e #blake3 "cb5ce1bf97c4695909859fa852cebd7f517d25246d3a26b237421d48892adc64" :a :adr/decision :v "Yes. Decided deliberations are indexed by entity type and contested attributes. When a new conflict arises, the system queries for precedent — past decisions on the same entity type and attributes. Precedent doesn't bind (not stare decisis) but is surfaced as context for the new deliberation." :op :assert}
   {:e #blake3 "3858ce113cceeeeb38046045c775ef1f2894635fd351ba947597e49e697aafa1" :a :db/ident :v :spec/adr-deliberation-004 :op :assert}
   {:e #blake3 "3858ce113cceeeeb38046045c775ef1f2894635fd351ba947597e49e697aafa1" :a :spec/element-type :v :spec.element/adr :op :assert}
   {:e #blake3 "3858ce113cceeeeb38046045c775ef1f2894635fd351ba947597e49e697aafa1" :a :spec/namespace :v :spec.ns/deliberation :op :assert}
   {:e #blake3 "3858ce113cceeeeb38046045c775ef1f2894635fd351ba947597e49e697aafa1" :a :db/doc :v "Crystallization Guard Over Immediate Commit" :op :assert}
   {:e #blake3 "3858ce113cceeeeb38046045c775ef1f2894635fd351ba947597e49e697aafa1" :a :spec/source-file :v "11-deliberation.md" :op :assert}
   {:e #blake3 "3858ce113cceeeeb38046045c775ef1f2894635fd351ba947597e49e697aafa1" :a :element/body :v "**Traces to**: ADRS CR-005\n**Stage**: 2\n\n#### Problem\nShould decisions take effect immediately or after a stability period?\n\n#### Decision\nStability guard. The default `stability_min = 0.7` ensures a decision is not\ncommitted prematurely. The guard checks six conditions (status, thread, confidence,\ncoherence, conflicts, commitment weight). This prevents the failure mode where\na quick decision with incomplete evidence cascades into downstream errors.\n\n#### Formal Justification\nPremature crystallization is an S0-severity failure mode (silently wrong artifacts\nwith no detection signal). The stability guard is the direct countermeasure.\nThe cost (delayed commitment) is justified by the risk (cascading incompleteness,\nFM-004).\n\n---" :op :assert}
   {:e #blake3 "3858ce113cceeeeb38046045c775ef1f2894635fd351ba947597e49e697aafa1" :a :element/traces-to :v "ADRS CR-005" :op :assert}
   {:e #blake3 "3858ce113cceeeeb38046045c775ef1f2894635fd351ba947597e49e697aafa1" :a :adr/problem :v "Should decisions take effect immediately or after a stability period?" :op :assert}
   {:e #blake3 "3858ce113cceeeeb38046045c775ef1f2894635fd351ba947597e49e697aafa1" :a :adr/decision :v "Stability guard. The default `stability_min = 0.7` ensures a decision is not committed prematurely. The guard checks six conditions (status, thread, confidence, coherence, conflicts, commitment weight). This prevents the failure mode where a quick decision with incomplete evidence cascades into downstream errors." :op :assert}
   {:e #blake3 "b1761b687269ddea849049ecdfbf7da11a78c18253a94068ba4ba8ed4c610003" :a :db/ident :v :spec/neg-deliberation-001 :op :assert}
   {:e #blake3 "b1761b687269ddea849049ecdfbf7da11a78c18253a94068ba4ba8ed4c610003" :a :spec/element-type :v :spec.element/negative-case :op :assert}
   {:e #blake3 "b1761b687269ddea849049ecdfbf7da11a78c18253a94068ba4ba8ed4c610003" :a :spec/namespace :v :spec.ns/deliberation :op :assert}
   {:e #blake3 "b1761b687269ddea849049ecdfbf7da11a78c18253a94068ba4ba8ed4c610003" :a :db/doc :v "No Decision Without Stability Guard" :op :assert}
   {:e #blake3 "b1761b687269ddea849049ecdfbf7da11a78c18253a94068ba4ba8ed4c610003" :a :spec/source-file :v "11-deliberation.md" :op :assert}
   {:e #blake3 "b1761b687269ddea849049ecdfbf7da11a78c18253a94068ba4ba8ed4c610003" :a :element/body :v "**Traces to**: ADRS CR-005\n**Verification**: `V:PROP`, `V:KANI`\n\n**Safety property**: `□ ¬(decision_recorded ∧ stability < stability_min)`\n\nNo decision may be recorded if the stability guard conditions are not met.\n\n**proptest strategy**: Generate random deliberation states with varying stability.\nAttempt DECIDE. Verify rejection when stability < threshold.\n\n**Kani harness**: Exhaustive check over all stability dimension combinations\nthat `decide()` rejects when any dimension is below threshold.\n\n---" :op :assert}
   {:e #blake3 "b1761b687269ddea849049ecdfbf7da11a78c18253a94068ba4ba8ed4c610003" :a :spec/statement :v "`□ ¬(decision_recorded ∧ stability < stability_min)`" :op :assert}
   {:e #blake3 "b1761b687269ddea849049ecdfbf7da11a78c18253a94068ba4ba8ed4c610003" :a :element/traces-to :v "ADRS CR-005" :op :assert}
   {:e #blake3 "b1761b687269ddea849049ecdfbf7da11a78c18253a94068ba4ba8ed4c610003" :a :spec/verification :v "`V:PROP`, `V:KANI`" :op :assert}
   {:e #blake3 "b1761b687269ddea849049ecdfbf7da11a78c18253a94068ba4ba8ed4c610003" :a :neg/violation :v "`□ ¬(decision_recorded ∧ stability < stability_min)`" :op :assert}
   {:e #blake3 "7aba1dedecb73320e20ddd7750c22031dc3fb747ba9ab4bc9f65f1f90732e752" :a :db/ident :v :spec/neg-deliberation-002 :op :assert}
