   {:e #blake3 "9f6119e6fcb929757f39964a93acea305ae05d706e55fc89c4b4a8ea37c38412" :a :db/ident :v :spec/inv-store-016 :op :assert}
   {:e #blake3 "9f6119e6fcb929757f39964a93acea305ae05d706e55fc89c4b4a8ea37c38412" :a :spec/element-type :v :spec.element/invariant :op :assert}
