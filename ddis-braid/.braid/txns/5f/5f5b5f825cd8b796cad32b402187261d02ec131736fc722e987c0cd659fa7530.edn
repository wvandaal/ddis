   {:e #blake3 "7dcc19f397e7df4a6a860f0b18fe98f28bc44a178c9230b032a5ccfb9fd006db" :a :spec/element-type :v :spec.element/invariant :op :assert}
   {:e #blake3 "7dcc19f397e7df4a6a860f0b18fe98f28bc44a178c9230b032a5ccfb9fd006db" :a :spec/namespace :v :spec.ns/query :op :assert}
   {:e #blake3 "7dcc19f397e7df4a6a860f0b18fe98f28bc44a178c9230b032a5ccfb9fd006db" :a :db/doc :v "Branch Visibility" :op :assert}
   {:e #blake3 "7dcc19f397e7df4a6a860f0b18fe98f28bc44a178c9230b032a5ccfb9fd006db" :a :spec/source-file :v "03-query.md" :op :assert}
   {:e #blake3 "7dcc19f397e7df4a6a860f0b18fe98f28bc44a178c9230b032a5ccfb9fd006db" :a :element/body :v "**Traces to**: ADRS AS-004\n**Verification**: `V:PROP`, `V:KANI`\n**Stage**: 2\n\n#### Level 0 (Algebraic Law)\n```\nvisible(branch b) = {d ∈ trunk | d.tx ≤ b.base_tx} ∪ {d | d.tx.branch = b}\n\nTrunk commits after the fork point are NOT visible unless the branch rebases.\n```\n\n#### Level 1 (State Invariant)\nA query against branch b sees exactly the trunk datoms at the fork point plus\nthe branch's own datoms. Snapshot isolation.\n\n**Falsification**: A branch query that sees trunk datoms with tx > branch.base_tx\nwithout an explicit rebase operation.\n\n---" :op :assert}
   {:e #blake3 "7dcc19f397e7df4a6a860f0b18fe98f28bc44a178c9230b032a5ccfb9fd006db" :a :spec/statement :v "``` visible(branch b) = {d ∈ trunk | d.tx ≤ b.base_tx} ∪ {d | d.tx.branch = b} Trunk commits after the fork point are NOT visible unless the branch rebases. ```" :op :assert}
   {:e #blake3 "7dcc19f397e7df4a6a860f0b18fe98f28bc44a178c9230b032a5ccfb9fd006db" :a :spec/falsification :v "A branch query that sees trunk datoms with tx > branch.base_tx without an explicit rebase operation." :op :assert}
   {:e #blake3 "7dcc19f397e7df4a6a860f0b18fe98f28bc44a178c9230b032a5ccfb9fd006db" :a :element/traces-to :v "ADRS AS-004" :op :assert}
   {:e #blake3 "7dcc19f397e7df4a6a860f0b18fe98f28bc44a178c9230b032a5ccfb9fd006db" :a :spec/verification :v "`V:PROP`, `V:KANI`" :op :assert}
   {:e #blake3 "a829ba33acbc77730e73ef752c49b8787aef9f9473e109eb7903dbd7b5c2fe81" :a :db/ident :v :spec/inv-query-005 :op :assert}
   {:e #blake3 "a829ba33acbc77730e73ef752c49b8787aef9f9473e109eb7903dbd7b5c2fe81" :a :spec/element-type :v :spec.element/invariant :op :assert}
   {:e #blake3 "a829ba33acbc77730e73ef752c49b8787aef9f9473e109eb7903dbd7b5c2fe81" :a :spec/namespace :v :spec.ns/query :op :assert}
   {:e #blake3 "a829ba33acbc77730e73ef752c49b8787aef9f9473e109eb7903dbd7b5c2fe81" :a :db/doc :v "Stratum Safety" :op :assert}
   {:e #blake3 "a829ba33acbc77730e73ef752c49b8787aef9f9473e109eb7903dbd7b5c2fe81" :a :spec/source-file :v "03-query.md" :op :assert}
   {:e #blake3 "a829ba33acbc77730e73ef752c49b8787aef9f9473e109eb7903dbd7b5c2fe81" :a :element/body :v "**Traces to**: ADRS SQ-004, SQ-009\n**Verification**: `V:TYPE`, `V:PROP`\n**Stage**: 0\n\n#### Level 0 (Algebraic Law)\n```\n∀ queries Q with stratum(Q) ∈ {0, 1}:         mode(Q) = Monotonic\n∀ queries Q with stratum(Q) ∈ {2, 3}:         mode(Q) = Stratified\n∀ queries Q with stratum(Q) = 4:              mode(Q) = Monotonic (conservative)\n∀ queries Q with stratum(Q) = 5:              mode(Q) = Barriered (for critical decisions)\n```\n\n#### Level 1 (State Invariant)\nThe query engine classifies every query into a stratum and enforces the corresponding\nmode constraint.\n\n**Falsification**: A stratum 5 query executing in Monotonic mode.\n\n---" :op :assert}
   {:e #blake3 "a829ba33acbc77730e73ef752c49b8787aef9f9473e109eb7903dbd7b5c2fe81" :a :spec/statement :v "``` ∀ queries Q with stratum(Q) ∈ {0, 1}:         mode(Q) = Monotonic ∀ queries Q with stratum(Q) ∈ {2, 3}:         mode(Q) = Stratified ∀ queries Q with stratum(Q) = 4:              mode(Q) = Monotonic (conservative) ∀ queries Q with stratum(Q) = 5:              mode(Q) = Barriered (for critical decisions) ```" :op :assert}
   {:e #blake3 "a829ba33acbc77730e73ef752c49b8787aef9f9473e109eb7903dbd7b5c2fe81" :a :spec/falsification :v "A stratum 5 query executing in Monotonic mode." :op :assert}
   {:e #blake3 "a829ba33acbc77730e73ef752c49b8787aef9f9473e109eb7903dbd7b5c2fe81" :a :element/traces-to :v "ADRS SQ-004, SQ-009" :op :assert}
   {:e #blake3 "a829ba33acbc77730e73ef752c49b8787aef9f9473e109eb7903dbd7b5c2fe81" :a :spec/verification :v "`V:TYPE`, `V:PROP`" :op :assert}
