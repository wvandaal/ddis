   {:e #blake3 "47f58ccf84ccca79c81eb0359096ebbcfa26bbb24f1d24c4bac33894ab4c8f57" :a :db/doc :v "No Working Set Leak" :op :assert}
   {:e #blake3 "47f58ccf84ccca79c81eb0359096ebbcfa26bbb24f1d24c4bac33894ab4c8f57" :a :spec/source-file :v "07-merge.md" :op :assert}
   {:e #blake3 "47f58ccf84ccca79c81eb0359096ebbcfa26bbb24f1d24c4bac33894ab4c8f57" :a :element/body :v "**Traces to**: ADRS PD-001\n**Verification**: `V:PROP`, `V:KANI`\n\n**Safety property**: `□ ¬(∃ W_α datom visible to agent β where α ≠ β)`\nWorking set datoms are never included in merge operations.\n\n**Kani harness**: For two agents with working sets, verify merge of their\nshared stores does not include any working set datom.\n\n---" :op :assert}
   {:e #blake3 "47f58ccf84ccca79c81eb0359096ebbcfa26bbb24f1d24c4bac33894ab4c8f57" :a :spec/statement :v "`□ ¬(∃ W_α datom visible to agent β where α ≠ β)`" :op :assert}
