   {:e #blake3 "e04b9e3184524c94f49916ba92adb0796ce75a7925aff9930124bbc24ae3d641" :a :spec/element-type :v :spec.element/invariant :op :assert}
   {:e #blake3 "e04b9e3184524c94f49916ba92adb0796ce75a7925aff9930124bbc24ae3d641" :a :spec/namespace :v :spec.ns/trilateral :op :assert}
   {:e #blake3 "e04b9e3184524c94f49916ba92adb0796ce75a7925aff9930124bbc24ae3d641" :a :db/doc :v "Three LIVE Projections" :op :assert}
   {:e #blake3 "e04b9e3184524c94f49916ba92adb0796ce75a7925aff9930124bbc24ae3d641" :a :spec/source-file :v "18-trilateral.md" :op :assert}
   {:e #blake3 "e04b9e3184524c94f49916ba92adb0796ce75a7925aff9930124bbc24ae3d641" :a :element/body :v "**Traces to**: SEED §1, §4, INV-STORE-012\n**Verification**: `V:PROP`\n**Stage**: 0\n\n#### Level 0 (Algebraic Law)\n```\nLIVE_I, LIVE_S, LIVE_P are monotone functions of the store semilattice (P(D), ∪):\n  S₁ ⊆ S₂ ⟹ LIVE_X(S₁) ⊆ LIVE_X(S₂)   for X ∈ {I, S, P}\n\nEach is a projection over a disjoint attribute namespace:\n  LIVE_X(S) = LIVE(project(S, X_ATTRS))\n  where LIVE is the INV-STORE-012 materialized view operation.\n```\n\n#### Level 1 (State Invariant)\nThe three LIVE views update incrementally with every transaction. Each view\ncontains exactly those datoms whose attribute falls within its namespace\npartition, with resolution applied per INV-STORE-012.\n\n**Falsification**: A datom with attribute in INTENT_ATTRS appears in LIVE_S\nor LIVE_P, or a transaction adding datoms to the store does not update the\nrelevant LIVE view.\n\n---" :op :assert}
   {:e #blake3 "e04b9e3184524c94f49916ba92adb0796ce75a7925aff9930124bbc24ae3d641" :a :spec/statement :v "``` LIVE_I, LIVE_S, LIVE_P are monotone functions of the store semilattice (P(D), ∪): S₁ ⊆ S₂ ⟹ LIVE_X(S₁) ⊆ LIVE_X(S₂)   for X ∈ {I, S, P} Each is a projection over a disjoint attribute namespace: LIVE_X(S) = LIVE(project(S, X_ATTRS)) where LIVE is the INV-STORE-012 materialized view operation. ```" :op :assert}
   {:e #blake3 "e04b9e3184524c94f49916ba92adb0796ce75a7925aff9930124bbc24ae3d641" :a :spec/falsification :v "A datom with attribute in INTENT_ATTRS appears in LIVE_S or LIVE_P, or a transaction adding datoms to the store does not update the relevant LIVE view." :op :assert}
   {:e #blake3 "e04b9e3184524c94f49916ba92adb0796ce75a7925aff9930124bbc24ae3d641" :a :element/traces-to :v "SEED §1, §4, INV-STORE-012" :op :assert}
   {:e #blake3 "e04b9e3184524c94f49916ba92adb0796ce75a7925aff9930124bbc24ae3d641" :a :spec/verification :v "`V:PROP`" :op :assert}
   {:e #blake3 "a1a370f415cc769dcf14b1f438183b366bb43052bc230dda81522a79d0fa8b25" :a :db/ident :v :spec/inv-trilateral-002 :op :assert}
   {:e #blake3 "a1a370f415cc769dcf14b1f438183b366bb43052bc230dda81522a79d0fa8b25" :a :spec/element-type :v :spec.element/invariant :op :assert}
   {:e #blake3 "a1a370f415cc769dcf14b1f438183b366bb43052bc230dda81522a79d0fa8b25" :a :spec/namespace :v :spec.ns/trilateral :op :assert}
   {:e #blake3 "a1a370f415cc769dcf14b1f438183b366bb43052bc230dda81522a79d0fa8b25" :a :db/doc :v "Divergence as Live Metric" :op :assert}
   {:e #blake3 "a1a370f415cc769dcf14b1f438183b366bb43052bc230dda81522a79d0fa8b25" :a :spec/source-file :v "18-trilateral.md" :op :assert}
   {:e #blake3 "a1a370f415cc769dcf14b1f438183b366bb43052bc230dda81522a79d0fa8b25" :a :element/body :v "**Traces to**: SEED §2, §6, ADRS CO-010\n**Verification**: `V:PROP`\n**Stage**: 0\n\n#### Level 0 (Algebraic Law)\n```\nΦ(S) = w₁ × D_IS(S) + w₂ × D_SP(S)\n\nΦ is computable from the store alone — no external state required.\nΦ ≥ 0 (by construction: divergence counts are non-negative).\nΦ = 0 iff all intent datoms have :spec/traces-to links to spec datoms AND\n         all spec datoms have :spec/implements links to impl datoms (and vice versa).\n```\n\n#### Level 1 (State Invariant)\nΦ is recomputed after every transaction. The COMPUTE_PHI transition reads\nonly from the store — no session state, no external files, no configuration\nbeyond the boundary weights (which are themselves datoms in the store).\n\n**Falsification**: Φ computation requires state not in the store, or Φ is\nnegative, or Φ = 0 while unlinked datoms exist across boundaries.\n\n---" :op :assert}
   {:e #blake3 "a1a370f415cc769dcf14b1f438183b366bb43052bc230dda81522a79d0fa8b25" :a :spec/statement :v "``` Φ(S) = w₁ × D_IS(S) + w₂ × D_SP(S) Φ is computable from the store alone — no external state required. Φ ≥ 0 (by construction: divergence counts are non-negative). Φ = 0 iff all intent datoms have :spec/traces-to links to spec datoms AND all spec datoms have :spec/implements links to impl datoms (and vice versa). ```" :op :assert}
   {:e #blake3 "a1a370f415cc769dcf14b1f438183b366bb43052bc230dda81522a79d0fa8b25" :a :spec/falsification :v "Φ computation requires state not in the store, or Φ is negative, or Φ = 0 while unlinked datoms exist across boundaries." :op :assert}
   {:e #blake3 "a1a370f415cc769dcf14b1f438183b366bb43052bc230dda81522a79d0fa8b25" :a :element/traces-to :v "SEED §2, §6, ADRS CO-010" :op :assert}
   {:e #blake3 "a1a370f415cc769dcf14b1f438183b366bb43052bc230dda81522a79d0fa8b25" :a :spec/verification :v "`V:PROP`" :op :assert}
   {:e #blake3 "2449bd34a7739a69e369b534e626b79d793f26145045ea353fd943dca5a7bc26" :a :db/ident :v :spec/inv-trilateral-003 :op :assert}
   {:e #blake3 "2449bd34a7739a69e369b534e626b79d793f26145045ea353fd943dca5a7bc26" :a :spec/element-type :v :spec.element/invariant :op :assert}
   {:e #blake3 "2449bd34a7739a69e369b534e626b79d793f26145045ea353fd943dca5a7bc26" :a :spec/namespace :v :spec.ns/trilateral :op :assert}
   {:e #blake3 "2449bd34a7739a69e369b534e626b79d793f26145045ea353fd943dca5a7bc26" :a :db/doc :v "Formality Gradient" :op :assert}
   {:e #blake3 "2449bd34a7739a69e369b534e626b79d793f26145045ea353fd943dca5a7bc26" :a :spec/source-file :v "18-trilateral.md" :op :assert}
   {:e #blake3 "2449bd34a7739a69e369b534e626b79d793f26145045ea353fd943dca5a7bc26" :a :element/body :v "**Traces to**: SEED §3 (specification formalism)\n**Verification**: `V:PROP`\n**Stage**: 0\n\n#### Level 0 (Algebraic Law)\n```\nformality_level : EntityId × Store → {0, 1, 2, 3, 4}\n\n∀ store growth S ⊂ S':\n  formality_level(e, S') ≥ formality_level(e, S)\n  (monotonically non-decreasing under store growth)\n```\n\n#### Level 1 (State Invariant)\nFormality level is computed from link structure, not from metadata or labels.\nA datom starts at Level 0 (no links) and progresses through Levels 1–4 as\ncross-boundary links, falsification conditions, and verification evidence\nare added. Because the store is append-only (C1), removing links is impossible\nwithout retraction, and retraction of a link would create a new datom rather\nthan deleting the old one — the formality level as measured from the full\nhistory never decreases.\n\n**Falsification**: An entity's formality level decreases between two store\nstates where S ⊂ S' (the second state is a superset of the first).\n\n---" :op :assert}
   {:e #blake3 "2449bd34a7739a69e369b534e626b79d793f26145045ea353fd943dca5a7bc26" :a :spec/statement :v "``` formality_level : EntityId × Store → {0, 1, 2, 3, 4} ∀ store growth S ⊂ S': formality_level(e, S') ≥ formality_level(e, S) (monotonically non-decreasing under store growth) ```" :op :assert}
   {:e #blake3 "2449bd34a7739a69e369b534e626b79d793f26145045ea353fd943dca5a7bc26" :a :spec/falsification :v "An entity's formality level decreases between two store states where S ⊂ S' (the second state is a superset of the first)." :op :assert}
   {:e #blake3 "2449bd34a7739a69e369b534e626b79d793f26145045ea353fd943dca5a7bc26" :a :element/traces-to :v "SEED §3 (specification formalism)" :op :assert}
   {:e #blake3 "2449bd34a7739a69e369b534e626b79d793f26145045ea353fd943dca5a7bc26" :a :spec/verification :v "`V:PROP`" :op :assert}
   {:e #blake3 "dd7d25cde04067a2ffcc8436f5cbf9272b025174d96f8b822d8541bb605c0e6e" :a :db/ident :v :spec/inv-trilateral-004 :op :assert}
   {:e #blake3 "dd7d25cde04067a2ffcc8436f5cbf9272b025174d96f8b822d8541bb605c0e6e" :a :spec/element-type :v :spec.element/invariant :op :assert}
   {:e #blake3 "dd7d25cde04067a2ffcc8436f5cbf9272b025174d96f8b822d8541bb605c0e6e" :a :spec/namespace :v :spec.ns/trilateral :op :assert}
   {:e #blake3 "dd7d25cde04067a2ffcc8436f5cbf9272b025174d96f8b822d8541bb605c0e6e" :a :db/doc :v "Convergence Monotonicity" :op :assert}
   {:e #blake3 "dd7d25cde04067a2ffcc8436f5cbf9272b025174d96f8b822d8541bb605c0e6e" :a :spec/source-file :v "18-trilateral.md" :op :assert}
   {:e #blake3 "dd7d25cde04067a2ffcc8436f5cbf9272b025174d96f8b822d8541bb605c0e6e" :a :element/body :v "**Traces to**: SEED §6, INV-BILATERAL-001\n**Verification**: `V:PROP`\n**Stage**: 1\n\n#### Level 0 (Algebraic Law)\n```\n∀ LINK operations adding :spec/traces-to or :spec/implements links:\n  Φ(S') ≤ Φ(S)\n  (adding convergence links never increases total divergence)\n```\n\n#### Level 1 (State Invariant)\nThe LINK transition can only decrease Φ or leave it unchanged. Adding a\n`:spec/traces-to` link connects an intent datom to a spec datom, reducing D_IS.\nAdding an `:spec/implements` link connects an impl datom to a spec datom, reducing\nD_SP. Neither operation can increase divergence at any boundary.\n\nThis extends INV-BILATERAL-001 (monotonic convergence of the bilateral fitness\nfunction) to the full trilateral model.\n\n**Falsification**: A LINK operation that increases Φ — i.e., adding a\n`:spec/traces-to` or `:spec/implements` link results in higher total divergence.\n\n---" :op :assert}
   {:e #blake3 "dd7d25cde04067a2ffcc8436f5cbf9272b025174d96f8b822d8541bb605c0e6e" :a :spec/statement :v "``` ∀ LINK operations adding :spec/traces-to or :spec/implements links: Φ(S') ≤ Φ(S) (adding convergence links never increases total divergence) ```" :op :assert}
   {:e #blake3 "dd7d25cde04067a2ffcc8436f5cbf9272b025174d96f8b822d8541bb605c0e6e" :a :spec/falsification :v "A LINK operation that increases Φ — i.e., adding a `:spec/traces-to` or `:spec/implements` link results in higher total divergence." :op :assert}
   {:e #blake3 "dd7d25cde04067a2ffcc8436f5cbf9272b025174d96f8b822d8541bb605c0e6e" :a :element/traces-to :v "SEED §6, INV-BILATERAL-001" :op :assert}
