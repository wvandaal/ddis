   {:e #blake3 "8ecce14ff843bf5ed5d50b05fcd722dbf63659818709c629e828525475503c18" :a :adr/problem :v "The existing Go CLI (~62,500 LOC) represents significant engineering investment. How should Braid relate to this codebase? A full rewrite discards working code; incremental migration risks inheriting architectural debt." :op :assert}
