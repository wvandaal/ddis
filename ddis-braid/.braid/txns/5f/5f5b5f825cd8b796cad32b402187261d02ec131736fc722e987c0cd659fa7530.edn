   {:e #blake3 "7235649dfed8af613336199e2157c9f62f1841e75ada99ec0d35d007a9f4a27c" :a :db/doc :v "Confusion Triggers Re-Association" :op :assert}
   {:e #blake3 "7235649dfed8af613336199e2157c9f62f1841e75ada99ec0d35d007a9f4a27c" :a :spec/source-file :v "09-signal.md" :op :assert}
   {:e #blake3 "7235649dfed8af613336199e2157c9f62f1841e75ada99ec0d35d007a9f4a27c" :a :element/body :v "**Traces to**: ADRS PO-005\n**Verification**: `V:PROP`\n**Stage**: 1\n\n#### Level 0 (Algebraic Law)\n`dispatch(Confusion(cue)) = ReAssociate(cue)` — confusion signals trigger the\nassociative retrieval pipeline within one agent cycle (not a full round-trip).\n\n#### Level 1 (State Invariant)\nFor all reachable states where a Confusion signal is emitted:\nwithin the same agent cycle, ASSOCIATE + ASSEMBLE execute with the confusion cue\nas input, producing an updated context.\n\n#### Level 2 (Implementation Contract)\nThe agent cycle handler intercepts Confusion signals and invokes the\n`associate → query → assemble` pipeline before proceeding to the next action.\n\n**Falsification**: A Confusion signal is emitted and the agent proceeds to the next\naction without re-association.\n\n**proptest strategy**: Inject Confusion signals at random points in agent cycle\nsimulations. Verify re-association always executes before the next action.\n\n---" :op :assert}
   {:e #blake3 "7235649dfed8af613336199e2157c9f62f1841e75ada99ec0d35d007a9f4a27c" :a :spec/statement :v "`dispatch(Confusion(cue)) = ReAssociate(cue)` — confusion signals trigger the associative retrieval pipeline within one agent cycle (not a full round-trip)." :op :assert}
   {:e #blake3 "7235649dfed8af613336199e2157c9f62f1841e75ada99ec0d35d007a9f4a27c" :a :spec/falsification :v "A Confusion signal is emitted and the agent proceeds to the next action without re-association." :op :assert}
   {:e #blake3 "7235649dfed8af613336199e2157c9f62f1841e75ada99ec0d35d007a9f4a27c" :a :element/traces-to :v "ADRS PO-005" :op :assert}
