   {:e #blake3 "96cdb911ad9aa3884b7dc9ce2810b871a14c8e197cb269efed051e5280a1e9e1" :a :db/doc :v "Intention Anchoring" :op :assert}
   {:e #blake3 "96cdb911ad9aa3884b7dc9ce2810b871a14c8e197cb269efed051e5280a1e9e1" :a :spec/source-file :v "06-seed.md" :op :assert}
   {:e #blake3 "96cdb911ad9aa3884b7dc9ce2810b871a14c8e197cb269efed051e5280a1e9e1" :a :element/body :v "**Traces to**: ADRS AA-005, PO-003\n**Verification**: `V:PROP`\n**Stage**: 0\n\n#### Level 0 (Algebraic Law)\n```\n∀ ASSEMBLE operations with include_intentions=true:\n  ∀ active intentions I: I ∈ assembled_context at projection level π₀\n  regardless of budget pressure\n```\n\n#### Level 1 (State Invariant)\nActive intentions are pinned at full detail (π₀) even when the budget would\notherwise compress or omit them. Intentions are never sacrificed for budget.\n\n**Falsification**: An active intention omitted from the assembled context when\n`include_intentions=true`, or projected below π₀.\n\n---" :op :assert}
   {:e #blake3 "96cdb911ad9aa3884b7dc9ce2810b871a14c8e197cb269efed051e5280a1e9e1" :a :spec/statement :v "``` ∀ ASSEMBLE operations with include_intentions=true: ∀ active intentions I: I ∈ assembled_context at projection level π₀ regardless of budget pressure ```" :op :assert}
   {:e #blake3 "96cdb911ad9aa3884b7dc9ce2810b871a14c8e197cb269efed051e5280a1e9e1" :a :spec/falsification :v "An active intention omitted from the assembled context when `include_intentions=true`, or projected below π₀." :op :assert}
   {:e #blake3 "96cdb911ad9aa3884b7dc9ce2810b871a14c8e197cb269efed051e5280a1e9e1" :a :element/traces-to :v "ADRS AA-005, PO-003" :op :assert}
   {:e #blake3 "96cdb911ad9aa3884b7dc9ce2810b871a14c8e197cb269efed051e5280a1e9e1" :a :spec/verification :v "`V:PROP`" :op :assert}
