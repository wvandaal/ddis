   {:e #blake3 "9ac184aef26a2e7b57ec51c2b724b34f7509604f5fcf4c838b7f34aa6283338b" :a :spec/namespace :v :spec.ns/bilateral :op :assert}
   {:e #blake3 "9ac184aef26a2e7b57ec51c2b724b34f7509604f5fcf4c838b7f34aa6283338b" :a :db/doc :v "Residual Documentation" :op :assert}
   {:e #blake3 "9ac184aef26a2e7b57ec51c2b724b34f7509604f5fcf4c838b7f34aa6283338b" :a :spec/source-file :v "10-bilateral.md" :op :assert}
   {:e #blake3 "9ac184aef26a2e7b57ec51c2b724b34f7509604f5fcf4c838b7f34aa6283338b" :a :element/body :v "**Traces to**: SEED §6 (explicitly acknowledged residual)\n**Verification**: `V:PROP`\n**Stage**: 1\n\n#### Level 0 (Algebraic Law)\nEvery gap that persists beyond a bilateral cycle is either:\n(a) resolved in the next cycle, or\n(b) documented as a residual with uncertainty marker and rationale.\n\nNo gap persists undocumented.\n\n#### Level 1 (State Invariant)\n`∀ gap ∈ divergence_map: age(gap) > 1 cycle ⟹ gap ∈ residuals ∨ gap resolved`\n\n**Falsification**: A gap appears in the divergence map for two consecutive cycles\nwithout being either resolved or documented as a residual.\n\n---" :op :assert}
   {:e #blake3 "9ac184aef26a2e7b57ec51c2b724b34f7509604f5fcf4c838b7f34aa6283338b" :a :spec/statement :v "Every gap that persists beyond a bilateral cycle is either: (a) resolved in the next cycle, or (b) documented as a residual with uncertainty marker and rationale. No gap persists undocumented." :op :assert}
   {:e #blake3 "9ac184aef26a2e7b57ec51c2b724b34f7509604f5fcf4c838b7f34aa6283338b" :a :spec/falsification :v "A gap appears in the divergence map for two consecutive cycles without being either resolved or documented as a residual." :op :assert}
