   {:e #blake3 "7aba1dedecb73320e20ddd7750c22031dc3fb747ba9ab4bc9f65f1f90732e752" :a :db/doc :v "No Losing Branch Leak" :op :assert}
   {:e #blake3 "7aba1dedecb73320e20ddd7750c22031dc3fb747ba9ab4bc9f65f1f90732e752" :a :spec/source-file :v "11-deliberation.md" :op :assert}
   {:e #blake3 "7aba1dedecb73320e20ddd7750c22031dc3fb747ba9ab4bc9f65f1f90732e752" :a :element/body :v "**Traces to**: ADRS PO-007\n**Verification**: `V:PROP`, `V:MODEL`\n\n**Safety property**: `□ ¬(branch.status = :abandoned ∧ branch.datoms ∩ trunk' ⊃ branch.datoms ∩ trunk)`\n\nNo new datoms from an abandoned branch appear in trunk.\n\n**Stateright model**: 3 agents, 2 competing branches. Decision selects one.\nVerify no datoms from the loser appear in trunk post-decision.\n\n---" :op :assert}
   {:e #blake3 "7aba1dedecb73320e20ddd7750c22031dc3fb747ba9ab4bc9f65f1f90732e752" :a :spec/statement :v "`□ ¬(branch.status = :abandoned ∧ branch.datoms ∩ trunk' ⊃ branch.datoms ∩ trunk)`" :op :assert}
   {:e #blake3 "7aba1dedecb73320e20ddd7750c22031dc3fb747ba9ab4bc9f65f1f90732e752" :a :element/traces-to :v "ADRS PO-007" :op :assert}
   {:e #blake3 "7aba1dedecb73320e20ddd7750c22031dc3fb747ba9ab4bc9f65f1f90732e752" :a :spec/verification :v "`V:PROP`, `V:MODEL`" :op :assert}
   {:e #blake3 "7aba1dedecb73320e20ddd7750c22031dc3fb747ba9ab4bc9f65f1f90732e752" :a :neg/violation :v "`□ ¬(branch.status = :abandoned ∧ branch.datoms ∩ trunk' ⊃ branch.datoms ∩ trunk)`" :op :assert}
   {:e #blake3 "55533009b6d516dffe2bb54c76c440a601132cf10136b44cafc856c1ab1bcffb" :a :db/ident :v :spec/neg-deliberation-003 :op :assert}
   {:e #blake3 "55533009b6d516dffe2bb54c76c440a601132cf10136b44cafc856c1ab1bcffb" :a :spec/element-type :v :spec.element/negative-case :op :assert}
   {:e #blake3 "55533009b6d516dffe2bb54c76c440a601132cf10136b44cafc856c1ab1bcffb" :a :spec/namespace :v :spec.ns/deliberation :op :assert}
   {:e #blake3 "55533009b6d516dffe2bb54c76c440a601132cf10136b44cafc856c1ab1bcffb" :a :db/doc :v "No Backward Lifecycle Transition" :op :assert}
   {:e #blake3 "55533009b6d516dffe2bb54c76c440a601132cf10136b44cafc856c1ab1bcffb" :a :spec/source-file :v "11-deliberation.md" :op :assert}
   {:e #blake3 "55533009b6d516dffe2bb54c76c440a601132cf10136b44cafc856c1ab1bcffb" :a :element/body :v "**Traces to**: ADRS CR-004\n**Verification**: `V:PROP`, `V:KANI`\n\n**Safety property**: `□ ¬(lifecycle(d,t2) ⊏ lifecycle(d,t1) for t2 > t1)`\n\nDeliberation lifecycle progresses monotonically: open → active → decided/stalled → contested → superseded.\nNo backward transitions (e.g., decided → active) are permitted.\n\n**proptest strategy**: Generate random transition sequences. Verify lattice\nmonotonicity after each transition.\n\n---" :op :assert}
   {:e #blake3 "55533009b6d516dffe2bb54c76c440a601132cf10136b44cafc856c1ab1bcffb" :a :spec/statement :v "`□ ¬(lifecycle(d,t2) ⊏ lifecycle(d,t1) for t2 > t1)`" :op :assert}
   {:e #blake3 "55533009b6d516dffe2bb54c76c440a601132cf10136b44cafc856c1ab1bcffb" :a :element/traces-to :v "ADRS CR-004" :op :assert}
   {:e #blake3 "55533009b6d516dffe2bb54c76c440a601132cf10136b44cafc856c1ab1bcffb" :a :spec/verification :v "`V:PROP`, `V:KANI`" :op :assert}
   {:e #blake3 "55533009b6d516dffe2bb54c76c440a601132cf10136b44cafc856c1ab1bcffb" :a :neg/violation :v "`□ ¬(lifecycle(d,t2) ⊏ lifecycle(d,t1) for t2 > t1)`" :op :assert}
   {:e #blake3 "00fef033f5c329793efc40be3338ce3fe708f0b44a0e3db9a817b62d38313c3f" :a :db/ident :v :spec/inv-guidance-001 :op :assert}
   {:e #blake3 "00fef033f5c329793efc40be3338ce3fe708f0b44a0e3db9a817b62d38313c3f" :a :spec/element-type :v :spec.element/invariant :op :assert}
   {:e #blake3 "00fef033f5c329793efc40be3338ce3fe708f0b44a0e3db9a817b62d38313c3f" :a :spec/namespace :v :spec.ns/guidance :op :assert}
   {:e #blake3 "00fef033f5c329793efc40be3338ce3fe708f0b44a0e3db9a817b62d38313c3f" :a :db/doc :v "Continuous Injection" :op :assert}
   {:e #blake3 "00fef033f5c329793efc40be3338ce3fe708f0b44a0e3db9a817b62d38313c3f" :a :spec/source-file :v "12-guidance.md" :op :assert}
   {:e #blake3 "00fef033f5c329793efc40be3338ce3fe708f0b44a0e3db9a817b62d38313c3f" :a :element/body :v "**Traces to**: ADRS GU-005\n**Verification**: `V:PROP`\n**Stage**: 0\n\n#### Level 0 (Algebraic Law)\n`∀ tool_response r: ∃ footer f: r' = r ⊕ f`\nEvery tool response includes a guidance footer.\n\n#### Level 1 (State Invariant)\nThe INJECT transition always fires as post-processing on tool output.\nNo tool response reaches the agent without a guidance footer.\n\n#### Level 2 (Implementation Contract)\nThe CLI output pipeline appends a footer to every response. The footer\nis computed from current store state and k*_eff.\n\n**Falsification**: Any tool response reaches the agent without a guidance footer.\n\n**Stage 0 simplification** (ADR-GUIDANCE-008): At Stage 0, k*_eff is not yet available\n(BUDGET is Stage 1). The Stage 0 footer includes M(t) methodology adherence computed\nfrom 4 of 5 sub-metrics (m1 transact_frequency, m2 spec_language_ratio, m3 query_diversity,\nm4 harvest_quality; m5 guidance_compliance deferred to Stage 1), plus store state and\na next-action recommendation:\n```\n↳ M(t): 0.73 (tx: ✓ | spec-lang: ✓ | q-div: △ | harvest: ✓) | Store: 142 datoms | Turn 7\n  Next: braid query [:find ...] — verify INV-STORE-003\n```\nThe footer is always appended (the L0/L1 invariant holds unconditionally) and provides\nmeaningful anti-drift signal even without k*_eff. Stage 1 adds k*_eff-driven compression,\nfull M(t) with m5 guidance_compliance, and R(t) routing recommendation.\n\n---" :op :assert}
   {:e #blake3 "00fef033f5c329793efc40be3338ce3fe708f0b44a0e3db9a817b62d38313c3f" :a :spec/statement :v "`∀ tool_response r: ∃ footer f: r' = r ⊕ f` Every tool response includes a guidance footer." :op :assert}
   {:e #blake3 "00fef033f5c329793efc40be3338ce3fe708f0b44a0e3db9a817b62d38313c3f" :a :spec/falsification :v "Any tool response reaches the agent without a guidance footer. **Stage 0 simplification** (ADR-GUIDANCE-008): At Stage 0, k*_eff is not yet available (BUDGET is Stage 1). The Stage 0 footer includes M(t) methodology adherence computed from 4 of 5 sub-metrics (m1 transact_frequency, m2 spec_language_ratio, m3 query_diversity, m4 harvest_quality; m5 guidance_compliance deferred to Stage 1), plus store state and a next-action recommendation: ``` ↳ M(t): 0.73 (tx: ✓ | spec-lang: ✓ | q-div: △ | harvest: ✓) | Store: 142 datoms | Turn 7 Next: braid query [:find ...] — verify INV-STORE-003 ``` The footer is always appended (the L0/L1 invariant holds unconditionally) and provides meaningful anti-drift signal even without k*_eff. Stage 1 adds k*_eff-driven compression, full M(t) with m5 guidance_compliance, and R(t) routing recommendation." :op :assert}
   {:e #blake3 "00fef033f5c329793efc40be3338ce3fe708f0b44a0e3db9a817b62d38313c3f" :a :element/traces-to :v "ADRS GU-005" :op :assert}
