   {:e #blake3 "d3b88544eda1d6b7180f5d957ebb49f32cbfb16f4ff089ab7604446ebca730fa" :a :db/ident :v :spec/inv-query-003 :op :assert}
   {:e #blake3 "d3b88544eda1d6b7180f5d957ebb49f32cbfb16f4ff089ab7604446ebca730fa" :a :spec/element-type :v :spec.element/invariant :op :assert}
   {:e #blake3 "d3b88544eda1d6b7180f5d957ebb49f32cbfb16f4ff089ab7604446ebca730fa" :a :spec/namespace :v :spec.ns/query :op :assert}
   {:e #blake3 "d3b88544eda1d6b7180f5d957ebb49f32cbfb16f4ff089ab7604446ebca730fa" :a :db/doc :v "Query Significance Tracking" :op :assert}
   {:e #blake3 "d3b88544eda1d6b7180f5d957ebb49f32cbfb16f4ff089ab7604446ebca730fa" :a :spec/source-file :v "03-query.md" :op :assert}
   {:e #blake3 "d3b88544eda1d6b7180f5d957ebb49f32cbfb16f4ff089ab7604446ebca730fa" :a :element/body :v "**Traces to**: ADRS AS-007, PO-013\n**Verification**: `V:PROP`\n**Stage**: 1\n\n#### Level 0 (Algebraic Law)\n```\n∀ queries Q executed against store S:\n  an access event is recorded in the ACCESS LOG (separate from S)\n  significance(d) = Σ decay(now - t) × query_weight(q) over queries returning d\n```\n\n#### Level 1 (State Invariant)\nEvery query generates an access event in the access log, NOT in the main store.\nThe access log feeds significance computation for ASSOCIATE.\n\n**Falsification**: A query that completes without generating an access event, or\nan access event recorded in the main store (violating AS-007's separation requirement).\n\n---" :op :assert}
   {:e #blake3 "d3b88544eda1d6b7180f5d957ebb49f32cbfb16f4ff089ab7604446ebca730fa" :a :spec/statement :v "``` ∀ queries Q executed against store S: an access event is recorded in the ACCESS LOG (separate from S) significance(d) = Σ decay(now - t) × query_weight(q) over queries returning d ```" :op :assert}
   {:e #blake3 "d3b88544eda1d6b7180f5d957ebb49f32cbfb16f4ff089ab7604446ebca730fa" :a :spec/falsification :v "A query that completes without generating an access event, or an access event recorded in the main store (violating AS-007's separation requirement)." :op :assert}
   {:e #blake3 "d3b88544eda1d6b7180f5d957ebb49f32cbfb16f4ff089ab7604446ebca730fa" :a :element/traces-to :v "ADRS AS-007, PO-013" :op :assert}
   {:e #blake3 "d3b88544eda1d6b7180f5d957ebb49f32cbfb16f4ff089ab7604446ebca730fa" :a :spec/verification :v "`V:PROP`" :op :assert}
