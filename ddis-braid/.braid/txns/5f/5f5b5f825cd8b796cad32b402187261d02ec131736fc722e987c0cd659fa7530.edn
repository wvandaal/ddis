   {:e #blake3 "1096bbb818d634b223e5ef773f816a583afaf25ce47d444a986ec8586b99b383" :a :spec/element-type :v :spec.element/negative-case :op :assert}
   {:e #blake3 "1096bbb818d634b223e5ef773f816a583afaf25ce47d444a986ec8586b99b383" :a :spec/namespace :v :spec.ns/layout :op :assert}
   {:e #blake3 "1096bbb818d634b223e5ef773f816a583afaf25ce47d444a986ec8586b99b383" :a :db/doc :v "No In-Place File Modification" :op :assert}
   {:e #blake3 "1096bbb818d634b223e5ef773f816a583afaf25ce47d444a986ec8586b99b383" :a :spec/source-file :v "01b-storage-layout.md" :op :assert}
   {:e #blake3 "1096bbb818d634b223e5ef773f816a583afaf25ce47d444a986ec8586b99b383" :a :element/body :v "**Traces to**: C1, INV-STORE-001, INV-LAYOUT-002\n**Stage**: 0\n\n**Safety property**: `□ ¬(∃ operation that modifies bytes of an existing file in txns/)`\n\n**Statement**: No operation in the Layout API writes to, truncates, or modifies an existing\ntransaction file. The only filesystem write operation that targets `txns/` is `write_tx`,\nwhich creates a *new* file via `O_CREAT|O_EXCL`.\n\n**Enforcement mechanism**: Type-level. The Layout struct exposes `write_tx` (create),\n`read_tx` (read), `list_txns` (enumerate). There is no `update_tx`, `modify_tx`,\n`truncate_tx`, or any method that takes an existing path and modifies its contents.\n\n**Violation condition**: The existence of any code path that opens an existing file in\n`txns/` with write permissions (O_WRONLY or O_RDWR without O_CREAT|O_EXCL).\n\n---" :op :assert}
   {:e #blake3 "1096bbb818d634b223e5ef773f816a583afaf25ce47d444a986ec8586b99b383" :a :spec/statement :v "No operation in the Layout API writes to, truncates, or modifies an existing" :op :assert}
   {:e #blake3 "1096bbb818d634b223e5ef773f816a583afaf25ce47d444a986ec8586b99b383" :a :element/traces-to :v "C1, INV-STORE-001, INV-LAYOUT-002" :op :assert}
   {:e #blake3 "1096bbb818d634b223e5ef773f816a583afaf25ce47d444a986ec8586b99b383" :a :neg/violation :v "No operation in the Layout API writes to, truncates, or modifies an existing" :op :assert}
   {:e #blake3 "08f299f749486b6fe8449f696f92e16c70b39af97909accb6c95abf67698a5d2" :a :db/ident :v :spec/neg-layout-002 :op :assert}
   {:e #blake3 "08f299f749486b6fe8449f696f92e16c70b39af97909accb6c95abf67698a5d2" :a :spec/element-type :v :spec.element/negative-case :op :assert}
   {:e #blake3 "08f299f749486b6fe8449f696f92e16c70b39af97909accb6c95abf67698a5d2" :a :spec/namespace :v :spec.ns/layout :op :assert}
   {:e #blake3 "08f299f749486b6fe8449f696f92e16c70b39af97909accb6c95abf67698a5d2" :a :db/doc :v "No File Deletion" :op :assert}
   {:e #blake3 "08f299f749486b6fe8449f696f92e16c70b39af97909accb6c95abf67698a5d2" :a :spec/source-file :v "01b-storage-layout.md" :op :assert}
   {:e #blake3 "08f299f749486b6fe8449f696f92e16c70b39af97909accb6c95abf67698a5d2" :a :element/body :v "**Traces to**: C1, INV-STORE-001, INV-STORE-005 (monotonicity)\n**Stage**: 0\n\n**Safety property**: `□ ¬(∃ removal of a transaction file from txns/)`\n\n**Statement**: No operation in the Layout API deletes, moves, or renames a transaction file.\nThe transaction set is monotonically non-decreasing. This is C1 (append-only) at the\nfilesystem level.\n\n**Enforcement mechanism**: Type-level. The Layout API has no `delete_tx`, `remove_tx`,\n`cleanup_txns`, or `compact` method. The only deletion permitted is `.cache/` contents\n(which are derived caches, not source of truth — INV-LAYOUT-009).\n\n**Violation condition**: Any code path that calls `fs::remove_file`, `fs::remove_dir`,\nor `fs::rename` on a path within `txns/`.\n\n---" :op :assert}
   {:e #blake3 "08f299f749486b6fe8449f696f92e16c70b39af97909accb6c95abf67698a5d2" :a :spec/statement :v "No operation in the Layout API deletes, moves, or renames a transaction file." :op :assert}
   {:e #blake3 "08f299f749486b6fe8449f696f92e16c70b39af97909accb6c95abf67698a5d2" :a :element/traces-to :v "C1, INV-STORE-001, INV-STORE-005 (monotonicity)" :op :assert}
   {:e #blake3 "08f299f749486b6fe8449f696f92e16c70b39af97909accb6c95abf67698a5d2" :a :neg/violation :v "No operation in the Layout API deletes, moves, or renames a transaction file." :op :assert}
