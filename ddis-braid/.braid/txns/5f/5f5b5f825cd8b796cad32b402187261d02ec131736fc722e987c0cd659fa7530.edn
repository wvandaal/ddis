   {:e #blake3 "be63bdefa9441ff6f33b9506359b9b99706fa5ebafbe291935c8cfca52c9f30f" :a :spec/element-type :v :spec.element/invariant :op :assert}
   {:e #blake3 "be63bdefa9441ff6f33b9506359b9b99706fa5ebafbe291935c8cfca52c9f30f" :a :spec/namespace :v :spec.ns/budget :op :assert}
   {:e #blake3 "be63bdefa9441ff6f33b9506359b9b99706fa5ebafbe291935c8cfca52c9f30f" :a :db/doc :v "Guidance Compression by Budget" :op :assert}
   {:e #blake3 "be63bdefa9441ff6f33b9506359b9b99706fa5ebafbe291935c8cfca52c9f30f" :a :spec/source-file :v "13-budget.md" :op :assert}
   {:e #blake3 "be63bdefa9441ff6f33b9506359b9b99706fa5ebafbe291935c8cfca52c9f30f" :a :element/body :v "**Traces to**: ADRS IB-006\n**Verification**: `V:PROP`\n**Stage**: 1\n\n#### Level 0 (Algebraic Law)\nGuidance footer size is a function of k*_eff:\n```\nk > 0.7:    full (100–200 tokens)\n0.4–0.7:    compressed (30–60 tokens)\n≤ 0.4:      minimal (10–20 tokens)\n≤ 0.2:      harvest signal only (\"Run ddis harvest\")\n```\n\n#### Level 1 (State Invariant)\nThe INJECT transition (from GUIDANCE namespace) selects footer size\nbased on the current k*_eff from the budget manager.\n\n**Falsification**: At k*_eff = 0.1, the guidance footer is 100+ tokens instead\nof a minimal harvest signal.\n\n---" :op :assert}
   {:e #blake3 "be63bdefa9441ff6f33b9506359b9b99706fa5ebafbe291935c8cfca52c9f30f" :a :spec/statement :v "Guidance footer size is a function of k*_eff: ``` k > 0.7:    full (100–200 tokens) 0.4–0.7:    compressed (30–60 tokens) ≤ 0.4:      minimal (10–20 tokens) ≤ 0.2:      harvest signal only (\"Run ddis harvest\") ```" :op :assert}
   {:e #blake3 "be63bdefa9441ff6f33b9506359b9b99706fa5ebafbe291935c8cfca52c9f30f" :a :spec/falsification :v "At k*_eff = 0.1, the guidance footer is 100+ tokens instead of a minimal harvest signal." :op :assert}
   {:e #blake3 "be63bdefa9441ff6f33b9506359b9b99706fa5ebafbe291935c8cfca52c9f30f" :a :element/traces-to :v "ADRS IB-006" :op :assert}
   {:e #blake3 "be63bdefa9441ff6f33b9506359b9b99706fa5ebafbe291935c8cfca52c9f30f" :a :spec/verification :v "`V:PROP`" :op :assert}
   {:e #blake3 "456793d5594b66d72c7e29a5cb18884c813692ac6111a486a8974e12df9fdba7" :a :db/ident :v :spec/inv-budget-005 :op :assert}
   {:e #blake3 "456793d5594b66d72c7e29a5cb18884c813692ac6111a486a8974e12df9fdba7" :a :spec/element-type :v :spec.element/invariant :op :assert}
   {:e #blake3 "456793d5594b66d72c7e29a5cb18884c813692ac6111a486a8974e12df9fdba7" :a :spec/namespace :v :spec.ns/budget :op :assert}
   {:e #blake3 "456793d5594b66d72c7e29a5cb18884c813692ac6111a486a8974e12df9fdba7" :a :db/doc :v "Command Attention Profile" :op :assert}
   {:e #blake3 "456793d5594b66d72c7e29a5cb18884c813692ac6111a486a8974e12df9fdba7" :a :spec/source-file :v "13-budget.md" :op :assert}
   {:e #blake3 "456793d5594b66d72c7e29a5cb18884c813692ac6111a486a8974e12df9fdba7" :a :element/body :v "**Traces to**: ADRS IB-007\n**Verification**: `V:PROP`\n**Stage**: 1\n\n#### Level 0 (Algebraic Law)\nCommands are classified by attention cost:\n```\nCHEAP    (≤ 50 tokens):  status, guidance, frontier, branch ls\nMODERATE (50–300):        associate, query, assemble, diff\nEXPENSIVE (300+):         assemble --full, seed\nMETA     (side effects):  harvest, transact, merge\n```\n\nThe budget manager adjusts output to stay within the allocated cost.\n\n#### Level 1 (State Invariant)\nEach CLI command has a declared attention profile. The output pipeline\nrespects the profile ceiling, truncating to fit.\n\n**Falsification**: A CHEAP command produces 300+ tokens of output.\n\n---" :op :assert}
   {:e #blake3 "456793d5594b66d72c7e29a5cb18884c813692ac6111a486a8974e12df9fdba7" :a :spec/statement :v "Commands are classified by attention cost: ``` CHEAP    (≤ 50 tokens):  status, guidance, frontier, branch ls MODERATE (50–300):        associate, query, assemble, diff EXPENSIVE (300+):         assemble --full, seed META     (side effects):  harvest, transact, merge ``` The budget manager adjusts output to stay within the allocated cost." :op :assert}
   {:e #blake3 "456793d5594b66d72c7e29a5cb18884c813692ac6111a486a8974e12df9fdba7" :a :spec/falsification :v "A CHEAP command produces 300+ tokens of output." :op :assert}
   {:e #blake3 "456793d5594b66d72c7e29a5cb18884c813692ac6111a486a8974e12df9fdba7" :a :element/traces-to :v "ADRS IB-007" :op :assert}
   {:e #blake3 "456793d5594b66d72c7e29a5cb18884c813692ac6111a486a8974e12df9fdba7" :a :spec/verification :v "`V:PROP`" :op :assert}
   {:e #blake3 "112f2c4b5a7096ba1c6050e87462157fd12ead26adf51996adf74823ad2ff8ed" :a :db/ident :v :spec/inv-budget-006 :op :assert}
   {:e #blake3 "112f2c4b5a7096ba1c6050e87462157fd12ead26adf51996adf74823ad2ff8ed" :a :spec/element-type :v :spec.element/invariant :op :assert}
   {:e #blake3 "112f2c4b5a7096ba1c6050e87462157fd12ead26adf51996adf74823ad2ff8ed" :a :spec/namespace :v :spec.ns/budget :op :assert}
   {:e #blake3 "112f2c4b5a7096ba1c6050e87462157fd12ead26adf51996adf74823ad2ff8ed" :a :db/doc :v "Token Efficiency as Testable Property" :op :assert}
   {:e #blake3 "112f2c4b5a7096ba1c6050e87462157fd12ead26adf51996adf74823ad2ff8ed" :a :spec/source-file :v "13-budget.md" :op :assert}
   {:e #blake3 "112f2c4b5a7096ba1c6050e87462157fd12ead26adf51996adf74823ad2ff8ed" :a :element/body :v "**Traces to**: ADRS IB-011\n**Verification**: `V:PROP`, `V:KANI`\n**Stage**: 1\n\n#### Level 0 (Algebraic Law)\n\nInformation density function `ρ(output) = semantic_units(output) / |output|`.\nFor a budget constraint `b`, the output `O(cmd, b)` satisfies:\n\n1. `|O(cmd, b)| ≤ b` — hard budget cap (already in INV-BUDGET-001)\n2. `ρ(O(cmd, b₁)) ≤ ρ(O(cmd, b₂))` for `b₁ > b₂` — density monotonicity\n   (tighter budgets produce denser output, not truncated output)\n3. Mode-specific ceilings:\n   - `agent_mode ≤ 300 tokens`\n   - `guidance_footer ≤ 50 tokens`\n   - `error_message ≤ 100 tokens`\n\n#### Level 1 (State Invariant)\n\nThe output pipeline evaluates density at each projection level. When budget\nforces projection from a higher level (Full) to a lower level (Summary), the\ndensity of the lower projection is verified to be ≥ the density of the higher.\nThe pipeline never produces output that is merely truncated — it always\nre-projects at a lower level.\n\n#### Level 2 (Implementation Contract)\n\n```rust\npub struct TokenEfficiency {\n    pub semantic_units: usize,\n    pub token_count: usize,\n}\n\nimpl TokenEfficiency {\n    pub fn density(&self) -> f64 {\n        self.semantic_units as f64 / self.token_count.max(1) as f64\n    }\n}\n\npub const AGENT_MODE_CEILING: usize = 300;\npub const GUIDANCE_FOOTER_CEILING: usize = 50;\npub const ERROR_MESSAGE_CEILING: usize = 100;\n\n// proptest: for any command at budget b1 > b2,\n//   density(output(cmd, b2)) >= density(output(cmd, b1))\n```\n\n**Falsification**: Reducing the budget by 50% reduces information value by more\nthan 50% (distortion exceeds rate-distortion bound), OR agent-mode output\nexceeds 300 tokens, OR a guidance footer exceeds 50 tokens, OR an error message\nexceeds 100 tokens.\n\n---" :op :assert}
   {:e #blake3 "112f2c4b5a7096ba1c6050e87462157fd12ead26adf51996adf74823ad2ff8ed" :a :spec/statement :v "Information density function `ρ(output) = semantic_units(output) / |output|`. For a budget constraint `b`, the output `O(cmd, b)` satisfies: 1. `|O(cmd, b)| ≤ b` — hard budget cap (already in INV-BUDGET-001) 2. `ρ(O(cmd, b₁)) ≤ ρ(O(cmd, b₂))` for `b₁ > b₂` — density monotonicity (tighter budgets produce denser output, not truncated output) 3. Mode-specific ceilings: - `agent_mode ≤ 300 tokens` - `guidance_footer ≤ 50 tokens` - `error_message ≤ 100 tokens`" :op :assert}
   {:e #blake3 "112f2c4b5a7096ba1c6050e87462157fd12ead26adf51996adf74823ad2ff8ed" :a :spec/falsification :v "Reducing the budget by 50% reduces information value by more than 50% (distortion exceeds rate-distortion bound), OR agent-mode output exceeds 300 tokens, OR a guidance footer exceeds 50 tokens, OR an error message exceeds 100 tokens." :op :assert}
   {:e #blake3 "112f2c4b5a7096ba1c6050e87462157fd12ead26adf51996adf74823ad2ff8ed" :a :element/traces-to :v "ADRS IB-011" :op :assert}
   {:e #blake3 "112f2c4b5a7096ba1c6050e87462157fd12ead26adf51996adf74823ad2ff8ed" :a :spec/verification :v "`V:PROP`, `V:KANI`" :op :assert}
   {:e #blake3 "cff9e078718897905209a59783f1a9ae961851a41e9b8449f05b08e1676543a4" :a :db/ident :v :spec/adr-budget-001 :op :assert}
   {:e #blake3 "cff9e078718897905209a59783f1a9ae961851a41e9b8449f05b08e1676543a4" :a :spec/element-type :v :spec.element/adr :op :assert}
   {:e #blake3 "cff9e078718897905209a59783f1a9ae961851a41e9b8449f05b08e1676543a4" :a :spec/namespace :v :spec.ns/budget :op :assert}
   {:e #blake3 "cff9e078718897905209a59783f1a9ae961851a41e9b8449f05b08e1676543a4" :a :db/doc :v "Measured Context Over Heuristic" :op :assert}
   {:e #blake3 "cff9e078718897905209a59783f1a9ae961851a41e9b8449f05b08e1676543a4" :a :spec/source-file :v "13-budget.md" :op :assert}
   {:e #blake3 "cff9e078718897905209a59783f1a9ae961851a41e9b8449f05b08e1676543a4" :a :element/body :v "**Traces to**: ADRS IB-005\n**Stage**: 1\n\n#### Problem\nShould attention budget be estimated heuristically or measured from actual consumption?\n\n#### Decision\nMeasured. Claude Code exposes `context_window.used_percentage` via the statusline hook.\nThis gives ground truth. The heuristic `k*_eff = k*_base × e^{-0.03n}` becomes fallback\nonly when measurement is unavailable.\n\n#### Formal Justification\nHeuristic is inaccurate because conversation structure varies — a session with many\nlong tool outputs consumes context faster than one with short exchanges. Measured\nconsumption eliminates this source of error.\n\n---" :op :assert}
   {:e #blake3 "cff9e078718897905209a59783f1a9ae961851a41e9b8449f05b08e1676543a4" :a :element/traces-to :v "ADRS IB-005" :op :assert}
   {:e #blake3 "cff9e078718897905209a59783f1a9ae961851a41e9b8449f05b08e1676543a4" :a :adr/problem :v "Should attention budget be estimated heuristically or measured from actual consumption?" :op :assert}
   {:e #blake3 "cff9e078718897905209a59783f1a9ae961851a41e9b8449f05b08e1676543a4" :a :adr/decision :v "Measured. Claude Code exposes `context_window.used_percentage` via the statusline hook. This gives ground truth. The heuristic `k*_eff = k*_base × e^{-0.03n}` becomes fallback only when measurement is unavailable." :op :assert}
   {:e #blake3 "a187f480ba14831ea1767c6c33fd64a7e2aed9c871ddac05641a0a91b4393a2e" :a :db/ident :v :spec/adr-budget-002 :op :assert}
   {:e #blake3 "a187f480ba14831ea1767c6c33fd64a7e2aed9c871ddac05641a0a91b4393a2e" :a :spec/element-type :v :spec.element/adr :op :assert}
   {:e #blake3 "a187f480ba14831ea1767c6c33fd64a7e2aed9c871ddac05641a0a91b4393a2e" :a :spec/namespace :v :spec.ns/budget :op :assert}
   {:e #blake3 "a187f480ba14831ea1767c6c33fd64a7e2aed9c871ddac05641a0a91b4393a2e" :a :db/doc :v "Piecewise Attention Decay" :op :assert}
   {:e #blake3 "a187f480ba14831ea1767c6c33fd64a7e2aed9c871ddac05641a0a91b4393a2e" :a :spec/source-file :v "13-budget.md" :op :assert}
   {:e #blake3 "a187f480ba14831ea1767c6c33fd64a7e2aed9c871ddac05641a0a91b4393a2e" :a :element/body :v "**Traces to**: ADRS IB-005\n**Verification**: Used in Q(t) computation\n**Stage**: 1\n\n#### Problem\nHow should attention quality degrade with context consumption?\n\n#### Decision\nPiecewise: full quality above 60% remaining, linear degradation 30–60%,\nquadratic degradation below 30%.\n\n#### Formal Justification\nEmpirical observation: LLM attention quality degrades faster than a simple linear\nmodel would predict. The piecewise function captures three regimes: comfortable\n(no degradation), pressured (graceful degradation), critical (rapid degradation).\nThe quadratic regime below 30% reflects the observed cliff in output quality.\n\n---" :op :assert}
   {:e #blake3 "a187f480ba14831ea1767c6c33fd64a7e2aed9c871ddac05641a0a91b4393a2e" :a :element/traces-to :v "ADRS IB-005" :op :assert}
   {:e #blake3 "a187f480ba14831ea1767c6c33fd64a7e2aed9c871ddac05641a0a91b4393a2e" :a :spec/verification :v "Used in Q(t) computation" :op :assert}
   {:e #blake3 "a187f480ba14831ea1767c6c33fd64a7e2aed9c871ddac05641a0a91b4393a2e" :a :adr/problem :v "How should attention quality degrade with context consumption?" :op :assert}
   {:e #blake3 "a187f480ba14831ea1767c6c33fd64a7e2aed9c871ddac05641a0a91b4393a2e" :a :adr/decision :v "Piecewise: full quality above 60% remaining, linear degradation 30–60%, quadratic degradation below 30%." :op :assert}
   {:e #blake3 "1a187f1541b51ec55f08050025a6146905009feeffbe79ea18b160a68d589b5e" :a :db/ident :v :spec/adr-budget-003 :op :assert}
   {:e #blake3 "1a187f1541b51ec55f08050025a6146905009feeffbe79ea18b160a68d589b5e" :a :spec/element-type :v :spec.element/adr :op :assert}
   {:e #blake3 "1a187f1541b51ec55f08050025a6146905009feeffbe79ea18b160a68d589b5e" :a :spec/namespace :v :spec.ns/budget :op :assert}
   {:e #blake3 "1a187f1541b51ec55f08050025a6146905009feeffbe79ea18b160a68d589b5e" :a :db/doc :v "Rate-Distortion Framework" :op :assert}
   {:e #blake3 "1a187f1541b51ec55f08050025a6146905009feeffbe79ea18b160a68d589b5e" :a :spec/source-file :v "13-budget.md" :op :assert}
   {:e #blake3 "1a187f1541b51ec55f08050025a6146905009feeffbe79ea18b160a68d589b5e" :a :element/body :v "**Traces to**: ADRS IB-011\n**Stage**: 1\n\n#### Problem\nWhat theoretical framework governs the budget-information tradeoff?\n\n#### Decision\nRate-distortion theory. The interface is a channel with rate constraint (budget).\nThe system maximizes information value while minimizing distortion (loss of\nimportant facts) at the given rate. The projection pyramid (π₀–π₃) is the\ncodebook with decreasing rate requirements.\n\n#### Formal Justification\nRate-distortion is the information-theoretic framework for lossy compression\nwith quality guarantees. It formalizes the intuition that \"less budget = less\ndetail, but the most important things survive.\" The precedence ordering defines\nwhat \"most important\" means.\n\n---" :op :assert}
   {:e #blake3 "1a187f1541b51ec55f08050025a6146905009feeffbe79ea18b160a68d589b5e" :a :element/traces-to :v "ADRS IB-011" :op :assert}
   {:e #blake3 "1a187f1541b51ec55f08050025a6146905009feeffbe79ea18b160a68d589b5e" :a :adr/problem :v "What theoretical framework governs the budget-information tradeoff?" :op :assert}
   {:e #blake3 "1a187f1541b51ec55f08050025a6146905009feeffbe79ea18b160a68d589b5e" :a :adr/decision :v "Rate-distortion theory. The interface is a channel with rate constraint (budget). The system maximizes information value while minimizing distortion (loss of important facts) at the given rate. The projection pyramid (π₀–π₃) is the codebook with decreasing rate requirements." :op :assert}
   {:e #blake3 "74c6787c0024794916d5dc3df97767f97355c17acbc6e1810a3b6a38ea7639a5" :a :db/ident :v :spec/adr-budget-004 :op :assert}
   {:e #blake3 "74c6787c0024794916d5dc3df97767f97355c17acbc6e1810a3b6a38ea7639a5" :a :spec/element-type :v :spec.element/adr :op :assert}
   {:e #blake3 "74c6787c0024794916d5dc3df97767f97355c17acbc6e1810a3b6a38ea7639a5" :a :spec/namespace :v :spec.ns/budget :op :assert}
   {:e #blake3 "74c6787c0024794916d5dc3df97767f97355c17acbc6e1810a3b6a38ea7639a5" :a :db/doc :v "Tokenization via Chars/4 Approximation" :op :assert}
   {:e #blake3 "74c6787c0024794916d5dc3df97767f97355c17acbc6e1810a3b6a38ea7639a5" :a :spec/source-file :v "13-budget.md" :op :assert}
   {:e #blake3 "74c6787c0024794916d5dc3df97767f97355c17acbc6e1810a3b6a38ea7639a5" :a :element/body :v "**Traces to**: SEED §8, ADRS IMPL-002\n**Stage**: 0\n\n#### Problem\nThe budget system requires token counting to enforce output caps, select\nprojection levels, and compute Q(t). At Stage 0, what tokenization strategy\nshould be used? Accurate tokenization requires model-specific vocabulary tables\n(e.g., tiktoken cl100k_base for Claude/GPT-4), which add dependencies and\ncomplexity.\n\n#### Options\nA) **tiktoken-rs at Stage 0** — use the cl100k_base tokenizer from day one for accurate counts.\nB) **HuggingFace tokenizers** — use the HuggingFace tokenizers crate with a Claude-specific model.\nC) **bpe crate** — use a generic BPE implementation.\nD) **chars/4 approximation** — estimate tokens as character count divided by 4, with content-type correction factors. Behind a `TokenCounter` trait for future swappability.\n\n#### Decision\n**Option D.** Use chars/4 with content-type correction factors at Stage 0.\nGraduate to tiktoken-rs (cl100k_base) at Stage 1 when token efficiency tracking\nneeds cross-session comparability. The implementation is behind a `TokenCounter`\ntrait so the approximation can be swapped for an accurate tokenizer without\nchanging any calling code.\n\nThe budget system operates on coarse bands (200/500/2000 tokens for projection\npyramid levels). A 15-20% approximation error from chars/4 rarely changes band\nselection. The error is systematic (consistently overestimates for code,\nunderestimates for prose) and can be partially corrected with content-type factors.\n\n#### Formal Justification\nAt Stage 0, zero external dependencies is a design goal — the system should be\nself-contained and buildable without network access. tiktoken-rs (Option A) adds\na non-trivial dependency with a model vocabulary file. HuggingFace tokenizers\n(Option B) pulls ~40 transitive dependencies and has no Claude-specific model.\nbpe (Option C) provides no model-specific encoding. The chars/4 approximation\n(Option D) has zero dependencies, is trivially correct to implement, and the\nbudget system's coarse bands (200/500/2000) provide sufficient margin for a\n15-20% error. The `TokenCounter` trait ensures the graduation path to accurate\ntokenization is frictionless.\n\n#### Consequences\n- Zero dependencies for tokenization at Stage 0\n- 15-20% approximation error, which is acceptable for coarse band selection\n- `TokenCounter` trait abstracts the strategy: `fn count(&self, text: &str) -> usize`\n- Content-type correction: `code_factor = 0.85`, `prose_factor = 1.1`, `mixed_factor = 1.0`\n- Stage 1 replaces the implementation behind the trait with tiktoken-rs cl100k_base\n- Cross-session token comparisons are not reliable until Stage 1\n\n#### Falsification\nThe chars/4 approximation error causes incorrect projection level selection in\nmore than 10% of cases (measured empirically), OR the `TokenCounter` trait is\nnot used (making the graduation path to accurate tokenization require widespread\ncode changes), OR Stage 0 adds tiktoken-rs as a dependency.\n\n---" :op :assert}
   {:e #blake3 "74c6787c0024794916d5dc3df97767f97355c17acbc6e1810a3b6a38ea7639a5" :a :element/traces-to :v "SEED §8, ADRS IMPL-002" :op :assert}
   {:e #blake3 "74c6787c0024794916d5dc3df97767f97355c17acbc6e1810a3b6a38ea7639a5" :a :adr/problem :v "The budget system requires token counting to enforce output caps, select projection levels, and compute Q(t). At Stage 0, what tokenization strategy should be used? Accurate tokenization requires model-specific vocabulary tables (e.g., tiktoken cl100k_base for Claude/GPT-4), which add dependencies and complexity." :op :assert}
   {:e #blake3 "74c6787c0024794916d5dc3df97767f97355c17acbc6e1810a3b6a38ea7639a5" :a :adr/decision :v "**Option D.** Use chars/4 with content-type correction factors at Stage 0. Graduate to tiktoken-rs (cl100k_base) at Stage 1 when token efficiency tracking needs cross-session comparability. The implementation is behind a `TokenCounter` trait so the approximation can be swapped for an accurate tokenizer without changing any calling code. The budget system operates on coarse bands (200/500/2000 tokens for projection pyramid levels). A 15-20% approximation error from chars/4 rarely changes band selection. The error is systematic (consistently overestimates for code, underestimates for prose) and can be partially corrected with content-type factors." :op :assert}
