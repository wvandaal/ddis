   {:e #blake3 "28700857c34c222e6289abfe80d554db3971abf560781786d784a8f4ac8f0343" :a :db/doc :v "Spec-Language Phrasing" :op :assert}
   {:e #blake3 "28700857c34c222e6289abfe80d554db3971abf560781786d784a8f4ac8f0343" :a :spec/source-file :v "12-guidance.md" :op :assert}
   {:e #blake3 "28700857c34c222e6289abfe80d554db3971abf560781786d784a8f4ac8f0343" :a :element/body :v "**Traces to**: ADRS GU-003\n**Verification**: `V:PROP`\n**Stage**: 0\n\n#### Level 0 (Algebraic Law)\nGuidance text references invariant IDs, formal structures, and spec elements.\nNever instruction-language (\"do step 1, then step 2\") — always spec-language\n(\"INV-STORE-001 requires append-only; current operation would mutate\").\n\n#### Level 1 (State Invariant)\nGuidance generation templates use invariant references. The template engine\npulls from the store's invariant index, not from hardcoded instruction strings.\n\n**Falsification**: Guidance output contains a numbered checklist or imperative\ninstruction without invariant reference.\n\n---" :op :assert}
   {:e #blake3 "28700857c34c222e6289abfe80d554db3971abf560781786d784a8f4ac8f0343" :a :spec/statement :v "Guidance text references invariant IDs, formal structures, and spec elements. Never instruction-language (\"do step 1, then step 2\") — always spec-language (\"INV-STORE-001 requires append-only; current operation would mutate\")." :op :assert}
   {:e #blake3 "28700857c34c222e6289abfe80d554db3971abf560781786d784a8f4ac8f0343" :a :spec/falsification :v "Guidance output contains a numbered checklist or imperative instruction without invariant reference." :op :assert}
   {:e #blake3 "28700857c34c222e6289abfe80d554db3971abf560781786d784a8f4ac8f0343" :a :element/traces-to :v "ADRS GU-003" :op :assert}
