   {:e #blake3 "40a9f5161b6fab59174d532562354a04ef653dd41bba69a34768157a04b3be0f" :a :db/ident :v :spec/inv-sync-001 :op :assert}
   {:e #blake3 "40a9f5161b6fab59174d532562354a04ef653dd41bba69a34768157a04b3be0f" :a :spec/element-type :v :spec.element/invariant :op :assert}
   {:e #blake3 "40a9f5161b6fab59174d532562354a04ef653dd41bba69a34768157a04b3be0f" :a :spec/namespace :v :spec.ns/sync :op :assert}
   {:e #blake3 "40a9f5161b6fab59174d532562354a04ef653dd41bba69a34768157a04b3be0f" :a :db/doc :v "Barrier Produces Consistent Cut" :op :assert}
   {:e #blake3 "40a9f5161b6fab59174d532562354a04ef653dd41bba69a34768157a04b3be0f" :a :spec/source-file :v "08-sync.md" :op :assert}
   {:e #blake3 "40a9f5161b6fab59174d532562354a04ef653dd41bba69a34768157a04b3be0f" :a :element/body :v "**Traces to**: SEED §6, ADRS PO-010\n**Verification**: `V:PROP`, `V:MODEL`\n**Stage**: 3\n\n#### Level 0 (Algebraic Law)\n```\n∀ resolved barriers B with participants {α₁, ..., αₙ}:\n  ∀ i, j: datoms_visible(αᵢ, B.cut) = datoms_visible(αⱼ, B.cut)\n  (all participants see the same datom set at the cut)\n```\n\n#### Level 1 (State Invariant)\nA resolved barrier guarantees that all participants have exchanged all\ndatoms up to the cut point. Non-monotonic queries at this cut produce\nidentical results regardless of which participant evaluates them.\n\n**Falsification**: Two participants at a resolved barrier producing different\nresults for the same non-monotonic query.\n\n**Stateright model**: 3 agents with different initial datom sets. Run barrier\nprotocol. Verify post-barrier query determinism across all agents.\n\n---" :op :assert}
   {:e #blake3 "40a9f5161b6fab59174d532562354a04ef653dd41bba69a34768157a04b3be0f" :a :spec/statement :v "``` ∀ resolved barriers B with participants {α₁, ..., αₙ}: ∀ i, j: datoms_visible(αᵢ, B.cut) = datoms_visible(αⱼ, B.cut) (all participants see the same datom set at the cut) ```" :op :assert}
   {:e #blake3 "40a9f5161b6fab59174d532562354a04ef653dd41bba69a34768157a04b3be0f" :a :spec/falsification :v "Two participants at a resolved barrier producing different results for the same non-monotonic query." :op :assert}
   {:e #blake3 "40a9f5161b6fab59174d532562354a04ef653dd41bba69a34768157a04b3be0f" :a :element/traces-to :v "SEED §6, ADRS PO-010" :op :assert}
   {:e #blake3 "40a9f5161b6fab59174d532562354a04ef653dd41bba69a34768157a04b3be0f" :a :spec/verification :v "`V:PROP`, `V:MODEL`" :op :assert}
   {:e #blake3 "97af617c631bc6101a957ccd955346a218bab0ec05a2507ab57ece81f3101a0f" :a :db/ident :v :spec/inv-sync-002 :op :assert}
   {:e #blake3 "97af617c631bc6101a957ccd955346a218bab0ec05a2507ab57ece81f3101a0f" :a :spec/element-type :v :spec.element/invariant :op :assert}
   {:e #blake3 "97af617c631bc6101a957ccd955346a218bab0ec05a2507ab57ece81f3101a0f" :a :spec/namespace :v :spec.ns/sync :op :assert}
   {:e #blake3 "97af617c631bc6101a957ccd955346a218bab0ec05a2507ab57ece81f3101a0f" :a :db/doc :v "Barrier Timeout Safety" :op :assert}
   {:e #blake3 "97af617c631bc6101a957ccd955346a218bab0ec05a2507ab57ece81f3101a0f" :a :spec/source-file :v "08-sync.md" :op :assert}
   {:e #blake3 "97af617c631bc6101a957ccd955346a218bab0ec05a2507ab57ece81f3101a0f" :a :element/body :v "**Traces to**: ADRS PO-010\n**Verification**: `V:PROP`, `V:MODEL`\n**Stage**: 3\n\n#### Level 0 (Algebraic Law)\n```\n∀ barriers B with timeout T:\n  B resolves within T OR B times out with status :timed-out\n  No barrier hangs indefinitely.\n```\n\n#### Level 1 (State Invariant)\nA barrier always terminates — either by resolution (all respond) or by\ntimeout (deadline reached). The timed-out barrier records which participants\nresponded and which did not, for crash-recovery (PD-003).\n\n**Falsification**: A barrier that neither resolves nor times out.\n\n**Stateright model**: N agents, 1 barrier, timeout T. Verify all paths reach\n`:resolved` or `:timed-out` within T steps.\n\n---" :op :assert}
   {:e #blake3 "97af617c631bc6101a957ccd955346a218bab0ec05a2507ab57ece81f3101a0f" :a :spec/statement :v "``` ∀ barriers B with timeout T: B resolves within T OR B times out with status :timed-out No barrier hangs indefinitely. ```" :op :assert}
   {:e #blake3 "97af617c631bc6101a957ccd955346a218bab0ec05a2507ab57ece81f3101a0f" :a :spec/falsification :v "A barrier that neither resolves nor times out." :op :assert}
   {:e #blake3 "97af617c631bc6101a957ccd955346a218bab0ec05a2507ab57ece81f3101a0f" :a :element/traces-to :v "ADRS PO-010" :op :assert}
   {:e #blake3 "97af617c631bc6101a957ccd955346a218bab0ec05a2507ab57ece81f3101a0f" :a :spec/verification :v "`V:PROP`, `V:MODEL`" :op :assert}
   {:e #blake3 "eddcf236f31810bd386291533b2eb99acd37dbf40dc62d0aa7f805e30747de09" :a :db/ident :v :spec/inv-sync-003 :op :assert}
   {:e #blake3 "eddcf236f31810bd386291533b2eb99acd37dbf40dc62d0aa7f805e30747de09" :a :spec/element-type :v :spec.element/invariant :op :assert}
   {:e #blake3 "eddcf236f31810bd386291533b2eb99acd37dbf40dc62d0aa7f805e30747de09" :a :spec/namespace :v :spec.ns/sync :op :assert}
   {:e #blake3 "eddcf236f31810bd386291533b2eb99acd37dbf40dc62d0aa7f805e30747de09" :a :db/doc :v "Barrier Is Topology-Independent" :op :assert}
   {:e #blake3 "eddcf236f31810bd386291533b2eb99acd37dbf40dc62d0aa7f805e30747de09" :a :spec/source-file :v "08-sync.md" :op :assert}
   {:e #blake3 "eddcf236f31810bd386291533b2eb99acd37dbf40dc62d0aa7f805e30747de09" :a :element/body :v "**Traces to**: ADRS PD-005, SQ-005\n**Verification**: `V:MODEL`\n**Stage**: 3\n\n#### Level 0 (Algebraic Law)\n```\n∀ topologies T₁, T₂, ∀ participant sets P, ∀ datom sets D:\n  barrier(P, D, T₁).cut = barrier(P, D, T₂).cut\n  (the consistent cut depends only on participants and datoms, not topology)\n```\n\n#### Level 1 (State Invariant)\nStar, ring, mesh, and hierarchical topologies all produce the same consistent\ncut for the same inputs.\n\n**Falsification**: Two different topologies producing different cuts for the same\nparticipants and datom sets.\n\n**Stateright model**: Run barrier protocol under 3 topologies (star, ring, mesh).\nVerify identical cuts.\n\n---" :op :assert}
   {:e #blake3 "eddcf236f31810bd386291533b2eb99acd37dbf40dc62d0aa7f805e30747de09" :a :spec/statement :v "``` ∀ topologies T₁, T₂, ∀ participant sets P, ∀ datom sets D: barrier(P, D, T₁).cut = barrier(P, D, T₂).cut (the consistent cut depends only on participants and datoms, not topology) ```" :op :assert}
   {:e #blake3 "eddcf236f31810bd386291533b2eb99acd37dbf40dc62d0aa7f805e30747de09" :a :spec/falsification :v "Two different topologies producing different cuts for the same participants and datom sets." :op :assert}
   {:e #blake3 "eddcf236f31810bd386291533b2eb99acd37dbf40dc62d0aa7f805e30747de09" :a :element/traces-to :v "ADRS PD-005, SQ-005" :op :assert}
   {:e #blake3 "eddcf236f31810bd386291533b2eb99acd37dbf40dc62d0aa7f805e30747de09" :a :spec/verification :v "`V:MODEL`" :op :assert}
   {:e #blake3 "8383bc63e7cce083a46c95d62a4412c96ae44d7c467af4e87f8041dbc4861985" :a :db/ident :v :spec/inv-sync-004 :op :assert}
   {:e #blake3 "8383bc63e7cce083a46c95d62a4412c96ae44d7c467af4e87f8041dbc4861985" :a :spec/element-type :v :spec.element/invariant :op :assert}
   {:e #blake3 "8383bc63e7cce083a46c95d62a4412c96ae44d7c467af4e87f8041dbc4861985" :a :spec/namespace :v :spec.ns/sync :op :assert}
   {:e #blake3 "8383bc63e7cce083a46c95d62a4412c96ae44d7c467af4e87f8041dbc4861985" :a :db/doc :v "Barrier Entity Provenance" :op :assert}
   {:e #blake3 "8383bc63e7cce083a46c95d62a4412c96ae44d7c467af4e87f8041dbc4861985" :a :spec/source-file :v "08-sync.md" :op :assert}
   {:e #blake3 "8383bc63e7cce083a46c95d62a4412c96ae44d7c467af4e87f8041dbc4861985" :a :element/body :v "**Traces to**: ADRS FD-012\n**Verification**: `V:PROP`\n**Stage**: 3\n\n#### Level 0 (Algebraic Law)\n```\n∀ barrier operations:\n  ∃ Barrier entity in the store recording:\n    participants, status, timeout, cut (if resolved), responses\n```\n\n#### Level 1 (State Invariant)\nEvery barrier — resolved or timed-out — produces a Barrier entity in the store.\nThe barrier history is queryable.\n\n**Falsification**: A barrier operation that completes without creating a Barrier entity.\n\n---" :op :assert}
   {:e #blake3 "8383bc63e7cce083a46c95d62a4412c96ae44d7c467af4e87f8041dbc4861985" :a :spec/statement :v "``` ∀ barrier operations: ∃ Barrier entity in the store recording: participants, status, timeout, cut (if resolved), responses ```" :op :assert}
   {:e #blake3 "8383bc63e7cce083a46c95d62a4412c96ae44d7c467af4e87f8041dbc4861985" :a :spec/falsification :v "A barrier operation that completes without creating a Barrier entity." :op :assert}
   {:e #blake3 "8383bc63e7cce083a46c95d62a4412c96ae44d7c467af4e87f8041dbc4861985" :a :element/traces-to :v "ADRS FD-012" :op :assert}
   {:e #blake3 "8383bc63e7cce083a46c95d62a4412c96ae44d7c467af4e87f8041dbc4861985" :a :spec/verification :v "`V:PROP`" :op :assert}
   {:e #blake3 "6d86f449eed9f204671adfb2c338d37a51f25ab0b565f679de5f1bfe2d3a916a" :a :db/ident :v :spec/inv-sync-005 :op :assert}
   {:e #blake3 "6d86f449eed9f204671adfb2c338d37a51f25ab0b565f679de5f1bfe2d3a916a" :a :spec/element-type :v :spec.element/invariant :op :assert}
   {:e #blake3 "6d86f449eed9f204671adfb2c338d37a51f25ab0b565f679de5f1bfe2d3a916a" :a :spec/namespace :v :spec.ns/sync :op :assert}
   {:e #blake3 "6d86f449eed9f204671adfb2c338d37a51f25ab0b565f679de5f1bfe2d3a916a" :a :db/doc :v "Non-Monotonic Queries Require Barrier" :op :assert}
   {:e #blake3 "6d86f449eed9f204671adfb2c338d37a51f25ab0b565f679de5f1bfe2d3a916a" :a :spec/source-file :v "08-sync.md" :op :assert}
   {:e #blake3 "6d86f449eed9f204671adfb2c338d37a51f25ab0b565f679de5f1bfe2d3a916a" :a :element/body :v "**Traces to**: ADRS SQ-004\n**Verification**: `V:PROP`\n**Stage**: 3\n\n#### Level 0 (Algebraic Law)\n```\n∀ queries Q with mode = Barriered(barrier_id):\n  barrier_id references a resolved Barrier entity\n  Q is evaluated against barrier.cut (not local frontier)\n```\n\n#### Level 1 (State Invariant)\nA Barriered query mode requires a valid, resolved barrier. The query engine\nrejects Barriered queries referencing unresolved or timed-out barriers.\n\n**Falsification**: A Barriered query executing against a timed-out or nonexistent barrier.\n\n---" :op :assert}
   {:e #blake3 "6d86f449eed9f204671adfb2c338d37a51f25ab0b565f679de5f1bfe2d3a916a" :a :spec/statement :v "``` ∀ queries Q with mode = Barriered(barrier_id): barrier_id references a resolved Barrier entity Q is evaluated against barrier.cut (not local frontier) ```" :op :assert}
   {:e #blake3 "6d86f449eed9f204671adfb2c338d37a51f25ab0b565f679de5f1bfe2d3a916a" :a :spec/falsification :v "A Barriered query executing against a timed-out or nonexistent barrier." :op :assert}
   {:e #blake3 "6d86f449eed9f204671adfb2c338d37a51f25ab0b565f679de5f1bfe2d3a916a" :a :element/traces-to :v "ADRS SQ-004" :op :assert}
   {:e #blake3 "6d86f449eed9f204671adfb2c338d37a51f25ab0b565f679de5f1bfe2d3a916a" :a :spec/verification :v "`V:PROP`" :op :assert}
   {:e #blake3 "873fe65b5ea48b32148d9ebc8ac629d9a2ca41129fed1a8be58c763b26ac00b4" :a :db/ident :v :spec/adr-sync-001 :op :assert}
   {:e #blake3 "873fe65b5ea48b32148d9ebc8ac629d9a2ca41129fed1a8be58c763b26ac00b4" :a :spec/element-type :v :spec.element/adr :op :assert}
   {:e #blake3 "873fe65b5ea48b32148d9ebc8ac629d9a2ca41129fed1a8be58c763b26ac00b4" :a :spec/namespace :v :spec.ns/sync :op :assert}
   {:e #blake3 "873fe65b5ea48b32148d9ebc8ac629d9a2ca41129fed1a8be58c763b26ac00b4" :a :db/doc :v "Barrier as Explicit Coordination Point" :op :assert}
   {:e #blake3 "873fe65b5ea48b32148d9ebc8ac629d9a2ca41129fed1a8be58c763b26ac00b4" :a :spec/source-file :v "08-sync.md" :op :assert}
   {:e #blake3 "873fe65b5ea48b32148d9ebc8ac629d9a2ca41129fed1a8be58c763b26ac00b4" :a :element/body :v "**Traces to**: ADRS SQ-001, PO-010\n**Stage**: 3\n\n#### Problem\nHow to handle non-monotonic queries that depend on the absence of facts?\n\n#### Options\nA) **Always consistent** — all queries require global consistency. Too expensive.\nB) **Never consistent** — all queries are local frontier. Non-monotonic results vary.\nC) **Explicit barriers** — monotonic queries run locally; non-monotonic queries can\n   optionally use a barrier for consistency.\n\n#### Decision\n**Option C.** Most queries (Strata 0–1) are monotonic and need no coordination.\nNon-monotonic queries (Strata 2–5) produce useful approximate results at local\nfrontier but can use a barrier when precision is critical.\n\n#### Formal Justification\nCALM theorem: monotonic programs have coordination-free implementations.\nBarriers are needed only for non-monotonic queries where correctness\ndepends on knowing what is NOT present.\n\n---" :op :assert}
   {:e #blake3 "873fe65b5ea48b32148d9ebc8ac629d9a2ca41129fed1a8be58c763b26ac00b4" :a :element/traces-to :v "ADRS SQ-001, PO-010" :op :assert}
   {:e #blake3 "873fe65b5ea48b32148d9ebc8ac629d9a2ca41129fed1a8be58c763b26ac00b4" :a :adr/problem :v "How to handle non-monotonic queries that depend on the absence of facts?" :op :assert}
   {:e #blake3 "873fe65b5ea48b32148d9ebc8ac629d9a2ca41129fed1a8be58c763b26ac00b4" :a :adr/decision :v "**Option C.** Most queries (Strata 0–1) are monotonic and need no coordination. Non-monotonic queries (Strata 2–5) produce useful approximate results at local frontier but can use a barrier when precision is critical." :op :assert}
   {:e #blake3 "28ea406186556a73fc120c0b92b1972fac8f8a0031569ecc688f32ef2c073759" :a :db/ident :v :spec/adr-sync-002 :op :assert}
   {:e #blake3 "28ea406186556a73fc120c0b92b1972fac8f8a0031569ecc688f32ef2c073759" :a :spec/element-type :v :spec.element/adr :op :assert}
   {:e #blake3 "28ea406186556a73fc120c0b92b1972fac8f8a0031569ecc688f32ef2c073759" :a :spec/namespace :v :spec.ns/sync :op :assert}
   {:e #blake3 "28ea406186556a73fc120c0b92b1972fac8f8a0031569ecc688f32ef2c073759" :a :db/doc :v "Topology-Agnostic Protocol" :op :assert}
   {:e #blake3 "28ea406186556a73fc120c0b92b1972fac8f8a0031569ecc688f32ef2c073759" :a :spec/source-file :v "08-sync.md" :op :assert}
   {:e #blake3 "28ea406186556a73fc120c0b92b1972fac8f8a0031569ecc688f32ef2c073759" :a :element/body :v "**Traces to**: ADRS PD-005\n**Stage**: 3\n\n#### Problem\nShould the sync protocol prescribe a topology?\n\n#### Decision\nNo. The protocol provides primitives (initiate, report, exchange, resolve).\nTopology emerges from deployment. Single-agent (trivial — barrier with self),\nbilateral (two agents exchange), flat swarm (all-to-all), hierarchy (tree) are\nall valid using the same primitives.\n\n#### Formal Justification\nPrescribing topology limits applicability. The invariant (INV-SYNC-003) that\nresults are topology-independent means the protocol can support any topology\nwithout changing the correctness guarantees.\n\n---" :op :assert}
   {:e #blake3 "28ea406186556a73fc120c0b92b1972fac8f8a0031569ecc688f32ef2c073759" :a :element/traces-to :v "ADRS PD-005" :op :assert}
   {:e #blake3 "28ea406186556a73fc120c0b92b1972fac8f8a0031569ecc688f32ef2c073759" :a :adr/problem :v "Should the sync protocol prescribe a topology?" :op :assert}
   {:e #blake3 "28ea406186556a73fc120c0b92b1972fac8f8a0031569ecc688f32ef2c073759" :a :adr/decision :v "No. The protocol provides primitives (initiate, report, exchange, resolve). Topology emerges from deployment. Single-agent (trivial — barrier with self), bilateral (two agents exchange), flat swarm (all-to-all), hierarchy (tree) are all valid using the same primitives." :op :assert}
   {:e #blake3 "22f8450af05cc2ec306924cd82a5d5d08bb5c44e385365831805622fc4b805d1" :a :db/ident :v :spec/adr-sync-003 :op :assert}
   {:e #blake3 "22f8450af05cc2ec306924cd82a5d5d08bb5c44e385365831805622fc4b805d1" :a :spec/element-type :v :spec.element/adr :op :assert}
   {:e #blake3 "22f8450af05cc2ec306924cd82a5d5d08bb5c44e385365831805622fc4b805d1" :a :spec/namespace :v :spec.ns/sync :op :assert}
