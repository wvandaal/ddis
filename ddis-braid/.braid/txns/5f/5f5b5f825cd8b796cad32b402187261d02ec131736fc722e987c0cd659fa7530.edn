   {:e #blake3 "73f9e869143e1a6a137b8c4feaa7b6a7ef1b64fe83165ecc8dfe5a5e4172ab3b" :a :db/doc :v "Lookahead via Branch Simulation" :op :assert}
   {:e #blake3 "73f9e869143e1a6a137b8c4feaa7b6a7ef1b64fe83165ecc8dfe5a5e4172ab3b" :a :spec/source-file :v "12-guidance.md" :op :assert}
   {:e #blake3 "73f9e869143e1a6a137b8c4feaa7b6a7ef1b64fe83165ecc8dfe5a5e4172ab3b" :a :element/body :v "**Traces to**: ADRS GU-002\n**Verification**: `V:PROP`, `V:KANI`\n**Stage**: 2\n\n#### Level 0 (Algebraic Law)\nLookahead (1–5 steps) simulates action consequences by creating a virtual branch,\napplying hypothetical actions, and evaluating the resulting store state.\n\n`lookahead(actions, n) = evaluate(apply(fork(store), actions[0..n]))`\n\n#### Level 1 (State Invariant)\nVirtual branches created for lookahead are never committed to trunk.\nLookahead branches are ephemeral — created, evaluated, and discarded within\nthe QUERY_GUIDANCE transition.\n\n**Falsification**: A lookahead branch persists after the guidance query completes\nor its datoms leak into trunk.\n\n---" :op :assert}
   {:e #blake3 "73f9e869143e1a6a137b8c4feaa7b6a7ef1b64fe83165ecc8dfe5a5e4172ab3b" :a :spec/statement :v "Lookahead (1–5 steps) simulates action consequences by creating a virtual branch, applying hypothetical actions, and evaluating the resulting store state. `lookahead(actions, n) = evaluate(apply(fork(store), actions[0..n]))`" :op :assert}
   {:e #blake3 "73f9e869143e1a6a137b8c4feaa7b6a7ef1b64fe83165ecc8dfe5a5e4172ab3b" :a :spec/falsification :v "A lookahead branch persists after the guidance query completes or its datoms leak into trunk." :op :assert}
