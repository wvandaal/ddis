   {:e #blake3 "b54344136acf901ffe48a5ae98c6b56543cf7e1207016ffb7c1c398d00b23d18" :a :spec/element-type :v :spec.element/invariant :op :assert}
   {:e #blake3 "b54344136acf901ffe48a5ae98c6b56543cf7e1207016ffb7c1c398d00b23d18" :a :spec/namespace :v :spec.ns/seed :op :assert}
   {:e #blake3 "b54344136acf901ffe48a5ae98c6b56543cf7e1207016ffb7c1c398d00b23d18" :a :db/doc :v "Section Compression Priority" :op :assert}
   {:e #blake3 "b54344136acf901ffe48a5ae98c6b56543cf7e1207016ffb7c1c398d00b23d18" :a :spec/source-file :v "06-seed.md" :op :assert}
   {:e #blake3 "b54344136acf901ffe48a5ae98c6b56543cf7e1207016ffb7c1c398d00b23d18" :a :element/body :v "**Traces to**: SEED §5, §8, ADRS IB-004, PO-003\n**Verification**: `V:PROP`\n**Stage**: 0\n\n#### Level 0 (Algebraic Law)\n```\nUnder budget pressure, sections compress in priority order (first-to-compress → last):\n  1. State       — lowest marginal value per token; reconstructible via store queries\n  2. Constraints — reconstructible from store; can degrade to ID-only references\n  3. Orientation — short, mostly fixed across sessions; compress but never omit\n  4. Warnings    — safety-critical, high behavioral leverage per token\n  5. Directive   — directly controls agent behavior; last to compress\n\n∀ ASSEMBLE operations under budget B:\n  if tokens(full_seed) > B:\n    compress(State) before compress(Constraints)\n    compress(Constraints) before compress(Orientation)\n    compress(Orientation) before compress(Warnings)\n    compress(Warnings) before compress(Directive)\n```\n\n#### Level 1 (State Invariant)\nThe ASSEMBLE pipeline compresses sections in priority order, not by section\nposition. State absorbs compression first because it is fully reconstructible\nfrom the store. Directive absorbs compression last because it directly controls\nthe agent's next action. Warnings are second-last because they are safety-critical\nand have high behavioral leverage per token.\n\n**Falsification**: An ASSEMBLE operation that compresses Warnings or Directive while\nState still contains verbose detail, or that omits Directive before omitting State.\n\n---" :op :assert}
   {:e #blake3 "b54344136acf901ffe48a5ae98c6b56543cf7e1207016ffb7c1c398d00b23d18" :a :spec/statement :v "``` Under budget pressure, sections compress in priority order (first-to-compress → last): 1. State       — lowest marginal value per token; reconstructible via store queries 2. Constraints — reconstructible from store; can degrade to ID-only references 3. Orientation — short, mostly fixed across sessions; compress but never omit 4. Warnings    — safety-critical, high behavioral leverage per token 5. Directive   — directly controls agent behavior; last to compress ∀ ASSEMBLE operations under budget B: if tokens(full_seed) > B: compress(State) before compress(Constraints) compress(Constraints) before compress(Orientation) compress(Orientation) before compress(Warnings) compress(Warnings) before compress(Directive) ```" :op :assert}
   {:e #blake3 "b54344136acf901ffe48a5ae98c6b56543cf7e1207016ffb7c1c398d00b23d18" :a :spec/falsification :v "An ASSEMBLE operation that compresses Warnings or Directive while State still contains verbose detail, or that omits Directive before omitting State." :op :assert}
   {:e #blake3 "b54344136acf901ffe48a5ae98c6b56543cf7e1207016ffb7c1c398d00b23d18" :a :element/traces-to :v "SEED §5, §8, ADRS IB-004, PO-003" :op :assert}
   {:e #blake3 "b54344136acf901ffe48a5ae98c6b56543cf7e1207016ffb7c1c398d00b23d18" :a :spec/verification :v "`V:PROP`" :op :assert}
   {:e #blake3 "f8aad9e52dd0215142a6c9b34de1e0af72221ed588c2421a0348716aeef00e99" :a :db/ident :v :spec/inv-seed-005 :op :assert}
   {:e #blake3 "f8aad9e52dd0215142a6c9b34de1e0af72221ed588c2421a0348716aeef00e99" :a :spec/element-type :v :spec.element/invariant :op :assert}
   {:e #blake3 "f8aad9e52dd0215142a6c9b34de1e0af72221ed588c2421a0348716aeef00e99" :a :spec/namespace :v :spec.ns/seed :op :assert}
   {:e #blake3 "f8aad9e52dd0215142a6c9b34de1e0af72221ed588c2421a0348716aeef00e99" :a :db/doc :v "Demonstration Density" :op :assert}
   {:e #blake3 "f8aad9e52dd0215142a6c9b34de1e0af72221ed588c2421a0348716aeef00e99" :a :spec/source-file :v "06-seed.md" :op :assert}
   {:e #blake3 "f8aad9e52dd0215142a6c9b34de1e0af72221ed588c2421a0348716aeef00e99" :a :element/body :v "**Traces to**: ADRS GU-003, GU-004, INV-GUIDANCE-007\n**Verification**: `V:PROP`\n**Stage**: 0\n\n#### Level 0 (Algebraic Law)\n```\n∀ constraint clusters C in the seed Constraints section:\n  if |C| ≥ 2 and budget permits:\n    ∃ at least one demonstration d showing compliance with C\n    d is a concrete 20-40 token example, not prose\n\nA constraint cluster is a set of related INVs/ADRs/NEGs that govern\nthe same behavioral domain (e.g., {INV-STORE-001, INV-STORE-003}\nform an append-only + content-addressed cluster).\n```\n\n#### Level 1 (State Invariant)\nThe seed includes at least one worked example per constraint cluster when\nbudget permits. Demonstrations activate the LLM's pattern-completion substrate\nfar more effectively than invariant statements alone. A 30-token demonstration\nis worth approximately 10x its token cost in behavioral activation.\n\nUnder budget pressure, demonstrations compress before their parent constraints\n(constraints without demonstrations are still useful; demonstrations without\nconstraints lack context).\n\n**Falsification**: A seed with 3+ related constraints and budget > 1000 tokens\nthat contains zero demonstrations for the cluster.\n\n---" :op :assert}
   {:e #blake3 "f8aad9e52dd0215142a6c9b34de1e0af72221ed588c2421a0348716aeef00e99" :a :spec/statement :v "``` ∀ constraint clusters C in the seed Constraints section: if |C| ≥ 2 and budget permits: ∃ at least one demonstration d showing compliance with C d is a concrete 20-40 token example, not prose A constraint cluster is a set of related INVs/ADRs/NEGs that govern the same behavioral domain (e.g., {INV-STORE-001, INV-STORE-003} form an append-only + content-addressed cluster). ```" :op :assert}
   {:e #blake3 "f8aad9e52dd0215142a6c9b34de1e0af72221ed588c2421a0348716aeef00e99" :a :spec/falsification :v "A seed with 3+ related constraints and budget > 1000 tokens that contains zero demonstrations for the cluster." :op :assert}
   {:e #blake3 "f8aad9e52dd0215142a6c9b34de1e0af72221ed588c2421a0348716aeef00e99" :a :element/traces-to :v "ADRS GU-003, GU-004, INV-GUIDANCE-007" :op :assert}
   {:e #blake3 "f8aad9e52dd0215142a6c9b34de1e0af72221ed588c2421a0348716aeef00e99" :a :spec/verification :v "`V:PROP`" :op :assert}
