   {:e #blake3 "0c490bf5ee6bfd43decea8886a1a88e3cfe02cbbae4edab03a6216ec0f7f440d" :a :db/doc :v "Divergence as Datalog Program" :op :assert}
   {:e #blake3 "0c490bf5ee6bfd43decea8886a1a88e3cfe02cbbae4edab03a6216ec0f7f440d" :a :spec/source-file :v "18-trilateral.md" :op :assert}
   {:e #blake3 "0c490bf5ee6bfd43decea8886a1a88e3cfe02cbbae4edab03a6216ec0f7f440d" :a :element/body :v "**Traces to**: INV-QUERY-001 (CALM-compliant monotonic reads)\n**Verification**: `V:PROP`\n**Stage**: 0\n\n#### Level 0 (Algebraic Law)\n```\nΦ is expressible as a Stratum 5 Datalog query (INV-QUERY-005):\n\n  -- Unlinked intent (no :spec/traces-to from spec)\n  unlinked_intent(E) :- intent_entity(E), not traced_from_spec(E).\n  traced_from_spec(E) :- [_, :spec/traces-to, E, _, :assert].\n\n  -- Unlinked spec (no :spec/implements from impl)\n  unlinked_spec(E) :- spec_entity(E), not implemented_by(E).\n  implemented_by(E) :- [_, :spec/implements, E, _, :assert].\n\n  -- Divergence counts\n  d_is = count(unlinked_intent) + count(untraced_spec).\n  d_sp = count(unlinked_spec) + count(unlinked_impl).\n\n  phi = w1 * d_is + w2 * d_sp.\n```\n\n#### Level 1 (State Invariant)\nBecause Φ is a Datalog program over the store, it inherits the CALM\ncompliance guarantees of the query engine (INV-QUERY-001): the computation\nis monotone (adding datoms can only change counts upward), deterministic\n(same store produces same Φ), and incrementalizable (delta-maintenance via\nsemi-naive evaluation).\n\n**Falsification**: The Φ computation cannot be expressed as a Datalog program,\nor the computation produces different results when evaluated incrementally\nvs. from scratch.\n\n---" :op :assert}
   {:e #blake3 "0c490bf5ee6bfd43decea8886a1a88e3cfe02cbbae4edab03a6216ec0f7f440d" :a :spec/statement :v "``` Φ is expressible as a Stratum 5 Datalog query (INV-QUERY-005): -- Unlinked intent (no :spec/traces-to from spec) unlinked_intent(E) :- intent_entity(E), not traced_from_spec(E). traced_from_spec(E) :- [_, :spec/traces-to, E, _, :assert]. -- Unlinked spec (no :spec/implements from impl) unlinked_spec(E) :- spec_entity(E), not implemented_by(E). implemented_by(E) :- [_, :spec/implements, E, _, :assert]. -- Divergence counts d_is = count(unlinked_intent) + count(untraced_spec). d_sp = count(unlinked_spec) + count(unlinked_impl). phi = w1 * d_is + w2 * d_sp. ```" :op :assert}
   {:e #blake3 "0c490bf5ee6bfd43decea8886a1a88e3cfe02cbbae4edab03a6216ec0f7f440d" :a :spec/falsification :v "The Φ computation cannot be expressed as a Datalog program, or the computation produces different results when evaluated incrementally vs. from scratch." :op :assert}
