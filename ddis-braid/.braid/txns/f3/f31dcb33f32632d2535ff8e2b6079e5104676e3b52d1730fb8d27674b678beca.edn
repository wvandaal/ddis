   {:e #blake3 "7096af37a7d29857a863a2c1c52e3c4e28f56ae7ad354719bf81a2026dbe180a" :a :spec/falsification :v "Violated if any of: (A) live.store().len() after write_tx does not include the new datoms. (B) Deserializing store.bin after write_tx produces a different datom count than live.store().len(). (C) A full rebuild from txn files produces a different datom count than the cached store. (D) fitness() differs between in-memory and cached stores." :op :assert}
   {:e #blake3 "7096af37a7d29857a863a2c1c52e3c4e28f56ae7ad354719bf81a2026dbe180a" :a :spec/id :v "INV-STORE-020" :op :assert}
   {:e #blake3 "7096af37a7d29857a863a2c1c52e3c4e28f56ae7ad354719bf81a2026dbe180a" :a :spec/namespace :v :spec.ns/STORE :op :assert}
   {:e #blake3 "7096af37a7d29857a863a2c1c52e3c4e28f56ae7ad354719bf81a2026dbe180a" :a :spec/statement :v "After any LiveStore::write_tx(tx), the following three representations are consistent: (1) The in-memory Store contains all datoms from tx. (2) The transaction file exists on disk at .braid/txns/{shard}/{hash}.edn with correct content. (3) The binary cache at .braid/.cache/store.bin, when deserialized, produces a Store with identical datom set and fitness to the in-memory Store. Formally: let S_mem be the in-memory store after write_tx, let S_disk be Store::from_datoms(all txn files), let S_cache be deserialize(store.bin). Then S_mem.datom_set() == S_disk.datom_set() == S_cache.datom_set() and S_mem.fitness() == S_cache.fitness(). This is the checkpoint-equals-fold invariant." :op :assert}
   {:e #blake3 "ca67de46a9bfb991432daed52ffbc0304ef01adbfc1751caf49ef26c26a0983a" :a :db/doc :v "Violated if any of: (A) live.store().len() after write_tx does not include the new datoms. (B) Deserializing store.bin after write_tx produces a different datom count than live.store().len(). (C) A full rebuild from txn files produces a different datom count than the cached store. (D) fitness() differs between in-memory and cached stores." :op :assert}
